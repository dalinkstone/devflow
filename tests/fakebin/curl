#!/usr/bin/env bash
# Fake curl for devflow tests (Daytona ssh-access API + ntfy push endpoint).
set -u
[ -n "${FAKE_LOG:-}" ] && printf 'curl %s\n' "$*" >> "$FAKE_LOG"
for a in "$@"; do
  case "$a" in
    *"/ssh-access"*)
      printf '{"token":"faketok123","sshCommand":"ssh faketok123@ssh.app.daytona.io"}'
      exit 0 ;;
    *"/api-keys"*)
      printf '{"name":"devflow-sandboxes","value":"dtn_MINTEDFAKE"}'
      exit 0 ;;
    *"/sandbox"*)
      # key-validation probe (GET /sandbox) — accept
      exit 0 ;;
    *"ntfy.sh/"*)
      # ntfy push endpoint — accept silently (argv already logged above)
      exit 0 ;;
  esac
done
exit 22
