#!/usr/bin/env bash
# ============================================================================
#  devflow — your agentic cloud dev environment
#
#  Spin up Claude Code or Codex in a Daytona sandbox using your existing
#  subscriptions (Claude Max / ChatGPT Pro) — no agent API keys. Optional
#  deployment credentials are forwarded only through explicit flags. Sessions
#  live in tmux inside the sandbox, so you can close your laptop and reattach from
#  anywhere with `devflow attach`.
#
#  https://github.com/dalinkstone/devflow
# ============================================================================
set -u
set -o pipefail

DEVFLOW_VERSION="0.3.0"

# ----------------------------------------------------------------------------
# Config (precedence: environment > config file > built-in default)
# ----------------------------------------------------------------------------
CONFIG_DIR="${DEVFLOW_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/devflow}"
CONFIG_FILE="$CONFIG_DIR/config"
SECRETS_FILE="$CONFIG_DIR/secrets"

GH_PIN_VERSION="2.96.0"          # fallback for in-sandbox gh install
CODEX_PIN_TAG="rust-v0.142.5"    # fallback for in-sandbox codex install
DT_PIN_VERSION="0.199.0"         # fallback for in-sandbox daytona install (--with-daytona)
DV_EXPECTED_PROVISION_VERSION=5

_CONFIG_KEYS="DEVFLOW_AGENT DEVFLOW_SIZE DEVFLOW_CPU DEVFLOW_MEMORY DEVFLOW_DISK DEVFLOW_AUTO_STOP DEVFLOW_TARGET DEVFLOW_SNAPSHOT DEVFLOW_CLAUDE_AUTH DEVFLOW_EXEC_STYLE DEVFLOW_WORKROOT DEVFLOW_HARNESS DEVFLOW_NTFY_URL DEVFLOW_NTFY_TOPIC DEVFLOW_AUTO_HANDOFF"

load_config() {
  # 1) preserve values that came from the caller's environment
  local k v _envsaved=""
  for k in $_CONFIG_KEYS DEVFLOW_CLAUDE_TOKEN DEVFLOW_DAYTONA_SANDBOX_KEY; do
    eval "v=\${$k-__devflow_unset__}"
    if [ "$v" != "__devflow_unset__" ]; then
      _envsaved="$_envsaved $k=$(printf '%q' "$v")"
    fi
  done
  # 2) config + secrets files (user-owned, chmod 600)
  # shellcheck disable=SC1090
  [ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"
  # shellcheck disable=SC1090
  [ -f "$SECRETS_FILE" ] && . "$SECRETS_FILE"
  # 3) environment wins
  [ -n "$_envsaved" ] && eval "$_envsaved"
  # 4) defaults fill the gaps
  : "${DEVFLOW_AGENT:=claude}"          # claude | codex | both | none
  : "${DEVFLOW_SIZE:=}"                 # small | medium | large; "" = medium
  : "${DEVFLOW_CPU:=}"                  # legacy; maps to the smallest size that fits
  : "${DEVFLOW_MEMORY:=}"               # legacy (MB); ditto
  : "${DEVFLOW_DISK:=}"                 # legacy (GB); ditto
  : "${DEVFLOW_AUTO_STOP:=0}"           # minutes; 0 = never (close your laptop safely)
  : "${DEVFLOW_TARGET:=}"               # us | eu | "" = org default
  : "${DEVFLOW_SNAPSHOT:=}"             # custom snapshot; "" = Daytona default image
  : "${DEVFLOW_CLAUDE_AUTH:=auto}"      # auto | token | creds
  : "${DEVFLOW_EXEC_STYLE:=}"           # join | argv | "" = auto-probe
  : "${DEVFLOW_WORKROOT:=work}"         # dir under $HOME in the sandbox
  : "${DEVFLOW_HARNESS:=auto}"          # auto | omc | omx | both | core
  : "${DEVFLOW_NTFY_URL:=https://ntfy.sh}"  # push server (self-hostable)
  : "${DEVFLOW_NTFY_TOPIC:=}"           # private topic; set by 'mobile --setup-push'
  : "${DEVFLOW_AUTO_HANDOFF:=}"         # ""=off | auto|push|op|bw|note — send reconnect line after every 'up'
  : "${DEVFLOW_CLAUDE_TOKEN:=}"
  : "${DEVFLOW_DAYTONA_SANDBOX_KEY:=}"  # minted API key forwarded by --with-daytona
  return 0
}

resolve_harness() { # AGENT REQUESTED -> effective harness
  local agent="$1" req="$2"
  case "$req" in
    auto)
      case "$agent" in
        claude) printf 'omc' ;;
        codex)  printf 'omx' ;;
        both)   printf 'both' ;;
        *)      printf 'core' ;;
      esac ;;
    none) printf 'core' ;;
    *)    printf '%s' "$req" ;;
  esac
}

# Daytona sizes sandboxes via its fixed-size default snapshots — the API
# rejects raw --cpu/--memory/--disk whenever a snapshot backs the sandbox,
# and the default image is a snapshot too. Sizes:
#   small = 1cpu/1gb/3gb · medium = 2cpu/4gb/8gb · large = 4cpu/8gb/10gb
size_desc() { # SIZE -> "2cpu/4gb/8gb"
  case "$1" in
    small)  printf '1cpu/1gb/3gb' ;;
    medium) printf '2cpu/4gb/8gb' ;;
    large)  printf '4cpu/8gb/10gb' ;;
  esac
}

size_for_resources() { # CPU MEM_MB DISK_GB (legacy knobs) -> smallest size that fits
  local cpu="${1:-1}" mem="${2:-1024}" disk="${3:-3}" n
  for n in "$cpu" "$mem" "$disk"; do
    case "$n" in ''|*[!0-9]*) printf 'large'; return 0 ;; esac
  done
  if [ "$cpu" -le 1 ] && [ "$mem" -le 1024 ] && [ "$disk" -le 3 ]; then printf 'small'
  elif [ "$cpu" -le 2 ] && [ "$mem" -le 4096 ] && [ "$disk" -le 8 ]; then printf 'medium'
  else printf 'large'; fi
}

default_size() { # from config: DEVFLOW_SIZE wins, legacy resources map, else medium
  if [ -n "$DEVFLOW_SIZE" ]; then printf '%s' "$DEVFLOW_SIZE"
  elif [ -n "${DEVFLOW_CPU}${DEVFLOW_MEMORY}${DEVFLOW_DISK}" ]; then
    size_for_resources "$DEVFLOW_CPU" "$DEVFLOW_MEMORY" "$DEVFLOW_DISK"
  else printf 'medium'; fi
}

config_set() { # config_set FILE KEY VALUE
  local file="$1" key="$2" val="$3" tmp
  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR" 2>/dev/null || true
  touch "$file"
  chmod 600 "$file"
  tmp="$(mktemp "${TMPDIR:-/tmp}/devflow.XXXXXX")"
  grep -v "^${key}=" "$file" >"$tmp" 2>/dev/null || true
  printf '%s=%q\n' "$key" "$val" >>"$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file"
}

# ----------------------------------------------------------------------------
# UI helpers
# ----------------------------------------------------------------------------
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_BLUE=$'\033[34m'; C_CYAN=$'\033[36m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_DIM=""; C_BLUE=""; C_CYAN=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_RESET=""
fi

say()  { printf '%s\n' "${C_CYAN}${C_BOLD}devflow${C_RESET} $*"; }
step() { printf '%s\n' "${C_BLUE}▸${C_RESET} $*"; }
ok()   { printf '%s\n' "${C_GREEN}✓${C_RESET} $*"; }
warn() { printf '%s\n' "${C_YELLOW}!${C_RESET} $*" >&2; }
err()  { printf '%s\n' "${C_RED}✗${C_RESET} $*" >&2; }
die()  { err "$@"; exit 1; }

confirm() { # confirm "question" -> 0 yes / 1 no
  local ans
  printf '%s' "${C_YELLOW}?${C_RESET} $1 [y/N] "
  read -r ans || true
  case "$ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

# ----------------------------------------------------------------------------
# Small utilities
# ----------------------------------------------------------------------------
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1 — run 'devflow setup' (or: $2)"; }
have_cmd() { command -v "$1" >/dev/null 2>&1; }
need_val() { [ -n "${2:-}" ] || die "flag $1 requires a value"; }

b64_encode() { # portable, single-line output
  if base64 --help 2>&1 | grep -q -- '-w'; then base64 -w0; else base64 | tr -d '\n'; fi
}

b64_decode() { # portable stdin decoder
  local data
  data="$(cat)"
  printf '%s' "$data" | base64 --decode 2>/dev/null \
    || printf '%s' "$data" | base64 -D 2>/dev/null \
    || printf '%s' "$data" | base64 -d
}

sanitize_name() {
  local out
  out="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-z0-9-]/-/g' -e 's/--*/-/g' -e 's/^-//' -e 's/-$//' | cut -c1-40)"
  [ -n "$out" ] && printf '%s' "$out" || printf 'sandbox'
}

repo_from_arg() { # normalize repo arg -> owner/name (empty if not repo-ish)
  local a="$1"
  a="${a%.git}"
  case "$a" in
    https://github.com/*) a="${a#https://github.com/}" ;;
    http://github.com/*)  a="${a#http://github.com/}" ;;
    git@github.com:*)     a="${a#git@github.com:}" ;;
  esac
  case "$a" in
    */*/*) printf '' ;;
    ?*/?*) printf '%s' "$a" ;;
    *)     printf '' ;;
  esac
}

current_repo() { # owner/name of cwd's github origin, or empty
  local url
  url="$(git config --get remote.origin.url 2>/dev/null || true)"
  [ -n "$url" ] || { printf ''; return 0; }
  repo_from_arg "$url"
}

# ----------------------------------------------------------------------------
# Daytona wrappers
# ----------------------------------------------------------------------------
dt() { command daytona "$@"; }

# NOTE: must be an org-scoped call that works under BOTH auth modes — the CLI
# refuses `organization` subcommands entirely under api-key auth
dt_auth_check() { dt list >/dev/null 2>&1; }

dt_info_json() { dt info "$1" -f json 2>/dev/null; }

sandbox_state() { # NAME -> state string or "missing"
  local j
  j="$(dt_info_json "$1")" || { printf 'missing'; return 0; }
  printf '%s' "$j" | jq -r '.state // .status // "unknown"'
}

wait_for_state() { # NAME WANT TIMEOUT_S
  local name="$1" want="$2" timeout="${3:-180}" waited=0 st=""
  while [ "$waited" -lt "$timeout" ]; do
    st="$(sandbox_state "$name")"
    case "$st" in
      "$want") return 0 ;;
      error|build_failed|destroyed) die "sandbox '$name' entered state: $st" ;;
    esac
    sleep 2
    waited=$((waited + 2))
  done
  die "timed out waiting for sandbox '$name' to be $want (last state: ${st:-unknown})"
}

# --- remote exec ------------------------------------------------------------
# Different daytona CLI builds pass `exec … -- args` through differently: some
# join args into one shell string, some preserve argv. Probe once, cache.
probe_exec_style() { # NAME (sandbox must be started)
  local out
  out="$(dt exec "$1" --timeout 30 -- printf %s 'x y' 2>/dev/null || true)"
  case "$out" in
    "x y") DEVFLOW_EXEC_STYLE="argv" ;;
    "xy")  DEVFLOW_EXEC_STYLE="join" ;;
    *)
      out="$(dt exec "$1" --timeout 30 -- echo 'dv probe' 2>/dev/null || true)"
      case "$out" in
        *"dv probe"*) DEVFLOW_EXEC_STYLE="argv" ;;
        *)            DEVFLOW_EXEC_STYLE="join" ;;
      esac
      ;;
  esac
  config_set "$CONFIG_FILE" DEVFLOW_EXEC_STYLE "$DEVFLOW_EXEC_STYLE"
}

dt_run() { # NAME SCRIPT [TIMEOUT] — run a (newline-free) bash command string
  local name="$1" script="$2" timeout="${3:-0}"
  [ -n "$DEVFLOW_EXEC_STYLE" ] || probe_exec_style "$name"
  if [ "$DEVFLOW_EXEC_STYLE" = "argv" ]; then
    dt exec "$name" --timeout "$timeout" -- bash -lc "$script"
  else
    local quoted
    quoted="$(printf '%q' "$script")"
    dt exec "$name" --timeout "$timeout" -- "bash -lc $quoted"
  fi
}

dt_push_file() { # NAME REMOTE_PATH  (content on stdin) — chunked base64 upload
  local name="$1" remote="$2" b64 len off=0 chunk=6000 part first=1
  b64="$(b64_encode)"
  len=${#b64}
  while [ "$off" -lt "$len" ]; do
    part="${b64:$off:$chunk}"
    if [ "$first" = 1 ]; then
      dt_run "$name" "umask 077 && printf %s '$part' > '$remote.b64'" 120 >/dev/null
      first=0
    else
      dt_run "$name" "printf %s '$part' >> '$remote.b64'" 120 >/dev/null
    fi
    off=$((off + chunk))
  done
  dt_run "$name" "umask 077 && base64 -d '$remote.b64' > '$remote' && rm -f '$remote.b64'" 60 >/dev/null
}

# ----------------------------------------------------------------------------
# Local auth harvesting (memoized; secrets never printed or logged)
# ----------------------------------------------------------------------------
_HARVESTED=0
harvest_all() {
  [ "$_HARVESTED" = 1 ] && return 0
  _HARVESTED=1
  # --- claude: token (preferred) or credentials copy ---
  CLAUDE_MODE="none"; CLAUDE_TOKEN=""; CLAUDE_CREDS_B64=""
  if [ "$DEVFLOW_CLAUDE_AUTH" != "creds" ] && [ -n "$DEVFLOW_CLAUDE_TOKEN" ]; then
    CLAUDE_MODE="token"; CLAUDE_TOKEN="$DEVFLOW_CLAUDE_TOKEN"
  elif [ "$DEVFLOW_CLAUDE_AUTH" != "token" ]; then
    local creds=""
    if [ "$(uname -s)" = "Darwin" ]; then
      creds="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)"
    fi
    if [ -z "$creds" ] && [ -f "$HOME/.claude/.credentials.json" ]; then
      creds="$(cat "$HOME/.claude/.credentials.json")"
    fi
    if [ -n "$creds" ]; then
      CLAUDE_MODE="creds"
      CLAUDE_CREDS_B64="$(printf '%s' "$creds" | b64_encode)"
    fi
  fi
  # --- codex: ChatGPT sign-in file ---
  CODEX_AUTH_B64=""
  local cf="${CODEX_HOME:-$HOME/.codex}/auth.json"
  [ -f "$cf" ] && CODEX_AUTH_B64="$(b64_encode <"$cf")"
  # --- github ---
  GH_TOKEN_VAL=""
  have_cmd gh && GH_TOKEN_VAL="$(gh auth token 2>/dev/null || true)"
  # --- git identity ---
  GIT_NAME="$(git config --global user.name 2>/dev/null || git config user.name 2>/dev/null || true)"
  GIT_EMAIL="$(git config --global user.email 2>/dev/null || git config user.email 2>/dev/null || true)"

  # --- explicit deployment credentials (opt-in per invocation) ---
  AWS_ENABLED=0 AWS_CREDS_B64="" AWS_CONFIG_B64="" AWS_EXPIRATION="" AWS_SOURCE_PROFILE=""
  SECRET_ENV_B64="" SECRET_ENV_NAMES=""
  local env_name env_value env_payload="" env_item env_assignment
  if [ -n "${DEVFLOW_AWS_PROFILE:-}" ]; then
    have_cmd aws || die "--aws-profile requires the AWS CLI locally"
    local aws_json aws_key aws_secret aws_token aws_region aws_creds aws_config
    aws_json="$(aws configure export-credentials --profile "$DEVFLOW_AWS_PROFILE" --format process 2>/dev/null)" \
      || die "could not resolve AWS profile '$DEVFLOW_AWS_PROFILE' (log in/refresh it, then retry)"
    aws_key="$(printf '%s' "$aws_json" | jq -r '.AccessKeyId // empty')"
    aws_secret="$(printf '%s' "$aws_json" | jq -r '.SecretAccessKey // empty')"
    aws_token="$(printf '%s' "$aws_json" | jq -r '.SessionToken // empty')"
    AWS_EXPIRATION="$(printf '%s' "$aws_json" | jq -r '.Expiration // empty')"
    [ -n "$aws_key" ] && [ -n "$aws_secret" ] \
      || die "AWS profile '$DEVFLOW_AWS_PROFILE' did not resolve usable credentials"
    if { [ -z "$aws_token" ] || [ -z "$AWS_EXPIRATION" ]; } && [ "${DEVFLOW_ALLOW_STATIC_AWS:-0}" != 1 ]; then
      die "AWS profile '$DEVFLOW_AWS_PROFILE' resolved non-expiring/static credentials; use an assumed-role profile with an expiring STS session (or explicitly accept the risk with --allow-static-aws)"
    fi
    aws sts get-caller-identity --profile "$DEVFLOW_AWS_PROFILE" >/dev/null 2>&1 \
      || die "AWS profile '$DEVFLOW_AWS_PROFILE' failed sts:GetCallerIdentity"
    aws_region="$(aws configure get region --profile "$DEVFLOW_AWS_PROFILE" 2>/dev/null || true)"
    [ -n "$aws_region" ] || aws_region="${AWS_REGION:-${AWS_DEFAULT_REGION:-us-east-1}}"
    aws_creds="[devflow]
aws_access_key_id = $aws_key
aws_secret_access_key = $aws_secret"
    [ -n "$aws_token" ] && aws_creds="$aws_creds
aws_session_token = $aws_token"
    aws_config="[profile devflow]
region = $aws_region
output = json"
    AWS_CREDS_B64="$(printf '%s\n' "$aws_creds" | b64_encode)"
    AWS_CONFIG_B64="$(printf '%s\n' "$aws_config" | b64_encode)"
    AWS_SOURCE_PROFILE="$DEVFLOW_AWS_PROFILE"
    AWS_ENABLED=1
  fi

  if [ -n "${DEVFLOW_SECRET_ENV_NAMES:-}" ]; then
    for env_name in $DEVFLOW_SECRET_ENV_NAMES; do
      case "$env_name" in
        ''|[0-9]*|*[!A-Za-z0-9_]*) die "invalid --secret-env name '$env_name'" ;;
      esac
      eval "env_value=\${$env_name-}"
      [ -n "$env_value" ] || die "--secret-env $env_name is unset or empty"
      env_payload="$env_payload$(printf 'export %s=%q' "$env_name" "$env_value")"$'\n'
      SECRET_ENV_NAMES="${SECRET_ENV_NAMES}${SECRET_ENV_NAMES:+ }$env_name"
    done
  fi
  if [ -n "${DEVFLOW_ENV_ITEMS:-}" ]; then
    for env_item in $DEVFLOW_ENV_ITEMS; do
      env_assignment="$(printf '%s' "$env_item" | b64_decode)" \
        || die "could not decode --env assignment"
      case "$env_assignment" in
        *=*) env_name="${env_assignment%%=*}"; env_value="${env_assignment#*=}" ;;
        *) die "--env expects NAME=VALUE" ;;
      esac
      case "$env_name" in
        ''|[0-9]*|*[!A-Za-z0-9_]*) die "invalid --env name '$env_name'" ;;
      esac
      env_payload="$env_payload$(printf 'export %s=%q' "$env_name" "$env_value")"$'\n'
      SECRET_ENV_NAMES="${SECRET_ENV_NAMES}${SECRET_ENV_NAMES:+ }$env_name"
    done
  fi
  [ -n "$env_payload" ] && SECRET_ENV_B64="$(printf '%s' "$env_payload" | b64_encode)"
  return 0
}

build_secrets_bundle() { # stdout: env file consumed by the sandbox provisioner
  harvest_all
  printf 'DV_CLAUDE_MODE=%s\n' "$CLAUDE_MODE"
  printf 'DV_CLAUDE_TOKEN=%s\n' "$CLAUDE_TOKEN"
  printf 'DV_CLAUDE_CREDS_B64=%s\n' "$CLAUDE_CREDS_B64"
  printf 'DV_CODEX_AUTH_B64=%s\n' "$CODEX_AUTH_B64"
  printf 'DV_GH_TOKEN=%s\n' "$GH_TOKEN_VAL"
  printf 'DV_GIT_NAME=%q\n' "${GIT_NAME:-}"
  printf 'DV_GIT_EMAIL=%q\n' "${GIT_EMAIL:-}"
  printf 'DV_GH_PIN=%s\n' "$GH_PIN_VERSION"
  printf 'DV_CODEX_PIN=%s\n' "$CODEX_PIN_TAG"
  printf 'DV_AWS_ENABLED=%s\n' "$AWS_ENABLED"
  printf 'DV_AWS_CREDS_B64=%s\n' "$AWS_CREDS_B64"
  printf 'DV_AWS_CONFIG_B64=%s\n' "$AWS_CONFIG_B64"
  printf 'DV_AWS_EXPIRATION=%q\n' "$AWS_EXPIRATION"
  printf 'DV_AWS_SOURCE_PROFILE=%q\n' "$AWS_SOURCE_PROFILE"
  printf 'DV_SECRET_ENV_B64=%s\n' "$SECRET_ENV_B64"
  printf 'DV_SECRET_ENV_NAMES=%q\n' "$SECRET_ENV_NAMES"
}

auth_summary() { # print what will be synced (no secret values)
  harvest_all
  case "$CLAUDE_MODE" in
    token) ok "Claude Code: long-lived subscription token" ;;
    creds) ok "Claude Code: local subscription credentials will be copied"
           step "${C_DIM}tip: 'devflow token' creates a dedicated 1-year token (avoids logout races)${C_RESET}" ;;
    none)  warn "Claude Code: no subscription auth found — run 'devflow token' (or log in to claude locally)" ;;
  esac
  if [ -n "$CODEX_AUTH_B64" ]; then ok "Codex: ChatGPT sign-in will be copied"
  else warn "Codex: no ~/.codex/auth.json — run 'codex' locally and sign in with ChatGPT first"; fi
  if [ -n "$GH_TOKEN_VAL" ]; then ok "GitHub: gh token will be forwarded"
  else warn "GitHub: gh not authenticated — private clones/pushes won't work (gh auth login)"; fi
  if [ "$AWS_ENABLED" = 1 ]; then
    if [ -n "$AWS_EXPIRATION" ]; then ok "AWS: temporary profile '$AWS_SOURCE_PROFILE' (expires $AWS_EXPIRATION)"
    else warn "AWS: static profile '$AWS_SOURCE_PROFILE' explicitly allowed"; fi
    step "AWS deployment toolchain will be installed in the sandbox"
  fi
  [ -n "$SECRET_ENV_NAMES" ] && ok "forwarded env: applying named variables ($SECRET_ENV_NAMES)"
}

# ----------------------------------------------------------------------------
# Repo selection
# ----------------------------------------------------------------------------
pick_repo() { # sets REPO_PICKED (owner/name, may be "")
  REPO_PICKED=""
  need_cmd gh "brew install gh"
  step "fetching your repositories…" >&2
  local list
  list="$(gh repo list --limit 200 --json nameWithOwner,description \
          --template '{{range .}}{{.nameWithOwner}}{{"\t"}}{{.description}}{{"\n"}}{{end}}' 2>/dev/null || true)"
  [ -n "$list" ] || die "could not list repos via gh — is 'gh auth login' done?"
  if have_cmd fzf; then
    local sel
    sel="$(printf '%s\n' "$list" | fzf --height=60% --reverse --prompt='repo> ' \
          --header='pick a repo (esc = blank sandbox)' --delimiter='\t' --with-nth=1,2 || true)"
    REPO_PICKED="$(printf '%s' "$sel" | cut -f1)"
  else
    say "pick a repo (number), or 0 for a blank sandbox:"
    printf '%s\n' "$list" | head -30 | nl -w3 -s') ' | cut -c1-100
    printf 'repo #: '
    local n
    read -r n || true
    if [ -n "$n" ] && [ "$n" != "0" ]; then
      REPO_PICKED="$(printf '%s\n' "$list" | sed -n "${n}p" | cut -f1)"
    fi
  fi
  return 0
}

# ----------------------------------------------------------------------------
# Embedded payload: sandbox provisioner (phased; runs INSIDE the sandbox)
# ----------------------------------------------------------------------------
emit_provision_script() {
cat <<'DVPROV_EOF'
#!/usr/bin/env bash
# devflow sandbox provisioner — runs INSIDE the Daytona sandbox. Idempotent.
# Phases (DV_PHASE): tools | auth | workspace | all
set -u
set -o pipefail

DV_DIR="$HOME/.devflow"
DV_BIN="$DV_DIR/bin"
DV_STAGE="$DV_DIR/stage"
DV_PROVISION_VERSION=5
export PATH="$HOME/.local/bin:$DV_BIN:$PATH"

: "${DV_PHASE:=all}"
: "${DV_AGENT:=claude}"
: "${DV_REPO:=}"
: "${DV_BRANCH:=}"
: "${DV_NAME:=sandbox}"
: "${DV_TASK_B64:=}"
: "${DV_WORKROOT:=work}"
: "${DV_HARNESS:=core}"   # core | omc | omx | both

log()  { printf '[devflow] %s\n' "$*"; }
fail() { printf '[devflow] ERROR: %s\n' "$*" >&2; exit 1; }

mkdir -p "$DV_DIR" "$DV_BIN" "$DV_STAGE" "$HOME/.local/bin"
chmod 700 "$DV_DIR" "$DV_STAGE"
cd "$HOME" || true   # tools that drop state in cwd (omx setup) must land in $HOME

SUDO=""
if [ "$(id -u)" != "0" ] && command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
  SUDO="sudo"
fi

apt_install() { # best-effort package install (root or passwordless sudo)
  command -v apt-get >/dev/null 2>&1 || return 1
  if [ "$(id -u)" = "0" ]; then
    apt-get update -qq >/dev/null 2>&1 || true
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq "$@" >/dev/null 2>&1
  elif [ -n "$SUDO" ]; then
    $SUDO apt-get update -qq >/dev/null 2>&1 || true
    DEBIAN_FRONTEND=noninteractive $SUDO apt-get install -y -qq "$@" >/dev/null 2>&1
  else
    return 1
  fi
}

ensure_node_path() { # surface nvm-installed node (default Daytona image uses nvm)
  command -v node >/dev/null 2>&1 && return 0
  if [ -s "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
  fi
  command -v node >/dev/null 2>&1 && return 0
  local d
  for d in "$HOME"/.nvm/versions/node/*/bin /usr/local/share/nvm/versions/node/*/bin; do
    if [ -x "$d/node" ]; then export PATH="$d:$PATH"; return 0; fi
  done
  return 0
}

arch_triple() { case "$(uname -m)" in aarch64|arm64) printf 'aarch64' ;; *) printf 'x86_64' ;; esac; }
arch_gh()     { case "$(uname -m)" in aarch64|arm64) printf 'arm64'   ;; *) printf 'amd64'  ;; esac; }

version_lt() { # VERSION MINIMUM; release versions only
  awk -v have="$1" -v want="$2" 'BEGIN {
    split(have, h, "."); split(want, w, ".")
    for (i = 1; i <= 3; i++) {
      h[i] += 0; w[i] += 0
      if (h[i] < w[i]) exit 0
      if (h[i] > w[i]) exit 1
    }
    exit 1
  }'
}

gh_curl() { # authenticated GitHub download when possible (rate limits)
  if [ -n "${DV_GH_TOKEN:-}" ]; then
    curl -fsSL -H "Authorization: Bearer $DV_GH_TOKEN" "$@"
  else
    curl -fsSL "$@"
  fi
}

load_secrets() {
  DV_CLAUDE_MODE=none DV_CLAUDE_TOKEN="" DV_CLAUDE_CREDS_B64="" DV_CODEX_AUTH_B64=""
  DV_GH_TOKEN="" DV_GIT_NAME="" DV_GIT_EMAIL="" DV_GH_PIN="2.96.0" DV_CODEX_PIN="rust-v0.142.5"
  DV_AWS_ENABLED=0 DV_AWS_CREDS_B64="" DV_AWS_CONFIG_B64="" DV_AWS_EXPIRATION="" DV_AWS_SOURCE_PROFILE=""
  DV_SECRET_ENV_B64="" DV_SECRET_ENV_NAMES=""
  if [ -f "$DV_STAGE/secrets.env" ]; then
    # shellcheck disable=SC1090
    . "$DV_STAGE/secrets.env"
  fi
}

ensure_npm() { # make npm usable (nvm-installed or fresh nvm install); rc 1 if impossible
  ensure_node_path
  if ! command -v npm >/dev/null 2>&1; then
    log "installing node 22 via nvm (needed for the multi-agent harness)…"
    export NVM_DIR="$HOME/.nvm"
    if [ ! -s "$NVM_DIR/nvm.sh" ]; then
      curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash > "$DV_DIR/nvm-install.log" 2>&1 || true
    fi
    # shellcheck disable=SC1091
    [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" >/dev/null 2>&1
    command -v nvm >/dev/null 2>&1 && nvm install 22 >> "$DV_DIR/nvm-install.log" 2>&1
    ensure_node_path
  fi
  command -v npm >/dev/null 2>&1 || return 1
  # non-root global installs need a user-writable prefix (skip under nvm,
  # which manages its own prefix and rejects overrides)
  local proot
  proot="$(npm root -g 2>/dev/null || true)"
  if [ -n "$proot" ] && [ ! -w "$(dirname "$proot")" ] && [ "$(id -u)" != "0" ]; then
    npm config set prefix "$HOME/.local" >/dev/null 2>&1 || true
  fi
  # nvm's bin dir is invisible to non-interactive login shells (ubuntu's
  # .bashrc returns early), so expose the runtime on a stable PATH
  link_global_bin node
  link_global_bin npm
  link_global_bin npx
  return 0
}

link_global_bin() { # expose an npm-global binary at ~/.local/bin
  local src
  src="$(npm prefix -g 2>/dev/null)/bin/$1"
  [ -x "$src" ] && [ "$src" != "$HOME/.local/bin/$1" ] && ln -sf "$src" "$HOME/.local/bin/$1"
  return 0
}

cloud_arch() { case "$(uname -m)" in aarch64|arm64) printf 'arm64' ;; *) printf 'amd64' ;; esac; }
aws_arch()   { case "$(uname -m)" in aarch64|arm64) printf 'aarch64' ;; *) printf 'x86_64' ;; esac; }

install_cloud_tools() {
  [ "${DV_AWS_ENABLED:-0}" = 1 ] || return 0
  log "installing AWS deployment toolchain (aws, eksctl, kubectl, helm, yq, envsubst, shellcheck, docker)…"
  apt_install unzip gettext-base openssh-client openssl file shellcheck docker.io \
    python3 python3-venv python3-pip ca-certificates || true
  local t arch kver
  arch="$(cloud_arch)"

  if ! command -v aws >/dev/null 2>&1; then
    t="$(mktemp -d)"
    if curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(aws_arch).zip" -o "$t/aws.zip" \
       && unzip -q "$t/aws.zip" -d "$t" \
       && "$t/aws/install" -i "$HOME/.local/aws-cli" -b "$HOME/.local/bin" >/dev/null; then :
    else rm -rf "$t"; fail "AWS CLI install failed"; fi
    rm -rf "$t"
  fi

  if ! command -v eksctl >/dev/null 2>&1; then
    t="$(mktemp -d)"
    if curl -fsSL "https://github.com/eksctl-io/eksctl/releases/latest/download/eksctl_Linux_${arch}.tar.gz" -o "$t/eksctl.tgz" \
       && tar -xzf "$t/eksctl.tgz" -C "$t" \
       && install -m 0755 "$t/eksctl" "$HOME/.local/bin/eksctl"; then :
    else rm -rf "$t"; fail "eksctl install failed"; fi
    rm -rf "$t"
  fi

  if ! command -v kubectl >/dev/null 2>&1; then
    kver="$(curl -fsSL https://dl.k8s.io/release/stable.txt 2>/dev/null || true)"
    [ -n "$kver" ] || fail "could not resolve the current stable kubectl version"
    curl -fsSL "https://dl.k8s.io/release/${kver}/bin/linux/${arch}/kubectl" -o "$HOME/.local/bin/kubectl" \
      || fail "kubectl install failed"
    chmod 0755 "$HOME/.local/bin/kubectl"
  fi

  if ! command -v helm >/dev/null 2>&1; then
    t="$(mktemp -d)"
    if curl -fsSL "https://get.helm.sh/helm-v3.18.4-linux-${arch}.tar.gz" -o "$t/helm.tgz" \
       && tar -xzf "$t/helm.tgz" -C "$t" \
       && install -m 0755 "$t/linux-${arch}/helm" "$HOME/.local/bin/helm"; then :
    else rm -rf "$t"; fail "helm install failed"; fi
    rm -rf "$t"
  fi

  if ! command -v yq >/dev/null 2>&1; then
    curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${arch}" -o "$HOME/.local/bin/yq" \
      || fail "yq install failed"
    chmod 0755 "$HOME/.local/bin/yq"
  fi

  if ! helm unittest --help >/dev/null 2>&1; then
    helm plugin install https://github.com/helm-unittest/helm-unittest.git --version v1.1.1 \
      > "$DV_DIR/helm-unittest-install.log" 2>&1 \
      || fail "helm-unittest install failed (see ~/.devflow/helm-unittest-install.log)"
  fi

  # Daytona's Docker-in-Docker snapshots can run dockerd. On a plain snapshot
  # the CLI is still installed, and a clear warning tells the operator to use
  # a prebuilt image or a DIND-capable snapshot.
  if command -v docker >/dev/null 2>&1 && ! docker info >/dev/null 2>&1; then
    [ -n "$SUDO" ] && $SUDO service docker start >/dev/null 2>&1 || true
    if ! docker info >/dev/null 2>&1 && [ -n "$SUDO" ] && $SUDO docker info >/dev/null 2>&1; then
      cat > "$HOME/.local/bin/docker" <<'DV_DOCKER_WRAPPER'
#!/usr/bin/env bash
exec sudo -n /usr/bin/docker "$@"
DV_DOCKER_WRAPPER
      chmod 0755 "$HOME/.local/bin/docker"
    fi
  fi

  for t in aws eksctl kubectl helm yq envsubst jq ssh-keygen curl openssl shellcheck docker file python3; do
    command -v "$t" >/dev/null 2>&1 || fail "AWS deployment tool missing after install: $t"
  done
  if docker info >/dev/null 2>&1; then
    log "AWS deployment toolchain ready (Docker daemon available)"
  else
    log "warn: Docker CLI installed but daemon unavailable — use a prebuilt runner image or a DIND-capable Daytona snapshot"
  fi
}

# ============================ phase: tools ===================================
phase_tools() {
  log "phase 1/4 tools: checking base packages…"
  local missing=""
  for t in tmux git curl; do command -v "$t" >/dev/null 2>&1 || missing="$missing $t"; done
  if [ -n "$missing" ]; then
    log "installing:$missing"
    # shellcheck disable=SC2086
    apt_install $missing ca-certificates || log "warn: could not apt-install$missing"
  fi
  command -v git  >/dev/null 2>&1 || fail "git missing and not installable in this image"
  command -v curl >/dev/null 2>&1 || fail "curl missing and not installable in this image"
  command -v tmux >/dev/null 2>&1 || log "warn: no tmux — sessions won't survive disconnects"
  command -v jq   >/dev/null 2>&1 || apt_install jq || true
  command -v rg   >/dev/null 2>&1 || apt_install ripgrep || true
  install_cloud_tools

  # ---- gh CLI ----
  if ! command -v gh >/dev/null 2>&1; then
    log "installing gh v$DV_GH_PIN…"
    local a t
    a="$(arch_gh)"
    t="$(mktemp -d)"
    if gh_curl "https://github.com/cli/cli/releases/download/v${DV_GH_PIN}/gh_${DV_GH_PIN}_linux_${a}.tar.gz" -o "$t/gh.tgz" \
       && tar -xzf "$t/gh.tgz" -C "$t"; then
      cp "$t/gh_${DV_GH_PIN}_linux_${a}/bin/gh" "$HOME/.local/bin/gh" && chmod +x "$HOME/.local/bin/gh"
    else
      log "warn: gh install failed (private-repo clone won't work)"
    fi
    rm -rf "$t"
  fi

  # ---- Claude Code ----
  ensure_node_path
  if ! command -v claude >/dev/null 2>&1; then
    log "installing Claude Code (native)…"
    curl -fsSL https://claude.ai/install.sh | bash > "$DV_DIR/claude-install.log" 2>&1 || true
    export PATH="$HOME/.local/bin:$PATH"
    if ! command -v claude >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
      log "native install unavailable — falling back to npm…"
      npm install -g @anthropic-ai/claude-code >> "$DV_DIR/claude-install.log" 2>&1 || true
    fi
  fi

  # ---- Codex CLI ----
  # Daytona snapshots may already contain Codex. Treat an older binary as
  # missing: stale defaults can select a model that ChatGPT auth rejects.
  local triple tag t bin codex_have codex_want install_codex
  triple="$(arch_triple)-unknown-linux-musl"
  tag=""
  if [ -n "${DV_GH_TOKEN:-}" ]; then
    tag="$(gh_curl https://api.github.com/repos/openai/codex/releases/latest 2>/dev/null | grep -m1 '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/' || true)"
  fi
  [ -n "$tag" ] || tag="$DV_CODEX_PIN"
  codex_want="${tag#rust-v}"
  codex_have="$(codex --version 2>/dev/null | awk '{print $NF}' | sed 's/^v//' || true)"
  install_codex=0
  if [ -z "$codex_have" ] || version_lt "$codex_have" "$codex_want"; then
    install_codex=1
  fi
  if [ "$install_codex" = 1 ]; then
    if [ -n "$codex_have" ]; then
      log "upgrading Codex CLI v$codex_have → v$codex_want…"
    else
      log "installing Codex CLI v$codex_want…"
    fi
    t="$(mktemp -d)"
    if gh_curl "https://github.com/openai/codex/releases/download/${tag}/codex-${triple}.tar.gz" -o "$t/codex.tgz" \
       2> "$DV_DIR/codex-native-install.log" \
       && tar -xzf "$t/codex.tgz" -C "$t" >> "$DV_DIR/codex-native-install.log" 2>&1; then
      bin="$(find "$t" -maxdepth 2 -type f -name 'codex*' ! -name '*.tar.gz' | head -1)"
      [ -n "$bin" ] && cp "$bin" "$HOME/.local/bin/codex" && chmod +x "$HOME/.local/bin/codex"
    fi
    rm -rf "$t"
    codex_have="$(codex --version 2>/dev/null | awk '{print $NF}' | sed 's/^v//' || true)"
    if [ -z "$codex_have" ] || version_lt "$codex_have" "$codex_want"; then
      log "native Codex install unavailable — falling back to a user-local npm install…"
      ensure_node_path
      command -v npm >/dev/null 2>&1 || ensure_npm || true
      if command -v npm >/dev/null 2>&1; then
        # ensure_npm may have linked an older snapshot-global codex here.
        # Remove that exact user-local launcher so npm can install the matching
        # package executable, never modifying the snapshot's Node tree.
        rm -f "$HOME/.local/bin/codex"
        npm install --prefix "$HOME/.local" --no-audit --no-fund "@openai/codex@$codex_want" \
          > "$DV_DIR/codex-install.log" 2>&1 || true
        if [ -x "$HOME/.local/node_modules/@openai/codex/bin/codex.js" ]; then
          ln -sf "$HOME/.local/node_modules/@openai/codex/bin/codex.js" "$HOME/.local/bin/codex"
        fi
      fi
    fi
  fi

  codex_have="$(codex --version 2>/dev/null | awk '{print $NF}' | sed 's/^v//' || true)"

  # only hard-fail if the selected agent is unusable
  case "$DV_AGENT" in
    claude) command -v claude >/dev/null 2>&1 || fail "claude install failed (see ~/.devflow/claude-install.log)" ;;
    codex)  command -v codex  >/dev/null 2>&1 || fail "codex install failed"
            version_lt "$codex_have" "$codex_want" && fail "Codex CLI v$codex_have is older than required v$codex_want" ;;
    both)   command -v claude >/dev/null 2>&1 || fail "claude install failed"
            command -v codex  >/dev/null 2>&1 || fail "codex install failed"
            version_lt "$codex_have" "$codex_want" && fail "Codex CLI v$codex_have is older than required v$codex_want" ;;
  esac
  log "tools ready: $(command -v claude >/dev/null 2>&1 && printf 'claude ')$(command -v codex >/dev/null 2>&1 && printf 'codex-v%s ' "$codex_have")$(command -v gh >/dev/null 2>&1 && printf 'gh ')$(command -v tmux >/dev/null 2>&1 && printf 'tmux')"
}

# ============================ phase: auth ====================================
phase_auth() {
  log "phase 2/4 auth: applying subscription credentials…"
  load_secrets
  umask 077
  mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.aws"
  chmod 700 "$HOME/.aws"

  : > "$DV_DIR/env"
  chmod 600 "$DV_DIR/env"
  case "$DV_CLAUDE_MODE" in
    token)
      printf 'export CLAUDE_CODE_OAUTH_TOKEN=%q\n' "$DV_CLAUDE_TOKEN" >> "$DV_DIR/env"
      log "claude auth: long-lived subscription token"
      ;;
    creds)
      printf '%s' "$DV_CLAUDE_CREDS_B64" | base64 -d > "$HOME/.claude/.credentials.json"
      chmod 600 "$HOME/.claude/.credentials.json"
      log "claude auth: subscription credentials copied"
      ;;
    *) log "claude auth: none provided (claude will ask to log in)" ;;
  esac
  printf '%s\n' '[ -f "$HOME/.devflow/forwarded.env" ] && . "$HOME/.devflow/forwarded.env"' >> "$DV_DIR/env"
  printf '%s\n' '[ -f "$HOME/.devflow/aws.env" ] && . "$HOME/.devflow/aws.env"' >> "$DV_DIR/env"

  if [ -n "$DV_CODEX_AUTH_B64" ]; then
    printf '%s' "$DV_CODEX_AUTH_B64" | base64 -d > "$HOME/.codex/auth.json"
    chmod 600 "$HOME/.codex/auth.json"
    log "codex auth: ChatGPT sign-in copied"
  else
    log "codex auth: none provided (use 'codex login --device-auth' in the sandbox)"
  fi

  if [ -n "$DV_GH_TOKEN" ] && command -v gh >/dev/null 2>&1; then
    printf '%s' "$DV_GH_TOKEN" | gh auth login --with-token 2>/dev/null || true
    gh auth setup-git 2>/dev/null || true
    log "github auth: $(gh api user -q .login 2>/dev/null || echo 'token applied')"
  fi

  [ -n "$DV_GIT_NAME" ]  && git config --global user.name  "$DV_GIT_NAME"
  [ -n "$DV_GIT_EMAIL" ] && git config --global user.email "$DV_GIT_EMAIL"
  git config --global init.defaultBranch main 2>/dev/null || true
  git config --global push.autoSetupRemote true 2>/dev/null || true

  if [ "${DV_AWS_ENABLED:-0}" = 1 ]; then
    printf '%s' "$DV_AWS_CREDS_B64" | base64 -d > "$HOME/.aws/credentials"
    printf '%s' "$DV_AWS_CONFIG_B64" | base64 -d > "$HOME/.aws/config"
    chmod 600 "$HOME/.aws/credentials" "$HOME/.aws/config"
    {
      printf 'export AWS_PROFILE=devflow\n'
      printf 'export AWS_SDK_LOAD_CONFIG=1\n'
      printf 'export AWS_CREDENTIAL_EXPIRATION=%q\n' "$DV_AWS_EXPIRATION"
      printf 'export DEVFLOW_AWS_EXPIRATION=%q\n' "$DV_AWS_EXPIRATION"
    } > "$DV_DIR/aws.env"
    chmod 600 "$DV_DIR/aws.env"
    printf '%s' "$DV_AWS_EXPIRATION" > "$DV_DIR/aws-expiration"
    printf '%s' "$DV_AWS_SOURCE_PROFILE" > "$DV_DIR/aws-profile"
    chmod 600 "$DV_DIR/aws-expiration" "$DV_DIR/aws-profile"
    if [ -n "$DV_AWS_EXPIRATION" ]; then
      log "aws auth: temporary session applied (expires $DV_AWS_EXPIRATION)"
    else
      log "aws auth: explicitly allowed static credentials applied"
    fi
  fi

  if [ -n "${DV_SECRET_ENV_B64:-}" ]; then
    printf '%s' "$DV_SECRET_ENV_B64" | base64 -d > "$DV_DIR/forwarded.env"
    chmod 600 "$DV_DIR/forwarded.env"
    printf '%s' "$DV_SECRET_ENV_NAMES" > "$DV_DIR/forwarded-env-names"
    chmod 600 "$DV_DIR/forwarded-env-names"
    log "forwarded env: named variables applied ($DV_SECRET_ENV_NAMES)"
  fi

  if command -v shred >/dev/null 2>&1; then shred -u "$DV_STAGE/secrets.env" 2>/dev/null || rm -f "$DV_STAGE/secrets.env"
  else rm -f "$DV_STAGE/secrets.env"; fi
  umask 022
  log "auth done."
}

# ============================ phase: workspace ================================
phase_workspace() {
  log "phase 3/4 workspace: repo + dotfiles + session…"

  # ---- repo ----
  local WORKDIR
  if [ -n "$DV_REPO" ]; then
    WORKDIR="$HOME/$DV_WORKROOT/${DV_REPO##*/}"
    if [ ! -d "$WORKDIR/.git" ]; then
      log "cloning $DV_REPO…"
      mkdir -p "$HOME/$DV_WORKROOT"
      if [ -n "$DV_BRANCH" ]; then
        git clone --branch "$DV_BRANCH" "https://github.com/$DV_REPO.git" "$WORKDIR" 2>/dev/null \
          || { git clone "https://github.com/$DV_REPO.git" "$WORKDIR" \
               && git -C "$WORKDIR" checkout -b "$DV_BRANCH"; } \
          || fail "clone failed for $DV_REPO (private? check gh auth)"
      else
        git clone "https://github.com/$DV_REPO.git" "$WORKDIR" || fail "clone failed for $DV_REPO"
      fi
    elif [ -n "$DV_BRANCH" ]; then
      git -C "$WORKDIR" checkout "$DV_BRANCH" 2>/dev/null || git -C "$WORKDIR" checkout -b "$DV_BRANCH" || true
    fi
  else
    WORKDIR="$HOME/$DV_WORKROOT/scratch"
    mkdir -p "$WORKDIR"
  fi
  printf '%s' "$WORKDIR"        > "$DV_DIR/workdir"
  printf '%s' "$DV_AGENT"       > "$DV_DIR/agent"
  printf '%s' "$DV_NAME"        > "$DV_DIR/name"
  printf '%s' "${DV_REPO:-}"    > "$DV_DIR/repo"
  touch "$DV_DIR/autotmux"

  if [ -n "$DV_TASK_B64" ]; then
    umask 077
    printf '%s' "$DV_TASK_B64" | base64 -d > "$DV_DIR/task"
    umask 022
    log "task queued for the agent"
  fi

  # ---- claude harness ----
  if [ ! -f "$HOME/.claude.json" ]; then
    cat > "$HOME/.claude.json" <<DV_CLAUDEJSON
{
  "hasCompletedOnboarding": true,
  "bypassPermissionsModeAccepted": true,
  "theme": "dark",
  "projects": {
    "$WORKDIR": {
      "hasTrustDialogAccepted": true,
      "hasCompletedProjectOnboarding": true
    }
  }
}
DV_CLAUDEJSON
  elif command -v jq >/dev/null 2>&1; then
    local tmpj
    tmpj="$(mktemp)"
    jq --arg wd "$WORKDIR" '.hasCompletedOnboarding = true
      | .bypassPermissionsModeAccepted = true
      | .projects[$wd] = ((.projects[$wd] // {}) + {hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true})' \
      "$HOME/.claude.json" > "$tmpj" && mv "$tmpj" "$HOME/.claude.json"
  fi

  if [ ! -f "$HOME/.claude/settings.json" ]; then
    cat > "$HOME/.claude/settings.json" <<'DV_SETTINGS'
{
  "statusLine": {
    "type": "command",
    "command": "~/.devflow/bin/dv-statusline",
    "padding": 0
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  }
}
DV_SETTINGS
  fi

  if [ ! -f "$HOME/.claude/CLAUDE.md" ]; then
    cat > "$HOME/.claude/CLAUDE.md" <<'DV_CLAUDEMD'
# devflow sandbox

You are running inside a disposable **Daytona cloud sandbox** provisioned by
devflow. Facts about this environment:

- The sandbox is yours alone: installing packages, editing system config, and
  long-running processes are all fine. Prefer acting over asking.
- The working repository is checked out under `~/work/`. Do your work there.
- `gh` is authenticated as the sandbox owner. Push to feature branches and
  open PRs with `gh pr create`; never force-push `main` unless explicitly
  asked.
- Git identity is already configured. Commit early and often — committed and
  pushed work is the only durable work if the sandbox is deleted.
- The session runs inside tmux (session `dv`). The user may detach and
  reattach at any time; you may be resumed mid-task. If resumed, run
  `git status` and skim recent commits to re-establish context first.
- Permission prompts are bypassed. Be deliberate with destructive commands;
  prefer reversible operations.

## Multi-agent

Specialized subagents are installed — delegate instead of doing everything
in one context:

- `dv-engineer` (implementation), `dv-designer` (UX/API design),
  `dv-security` (security review) are always available. Use dv-security
  proactively after changes that touch auth, input handling, or secrets.
- If oh-my-claudecode is installed (check: `/help` lists `/autopilot`),
  prefer its workflows for big tasks: `/autopilot "…"` for autonomous
  builds, `/team N:executor "…"` for parallel work, `/ultrawork` for
  max-effort passes; its roster includes architect, designer,
  security-reviewer, test-engineer, and more.
DV_CLAUDEMD
  fi

  # ---- codex harness ----
  if [ ! -f "$HOME/.codex/config.toml" ]; then
    cat > "$HOME/.codex/config.toml" <<DV_CODEXCFG
# devflow harness — the Daytona sandbox is the isolation boundary, so codex
# itself runs with full autonomy inside it.
approval_policy = "never"
sandbox_mode = "danger-full-access"
forced_login_method = "chatgpt"
cli_auth_credentials_store = "file"

[projects."$WORKDIR"]
trust_level = "trusted"
DV_CODEXCFG
  fi

  if [ ! -f "$HOME/.codex/AGENTS.md" ]; then
    cat > "$HOME/.codex/AGENTS.md" <<'DV_AGENTSMD'
# devflow sandbox

You are running inside a disposable Daytona cloud sandbox provisioned by
devflow. The working repository is under `~/work/`. `gh` is authenticated —
push to feature branches and open PRs with `gh pr create`. Git identity is
configured; commit early and often since only pushed work survives sandbox
deletion. You run with full autonomy (no approval prompts) — be deliberate
with destructive commands. You may be detached from and resumed at any time;
on resume, check `git status` first.

If oh-my-codex is installed (the `omx` command exists), its workflows and
agent teams are available — prefer `$ultragoal`-style structured workflows
for large tasks, and consult its skills before hand-rolling orchestration.
DV_AGENTSMD
  fi

  # ---- tmux ----
  if [ ! -f "$HOME/.tmux.conf" ]; then
    cat > "$HOME/.tmux.conf" <<'DV_TMUXCONF'
# devflow tmux defaults
set -g mouse on
set -g history-limit 100000
set -g default-terminal "screen-256color"
set -g status-style "bg=colour24,fg=colour255"
set -g status-left "#[bold] devflow:#S "
set -g status-left-length 30
set -g status-right "#[fg=colour255]%H:%M "
set -g allow-rename off
set -g automatic-rename off
setw -g aggressive-resize on
DV_TMUXCONF
  fi

  # ---- shell integration ----
  cat > "$DV_DIR/shellrc" <<'DV_SHELLRC'
# devflow shell integration (sourced from ~/.bashrc and ~/.profile)
[ -n "${DEVFLOW_SHELLRC_RAN:-}" ] && return 0
DEVFLOW_SHELLRC_RAN=1; export DEVFLOW_SHELLRC_RAN

export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"
[ -f "$HOME/.devflow/env" ] && . "$HOME/.devflow/env"
export DEVFLOW_SANDBOX=1
DEVFLOW_NAME="$(cat "$HOME/.devflow/name" 2>/dev/null || echo sandbox)"
export DEVFLOW_NAME

alias dv-work='cd "$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"'
alias yolo='claude --dangerously-skip-permissions'

# Auto-attach the devflow tmux session on interactive SSH logins, so
# `devflow attach` / `daytona ssh` drop straight into the agent.
if [ -n "${SSH_CONNECTION:-}" ] && [ -z "${TMUX:-}" ] && [ -t 0 ] \
   && [ -f "$HOME/.devflow/autotmux" ] && command -v tmux >/dev/null 2>&1; then
  case "$-" in
    *i*)
      "$HOME/.devflow/bin/dv-ensure" >/dev/null 2>&1
      tmux new-session -A -s dv
      printf '\n[devflow] detached — "exit" to close, "tmux attach -t dv" to rejoin.\n'
      ;;
  esac
fi
DV_SHELLRC

  local rcfile
  for rcfile in "$HOME/.bashrc" "$HOME/.profile"; do
    if ! grep -q 'devflow/shellrc' "$rcfile" 2>/dev/null; then
      {
        printf '\n# --- devflow ---\n'
        printf '[ -f "$HOME/.devflow/shellrc" ] && . "$HOME/.devflow/shellrc"\n'
      } >> "$rcfile"
    fi
  done

  # ---- in-sandbox helper scripts ----
  cat > "$DV_BIN/dv-agent" <<'DV_DVAGENT'
#!/usr/bin/env bash
# dv-agent [claude|codex] — launch the coding agent in the work directory,
# resuming the previous conversation when one exists.
set -u
set -o pipefail
DV_DIR="$HOME/.devflow"
RUN_DIR="$DV_DIR/run"
AGENT="${1:-$(cat "$HOME/.devflow/agent" 2>/dev/null || echo claude)}"
WORKDIR="$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"
cd "$WORKDIR" 2>/dev/null || cd "$HOME"
[ -f "$HOME/.devflow/env" ] && . "$HOME/.devflow/env"
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"
mkdir -p "$RUN_DIR"
chmod 700 "$RUN_DIR"

TASK=""
TASK_FILE="$RUN_DIR/task.txt"
if [ -f "$DV_DIR/task" ]; then
  mv -f "$DV_DIR/task" "$TASK_FILE"
  chmod 600 "$TASK_FILE"
  TASK=1
fi
STARTED_AT="$(date -u +%FT%TZ)"
COMPLETED_AT=""
PROMPT_SHA=""
if [ -n "$TASK" ]; then
  if command -v sha256sum >/dev/null 2>&1; then
    PROMPT_SHA="$(sha256sum "$TASK_FILE" | awk '{print $1}')"
  else
    PROMPT_SHA="$(shasum -a 256 "$TASK_FILE" | awk '{print $1}')"
  fi
fi

status_write() { # STATE [EXIT_CODE]
  local state="$1" exit_code="${2:-}" tmp="$RUN_DIR/status.tmp.$$"
  {
    printf 'state=%s\n' "$state"
    printf 'agent=%s\n' "$AGENT"
    printf 'pid=%s\n' "$$"
    printf 'started_at=%s\n' "$STARTED_AT"
    [ -n "$COMPLETED_AT" ] && printf 'completed_at=%s\n' "$COMPLETED_AT"
    [ -n "$PROMPT_SHA" ] && printf 'prompt_sha256=%s\n' "$PROMPT_SHA"
    [ -n "$exit_code" ] && printf 'exit_code=%s\n' "$exit_code"
  } > "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$RUN_DIR/status"
}

CLAUDE_FLAGS="--dangerously-skip-permissions"
if [ "$(id -u)" = "0" ]; then
  # claude refuses bypass mode as root
  CLAUDE_FLAGS="--permission-mode acceptEdits"
fi

has_claude_history() {
  local munged
  munged="$(printf '%s' "$WORKDIR" | sed 's|[/._]|-|g')"
  ls "$HOME/.claude/projects/$munged"/*.jsonl >/dev/null 2>&1
}

case "$AGENT" in
  codex)
    if [ -n "$TASK" ]; then
      : > "$RUN_DIR/agent.log"
      chmod 600 "$RUN_DIR/agent.log"
      status_write running
      codex exec --dangerously-bypass-approvals-and-sandbox --color never \
        -C "$WORKDIR" -o "$RUN_DIR/last-message.txt" - < "$TASK_FILE" 2>&1 \
        | tee -a "$RUN_DIR/agent.log"
      rc="${PIPESTATUS[0]}"
      COMPLETED_AT="$(date -u +%FT%TZ)"
      chmod 600 "$RUN_DIR/last-message.txt" 2>/dev/null || true
      if [ "$rc" -eq 0 ]; then status_write completed "$rc"
      else status_write failed "$rc"; fi
      exit "$rc"
    fi
    status_write interactive
    if codex resume --last 2>/dev/null; then exit 0; fi
    if command -v omx >/dev/null 2>&1; then exec omx; fi
    exec codex
    ;;
  claude|*)
    if [ -n "$TASK" ]; then
      status_write running
      # shellcheck disable=SC2086
      exec claude $CLAUDE_FLAGS "$(cat "$TASK_FILE")"
    fi
    status_write interactive
    if has_claude_history; then
      # shellcheck disable=SC2086
      claude $CLAUDE_FLAGS --continue || exec claude $CLAUDE_FLAGS
    else
      # shellcheck disable=SC2086
      exec claude $CLAUDE_FLAGS
    fi
    ;;
esac
DV_DVAGENT
  chmod +x "$DV_BIN/dv-agent"

  cat > "$DV_BIN/dv-task-start" <<'DV_TASKSTART'
#!/usr/bin/env bash
# Start one queued task in a fresh tmux agent window without attaching.
set -u
DV_DIR="$HOME/.devflow"
RUN_DIR="$DV_DIR/run"
WORKDIR="$(cat "$DV_DIR/workdir" 2>/dev/null || echo "$HOME")"
AGENT="$(cat "$DV_DIR/agent" 2>/dev/null || echo claude)"
INCOMING="${1:-}"
AGENT_OVERRIDE="${2:-}"
export PATH="$HOME/.local/bin:$DV_DIR/bin:$PATH"
command -v tmux >/dev/null 2>&1 || { echo "tmux is not installed" >&2; exit 1; }

state="$(sed -n 's/^state=//p' "$RUN_DIR/status" 2>/dev/null | head -1)"
pid="$(sed -n 's/^pid=//p' "$RUN_DIR/status" 2>/dev/null | head -1)"
if [ "$state" = "running" ] && [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
  echo "an agent task is already running (pid $pid)" >&2
  exit 2
fi
if [ -n "$AGENT_OVERRIDE" ]; then
  case "$AGENT_OVERRIDE" in claude|codex|both) AGENT="$AGENT_OVERRIDE" ;; *) echo "invalid agent override" >&2; exit 1 ;; esac
  printf '%s' "$AGENT" > "$DV_DIR/agent"
fi
[ "$AGENT" != "none" ] || { echo "sandbox agent is set to none" >&2; exit 1; }
mkdir -p "$RUN_DIR"
chmod 700 "$RUN_DIR"
if [ -n "$INCOMING" ]; then
  [ -f "$INCOMING" ] || { echo "incoming task file not found" >&2; exit 1; }
  mv -f "$INCOMING" "$DV_DIR/task"
  chmod 600 "$DV_DIR/task"
fi
[ -f "$DV_DIR/task" ] || { echo "no queued task" >&2; exit 1; }
printf 'state=queued\nagent=%s\n' "$AGENT" > "$RUN_DIR/status"
chmod 600 "$RUN_DIR/status"

if ! tmux has-session -t dv 2>/dev/null; then
  tmux new-session -d -s dv -n shell -c "$WORKDIR"
elif ! tmux list-windows -t dv -F '#{window_name}' | grep -qx shell; then
  tmux new-window -d -t dv -n shell -c "$WORKDIR"
fi
tmux kill-window -t dv:agent 2>/dev/null || true
tmux new-window -d -t dv -n agent -c "$WORKDIR"
tmux send-keys -t dv:agent "dv-agent $AGENT" C-m
tmux select-window -t dv:agent
echo "agent task started in tmux window dv:agent"
DV_TASKSTART
  chmod +x "$DV_BIN/dv-task-start"

  cat > "$DV_BIN/dv-ensure" <<'DV_DVENSURE'
#!/usr/bin/env bash
# dv-ensure — make sure the devflow tmux session exists (agent + shell windows)
set -u
command -v tmux >/dev/null 2>&1 || exit 0
WORKDIR="$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"
AGENT="$(cat "$HOME/.devflow/agent" 2>/dev/null || echo claude)"
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"

if ! tmux has-session -t dv 2>/dev/null; then
  tmux new-session -d -s dv -n shell -c "$WORKDIR"
fi
if ! tmux list-windows -t dv -F '#{window_name}' | grep -qx shell; then
  tmux new-window -d -t dv -n shell -c "$WORKDIR"
fi
case "$AGENT" in
  none)
    if ! tmux list-windows -t dv -F '#{window_name}' | grep -qx agent; then
      tmux new-window -d -t dv -n agent -c "$WORKDIR"
    fi
    ;;
  both)
    if ! tmux list-windows -t dv -F '#{window_name}' | grep -qx agent; then
      tmux new-window -d -t dv -n agent -c "$WORKDIR"
      tmux send-keys -t dv:agent "dv-agent claude" C-m
    fi
    if ! tmux list-windows -t dv -F '#{window_name}' | grep -qx codex; then
      tmux new-window -d -t dv -n codex -c "$WORKDIR"
      tmux send-keys -t dv:codex "dv-agent codex" C-m
    fi
    ;;
  *)
    if ! tmux list-windows -t dv -F '#{window_name}' | grep -qx agent; then
      tmux new-window -d -t dv -n agent -c "$WORKDIR"
      tmux send-keys -t dv:agent "dv-agent $AGENT" C-m
    fi
    ;;
esac
if tmux list-windows -t dv -F '#{window_name}' | grep -qx agent; then
  tmux select-window -t dv:agent
else
  tmux select-window -t dv:shell
fi
DV_DVENSURE
  chmod +x "$DV_BIN/dv-ensure"

  cat > "$DV_BIN/dv-statusline" <<'DV_STATUSLINE'
#!/usr/bin/env bash
# claude code statusline: sandbox · model · dir · branch · context
input="$(cat)"
name="$(cat "$HOME/.devflow/name" 2>/dev/null || echo sandbox)"
if command -v jq >/dev/null 2>&1; then
  model="$(printf '%s' "$input" | jq -r '.model.display_name // "?"')"
  dir="$(printf '%s' "$input" | jq -r '.workspace.current_dir // "?"')"
  ctx="$(printf '%s' "$input" | jq -r '.context_window.used_percentage // empty' 2>/dev/null)"
else
  model="?"; dir="$PWD"; ctx=""
fi
branch="$(git -C "$dir" branch --show-current 2>/dev/null)"
out="☁ $name · $model · ${dir/#$HOME/~}"
[ -n "$branch" ] && out="$out · $branch"
[ -n "$ctx" ] && out="$out · ctx ${ctx%%.*}%"
printf '%s' "$out"
DV_STATUSLINE
  chmod +x "$DV_BIN/dv-statusline"

  # ---- start the session ----
  # dv-ensure preserves existing windows. A queued task must instead replace
  # an idle or previously failed agent window so it cannot remain stranded.
  if [ -n "$DV_TASK_B64" ]; then
    "$DV_BIN/dv-task-start"
  else
    "$DV_BIN/dv-ensure"
  fi
  printf '%s' "$DV_PROVISION_VERSION" > "$DV_DIR/provisioned"
  log "workspace ready: agent=$DV_AGENT repo=${DV_REPO:-none} workdir=$WORKDIR"
}

# ============================ phase: harness ==================================
install_dv_subagents() {
  # devflow-native mini-team for Claude Code (always installed; dv- prefix
  # avoids collisions with oh-my-claudecode's own roster)
  mkdir -p "$HOME/.claude/agents"

  if [ ! -f "$HOME/.claude/agents/dv-engineer.md" ]; then
    cat > "$HOME/.claude/agents/dv-engineer.md" <<'DV_AG_ENG'
---
name: dv-engineer
description: Senior implementation engineer. Use for writing, refactoring, and debugging code once an approach is decided — turns a plan or bug report into working, tested changes.
---

You are a senior software engineer working inside a disposable cloud sandbox.
You own implementation quality: correct, minimal, idiomatic changes that match
the surrounding codebase.

- Read the relevant code before changing it; follow the repo's existing
  patterns, naming, and tooling.
- Prefer the smallest change that fully solves the problem. No drive-by
  refactors unless asked.
- Run the project's tests/linters after changes; fix what you break. If there
  are no tests, add focused ones for the behavior you changed.
- Commit logically-scoped changes with clear messages as you go.
- Report back: what changed, why, how it was verified, and any follow-ups.
DV_AG_ENG
  fi

  if [ ! -f "$HOME/.claude/agents/dv-designer.md" ]; then
    cat > "$HOME/.claude/agents/dv-designer.md" <<'DV_AG_DES'
---
name: dv-designer
description: Product/UX and API designer. Use before building user-facing surfaces or public interfaces — turns requirements into concrete flows, layouts, naming, and API shapes.
---

You are a pragmatic product designer who thinks in user flows and interface
contracts (UI and API alike).

- Start from the user's job-to-be-done; enumerate the primary flow and the two
  most likely edge flows before proposing surfaces.
- For UI: propose hierarchy, states (empty/loading/error), and copy. Favor
  conventions of the project's existing stack over novelty.
- For APIs/CLIs: design the smallest coherent surface; name things the way the
  codebase already names things; show example calls before writing code.
- Deliver artifacts the engineer can build from directly: annotated flows,
  component/endpoint lists, example payloads — not vague principles.
DV_AG_DES
  fi

  if [ ! -f "$HOME/.claude/agents/dv-security.md" ]; then
    cat > "$HOME/.claude/agents/dv-security.md" <<'DV_AG_SEC'
---
name: dv-security
description: Security reviewer. Use proactively after changes touching auth, input handling, secrets, network, file access, or dependencies — finds and explains real vulnerabilities with fixes.
---

You are an application security reviewer. Hunt for vulnerabilities that are
actually exploitable in this codebase — not theoretical checklist items.

- Priorities: injection (SQL/shell/template), authn/authz gaps, secret
  handling and logging, unsafe deserialization, path traversal, SSRF, unsafe
  defaults, and dependency risk.
- For each finding: the exact location, a concrete attack scenario, severity,
  and the minimal fix. Verify the fix compiles/tests when you apply one.
- Distinguish "exploitable now" from "hardening"; lead with the former.
- End with a short verdict: safe to ship, or blockers listed in order.
DV_AG_SEC
  fi
}

# Shared npm-harness installer: install the package if its main bin is
# missing, symlink bins where non-interactive shells can see them, then run
# the tool's own idempotent setup. Everything best-effort: failures warn into
# the per-tool log and the session stays usable on the core harness.
install_harness_tool() { # LABEL NPM_PKG MAIN_BIN SETUP_CMD READY_MSG [EXTRA_BINS…]
  local label="$1" pkg="$2" mainbin="$3" setup_cmd="$4" ready="$5" b
  shift 5
  if ! command -v "$mainbin" >/dev/null 2>&1; then
    log "installing $label…"
    npm install -g "$pkg@latest" > "$DV_DIR/$mainbin-install.log" 2>&1 \
      || log "warn: $mainbin npm install failed (see ~/.devflow/$mainbin-install.log)"
    ensure_node_path
    link_global_bin "$mainbin"
    for b in "$@"; do link_global_bin "$b"; done
  fi
  if command -v "$mainbin" >/dev/null 2>&1; then
    # shellcheck disable=SC2086  # setup_cmd is a controlled argv string
    if $setup_cmd </dev/null >> "$DV_DIR/$mainbin-install.log" 2>&1; then
      log "$ready"
    else
      log "warn: $mainbin setup failed:"
      tail -n 6 "$DV_DIR/$mainbin-install.log" 2>/dev/null | sed 's/^/[devflow]   /'
    fi
  fi
}

phase_harness() {
  log "phase 4/4 harness: multi-agent setup ($DV_HARNESS)…"

  case "$DV_HARNESS" in
    omc|omx|both)
      if ! ensure_npm; then
        log "warn: npm unavailable — skipped $DV_HARNESS install (core harness still active)"
        DV_HARNESS=core
      fi
      ;;
  esac

  if [ "$DV_HARNESS" = "omc" ] || [ "$DV_HARNESS" = "both" ]; then
    install_harness_tool "oh-my-claudecode (this can take a minute)" \
      oh-my-claude-sisyphus omc \
      "omc setup --no-plugin --force --quiet" \
      "omc ready: /autopilot, /ultrawork, /team (architect, designer, security-reviewer, +26 more)" \
      oh-my-claudecode omc-cli
  fi

  if [ "$DV_HARNESS" = "omx" ] || [ "$DV_HARNESS" = "both" ]; then
    install_harness_tool "oh-my-codex" \
      oh-my-codex omx \
      "omx setup --scope user --merge-agents --force" \
      "omx ready: launch codex sessions with 'omx' (\$ultragoal keywords, agent teams)"
  fi

  # after omc setup: its installer syncs ~/.claude/agents and drops unknown
  # files, so the devflow-native trio must be (re)installed last
  install_dv_subagents
  log "core team ready: dv-engineer / dv-designer / dv-security"

  printf '%s' "$DV_HARNESS" > "$DV_DIR/harness"
  log "harness done."
}

load_secrets   # defaults + secrets file if present (tools needs pins/token too)

case "$DV_PHASE" in
  tools)     phase_tools ;;
  auth)      phase_auth ;;
  workspace) phase_workspace ;;
  harness)   phase_harness ;;
  all)       phase_tools; phase_auth; phase_workspace; phase_harness ;;
  *)         fail "unknown phase: $DV_PHASE" ;;
esac
DVPROV_EOF
}

# ----------------------------------------------------------------------------
# Provision + sync orchestration (local side)
# ----------------------------------------------------------------------------
upload_provisioner() { # NAME [WITH_SECRETS]
  local name="$1" with_secrets="${2:-1}"
  emit_provision_script | dt_push_file "$name" "/tmp/.dv-provision.sh"
  if [ "$with_secrets" = 1 ]; then
    build_secrets_bundle | dt_push_file "$name" "/tmp/.dv-secrets.env"
  fi
  dt_run "$name" 'mkdir -p "$HOME/.devflow/stage" && chmod 700 "$HOME/.devflow" "$HOME/.devflow/stage" && mv -f /tmp/.dv-provision.sh "$HOME/.devflow/stage/provision.sh" && { [ ! -f /tmp/.dv-secrets.env ] || mv -f /tmp/.dv-secrets.env "$HOME/.devflow/stage/secrets.env"; }' 120 >/dev/null
}

run_phase() { # NAME PHASE AGENT REPO BRANCH TASK_B64 [HARNESS]
  local name="$1" phase="$2" agent="$3" repo="$4" branch="$5" task_b64="$6" harness="${7:-core}"
  dt_run "$name" "DV_PHASE='$phase' DV_AGENT='$agent' DV_REPO='$repo' DV_BRANCH='$branch' DV_NAME='$name' DV_TASK_B64='$task_b64' DV_WORKROOT='$DEVFLOW_WORKROOT' DV_HARNESS='$harness' bash \"\$HOME/.devflow/stage/provision.sh\"" 0
}

provision_sandbox() { # NAME AGENT REPO BRANCH TASK HARNESS
  local name="$1" agent="$2" repo="$3" branch="$4" task="$5" harness="$6" task_b64=""
  [ -n "$task" ] && task_b64="$(printf '%s' "$task" | b64_encode)"

  step "uploading provisioner + syncing subscription auth…"
  upload_provisioner "$name" 1

  step "installing tools (tmux, gh, claude, codex — output appears when done)…"
  run_phase "$name" tools "$agent" "$repo" "$branch" "$task_b64" "$harness" \
    || die "sandbox tools phase failed; task was not queued"

  step "applying auth…"
  run_phase "$name" auth "$agent" "$repo" "$branch" "$task_b64" "$harness" \
    || die "sandbox auth phase failed; task was not queued"

  step "setting up workspace + starting agent session…"
  run_phase "$name" workspace "$agent" "$repo" "$branch" "$task_b64" "$harness" \
    || die "sandbox workspace phase failed; task was not queued"

  step "installing multi-agent harness ($harness)…"
  run_phase "$name" harness "$agent" "$repo" "$branch" "$task_b64" "$harness" \
    || die "sandbox harness phase failed; task was not queued"
}

sandbox_is_provisioned() { # NAME
  local got
  got="$(dt_run "$1" 'cat "$HOME/.devflow/provisioned" 2>/dev/null || true' 60 2>/dev/null | tail -1)"
  [ "$got" = "$DV_EXPECTED_PROVISION_VERSION" ]
}

agent_task_state() { # NAME
  dt_run "$1" 'i=0; state=""; while [ "$i" -lt 30 ]; do state="$(sed -n "s/^state=//p" "$HOME/.devflow/run/status" 2>/dev/null | head -1)"; case "$state" in running|completed|failed) break ;; esac; i=$((i + 1)); sleep 1; done; printf "%s\n" "${state:-not-started}"' 60 2>/dev/null | tail -1
}

verify_agent_task_started() { # NAME
  local state
  state="$(agent_task_state "$1")"
  case "$state" in
    running|completed) ok "agent task state: $state" ;;
    failed) die "agent task exited immediately (inspect: devflow peek $1; devflow status $1)" ;;
    *) die "agent task did not start (state: ${state:-unknown}; inspect: devflow status $1)" ;;
  esac
}

queue_agent_task() { # NAME TASK [AGENT_OVERRIDE]
  local name="$1" task="$2" agent_override="${3:-}"
  [ -n "$task" ] || return 0
  printf '%s' "$task" | dt_push_file "$name" "/tmp/.dv-task"
  step "starting detached agent task…"
  if ! dt_run "$name" '"$HOME/.devflow/bin/dv-task-start" /tmp/.dv-task '"$agent_override" 60; then
    dt_run "$name" 'rm -f /tmp/.dv-task' 60 >/dev/null 2>&1 || true
    die "could not start task — another agent task may already be running (check: devflow status $name)"
  fi
  verify_agent_task_started "$name"
}

ensure_running() { # NAME — start if stopped/archived
  local st
  st="$(sandbox_state "$1")"
  case "$st" in
    started) return 0 ;;
    missing) die "no sandbox named '$1' — run: devflow up" ;;
    stopped|archived)
      step "sandbox is $st — starting…"
      dt start "$1" >/dev/null
      wait_for_state "$1" started 300
      ;;
    *)
      step "sandbox state: $st — waiting for it to start…"
      wait_for_state "$1" started 300
      ;;
  esac
}

# ----------------------------------------------------------------------------
# Sandbox listing / resolution
# ----------------------------------------------------------------------------
devflow_sandboxes_json() {
  dt list -f json 2>/dev/null \
    | jq '(if type == "object" then (.items // .sandboxes // .result // []) else . end)
          | [ .[] | select(((.labels // {})["devflow"] // "") == "1") ]'
}

resolve_name() { # [ARG] -> NAME (auto-picks when unambiguous)
  local arg="${1:-}"
  if [ -n "$arg" ]; then printf '%s' "$arg"; return 0; fi
  local names count
  names="$(devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' 2>/dev/null || true)"
  count="$(printf '%s' "$names" | grep -c . 2>/dev/null || true)"
  if [ "$count" = "1" ]; then printf '%s' "$names"; return 0; fi
  if [ "$count" = "0" ] || [ -z "$count" ]; then die "no devflow sandboxes — run: devflow up"; fi
  if have_cmd fzf && [ -t 0 ]; then
    printf '%s\n' "$names" | fzf --height=40% --reverse --prompt='sandbox> '
  else
    err "multiple sandboxes — specify one of:"
    printf '%s\n' "$names" >&2
    exit 1
  fi
}

# ----------------------------------------------------------------------------
# User scripts (up --script FILE) + Daytona forwarding (up --with-daytona)
# ----------------------------------------------------------------------------
emit_script_launcher() { # in-sandbox: start user-script.sh in tmux window 'script'
cat <<'DV_SCRIPTLAUNCH'
#!/usr/bin/env bash
# dv-script — run ~/.devflow/user-script.sh detach-safe (tmux window 'script')
set -u
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"
WD="$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"
"$HOME/.devflow/bin/dv-ensure" 2>/dev/null || true
if command -v tmux >/dev/null 2>&1 && tmux has-session -t dv 2>/dev/null; then
  tmux kill-window -t dv:script 2>/dev/null || true
  tmux new-window -d -t dv -n script -c "$WD" "$HOME/.devflow/bin/dv-script-exec"
  echo "script started in tmux window 'script'"
else
  nohup "$HOME/.devflow/bin/dv-script-exec" >/dev/null 2>&1 &
  echo "script started headless (log: ~/.devflow/script.log)"
fi
DV_SCRIPTLAUNCH
}

emit_script_exec() { # in-sandbox: the actual runner — tee to log, report exit
cat <<'DV_SCRIPTEXEC'
#!/usr/bin/env bash
set -u
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"
cd "$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")" 2>/dev/null || cd "$HOME"
LOG="$HOME/.devflow/script.log"
bash "$HOME/.devflow/user-script.sh" 2>&1 | tee "$LOG"
ec="${PIPESTATUS[0]}"
printf '[devflow script exit: %s]\n' "$ec" >> "$LOG"
if [ -n "${TMUX:-}" ]; then
  printf '[devflow script exit: %s] — window stays open for inspection (Ctrl-b d detaches)\n' "$ec"
  exec bash
fi
exit "$ec"
DV_SCRIPTEXEC
}

run_user_script() { # NAME LOCAL_FILE — upload + launch; best-effort (caller warns)
  local name="$1" file="$2"
  step "uploading ${C_BOLD}$(basename "$file")${C_RESET} → running in tmux window 'script'…"
  dt_push_file "$name" "/tmp/.dv-user-script" < "$file" || return 1
  emit_script_launcher | dt_push_file "$name" "/tmp/.dv-script" || return 1
  emit_script_exec | dt_push_file "$name" "/tmp/.dv-script-exec" || return 1
  dt_run "$name" 'mkdir -p "$HOME/.devflow/bin" && mv /tmp/.dv-user-script "$HOME/.devflow/user-script.sh" && mv /tmp/.dv-script "$HOME/.devflow/bin/dv-script" && mv /tmp/.dv-script-exec "$HOME/.devflow/bin/dv-script-exec" && chmod +x "$HOME/.devflow/user-script.sh" "$HOME/.devflow/bin/dv-script" "$HOME/.devflow/bin/dv-script-exec" && "$HOME/.devflow/bin/dv-script"' 60 || return 1
  ok "script running — watch: ${C_BOLD}devflow peek $name -w script${C_RESET} · log: devflow exec $name -- 'cat ~/.devflow/script.log'"
  return 0
}

sandbox_daytona_key() { # sets DT_SANDBOX_KEY: durable, VALIDATED API key (mints + caches once)
  # requires resolve_daytona_api to have run (DT_API_KEY/DT_API_URL/DT_ORG_ID set)
  DT_SANDBOX_KEY=""
  if [ -n "$DEVFLOW_DAYTONA_SANDBOX_KEY" ]; then
    if dt_key_valid "$DEVFLOW_DAYTONA_SANDBOX_KEY"; then
      DT_SANDBOX_KEY="$DEVFLOW_DAYTONA_SANDBOX_KEY"; return 0
    fi
    warn "cached devflow-sandboxes key was revoked — minting a fresh one"
  fi
  case "$DT_API_KEY" in
    dtn_*)  # already a durable key (env var or api-key login) — but verify it
      if dt_key_valid "$DT_API_KEY"; then DT_SANDBOX_KEY="$DT_API_KEY"; return 0; fi
      warn "local Daytona API key is stale (check DAYTONA_API_KEY in your shell env) — minting a fresh one"
      ;;
  esac
  # mint a dedicated, revocable, sandbox-scoped key and cache it (0600 secrets).
  # bearer: prefer the browser-login OAuth token; /api-keys needs a live credential
  local bearer="${DT_OAUTH_TOKEN:-$DT_API_KEY}" resp val
  [ -n "$DT_ORG_ID" ] || { warn "no active Daytona organization in CLI config (run: daytona login)"; return 1; }
  resp="$(curl -fsSL -X POST -H "Authorization: Bearer $bearer" \
          -H "X-Daytona-Organization-ID: $DT_ORG_ID" -H "Content-Type: application/json" \
          -d '{"name":"devflow-sandboxes","permissions":["write:sandboxes","delete:sandboxes"]}' \
          "$DT_API_URL/api-keys" 2>/dev/null)" || {
    # name may already exist from a lost secrets file — replace it (we own the name)
    curl -fsSL -X DELETE -H "Authorization: Bearer $bearer" \
      -H "X-Daytona-Organization-ID: $DT_ORG_ID" \
      "$DT_API_URL/api-keys/devflow-sandboxes" >/dev/null 2>&1
    resp="$(curl -fsSL -X POST -H "Authorization: Bearer $bearer" \
            -H "X-Daytona-Organization-ID: $DT_ORG_ID" -H "Content-Type: application/json" \
            -d '{"name":"devflow-sandboxes","permissions":["write:sandboxes","delete:sandboxes"]}' \
            "$DT_API_URL/api-keys" 2>/dev/null)" || { warn "could not mint a Daytona API key (run: daytona login)"; return 1; }
  }
  val="$(printf '%s' "$resp" | jq -r '.value // empty')"
  [ -n "$val" ] || { warn "unexpected api-keys response"; return 1; }
  config_set "$SECRETS_FILE" DEVFLOW_DAYTONA_SANDBOX_KEY "$val"
  DEVFLOW_DAYTONA_SANDBOX_KEY="$val"
  DT_SANDBOX_KEY="$val"
  step "minted Daytona API key 'devflow-sandboxes' (scope: sandboxes; revoke: app.daytona.io/dashboard/keys)"
}

forward_daytona() { # NAME — daytona CLI + API auth + devflow itself, inside the sandbox
  local name="$1"
  resolve_daytona_api || { warn "no local Daytona credentials (run: daytona login)"; return 1; }
  sandbox_daytona_key || return 1
  local fwd_key="$DT_SANDBOX_KEY"
  step "forwarding Daytona control into ${C_BOLD}$name${C_RESET} (CLI + API key + devflow — ~30s)…"
  local dtv
  dtv="$(daytona version 2>/dev/null | sed -n 's/.*v\([0-9][0-9.]*\).*/\1/p' | head -1)"
  [ -n "$dtv" ] || dtv="$DT_PIN_VERSION"
  # same config schema the daytona CLI writes; 0600 like every devflow secret
  local org_field=""
  [ -n "$DT_ORG_ID" ] && org_field=",\"activeOrganizationId\":\"$DT_ORG_ID\""
  printf '{"activeProfile":"default","profiles":[{"id":"default","name":"default","api":{"url":"%s","key":"%s"}%s}]}' \
      "$DT_API_URL" "$fwd_key" "$org_field" \
    | dt_push_file "$name" "/tmp/.dv-daytona-config" || return 1
  dt_push_file "$name" "/tmp/.dv-devflow" < "$0" || return 1
  # the sandbox image ships its own `daytona` binary (the in-sandbox daemon on
  # /usr/local/bin) — so install the real CLI unconditionally at ~/.local/bin
  # (which shadows it on PATH) and sanity-check it actually IS the CLI
  dt_run "$name" 'mkdir -p "$HOME/.local/bin" "$HOME/.config/daytona" && mv /tmp/.dv-daytona-config "$HOME/.config/daytona/config.json" && chmod 600 "$HOME/.config/daytona/config.json" && mv /tmp/.dv-devflow "$HOME/.local/bin/devflow" && chmod +x "$HOME/.local/bin/devflow" && ln -sf "$HOME/.local/bin/devflow" "$HOME/.local/bin/dv" && { [ -x "$HOME/.local/bin/daytona" ] || { curl -fsSL "https://github.com/daytona/clients/releases/download/v'"$dtv"'/daytona-linux-amd64" -o "$HOME/.local/bin/daytona" && chmod +x "$HOME/.local/bin/daytona" && timeout 10 "$HOME/.local/bin/daytona" version 2>/dev/null | grep -q "Daytona CLI"; }; } && { command -v jq >/dev/null 2>&1 || { curl -fsSL "https://github.com/jqlang/jq/releases/download/jq-1.7.1/jq-linux-amd64" -o "$HOME/.local/bin/jq" && chmod +x "$HOME/.local/bin/jq"; }; }' 240 || return 1
  ok "sandbox can now run ${C_BOLD}daytona${C_RESET} + ${C_BOLD}devflow${C_RESET} — new sandboxes it makes are ${C_BOLD}siblings${C_RESET} on your account (bill + need cleanup: devflow rm)"
  return 0
}

# ----------------------------------------------------------------------------
# Commands
# ----------------------------------------------------------------------------
set_forwarding_options() { # AWS_PROFILE SECRET_ENV_NAMES ALLOW_STATIC ENV_ITEMS
  DEVFLOW_AWS_PROFILE="$1"
  DEVFLOW_SECRET_ENV_NAMES="$2"
  DEVFLOW_ALLOW_STATIC_AWS="$3"
  DEVFLOW_ENV_ITEMS="${4:-}"
  _HARVESTED=0
  if [ -n "$DEVFLOW_AWS_PROFILE" ]; then
    need_cmd aws "install AWS CLI v2"
    need_cmd jq "brew install jq"
  fi
}

refresh_forwarded_auth() { # NAME [RUN_TOOLS]
  local name="$1" run_tools="${2:-0}"
  ensure_running "$name"
  step "re-syncing auth and explicitly forwarded credentials into '$name'…"
  upload_provisioner "$name" 1
  if [ "$run_tools" = 1 ]; then
    run_phase "$name" tools "" "" "" "" "core" \
      || die "sandbox tools phase failed; auth was not refreshed"
  fi
  run_phase "$name" auth "" "" "" "" "core" \
    || die "sandbox auth phase failed"
  ok "auth refreshed in '$name'"
}

cmd_up() {
  local repo="" name="" branch="" agent="$DEVFLOW_AGENT" task="" attach=1 fresh=0 blank=0
  local size="" cpu="$DEVFLOW_CPU" memory="$DEVFLOW_MEMORY" disk="$DEVFLOW_DISK" auto_stop="$DEVFLOW_AUTO_STOP"
  local snapshot="$DEVFLOW_SNAPSHOT" explicit_resources=0 harness="$DEVFLOW_HARNESS"
  local script="" with_daytona=0 aws_profile="" secret_env_names="" env_items="" allow_static_aws=0
  local size_explicit=0 snapshot_explicit=0 agent_explicit=0

  while [ $# -gt 0 ]; do
    case "$1" in
      -a|--agent)   need_val "$1" "${2:-}"; agent="$2"; agent_explicit=1; shift 2 ;;
      -H|--harness) need_val "$1" "${2:-}"; harness="$2"; shift 2 ;;
      -n|--name)    need_val "$1" "${2:-}"; name="$2"; shift 2 ;;
      -b|--branch)  need_val "$1" "${2:-}"; branch="$2"; shift 2 ;;
      -m|--task)    need_val "$1" "${2:-}"; task="$2"; shift 2 ;;
      -s|--size)    need_val "$1" "${2:-}"; size="$2"; size_explicit=1; shift 2 ;;
      --cpu)        need_val "$1" "${2:-}"; cpu="$2"; explicit_resources=1; shift 2 ;;      # legacy
      --memory)     need_val "$1" "${2:-}"; memory="$2"; explicit_resources=1; shift 2 ;;   # legacy
      --disk)       need_val "$1" "${2:-}"; disk="$2"; explicit_resources=1; shift 2 ;;     # legacy
      --auto-stop)  need_val "$1" "${2:-}"; auto_stop="$2"; shift 2 ;;
      --snapshot)   need_val "$1" "${2:-}"; snapshot="$2"; snapshot_explicit=1; shift 2 ;;
      --script)     need_val "$1" "${2:-}"; script="$2"; shift 2 ;;
      --aws-profile) need_val "$1" "${2:-}"; aws_profile="$2"; shift 2 ;;
      --secret-env) need_val "$1" "${2:-}"; secret_env_names="${secret_env_names}${secret_env_names:+ }$2"; shift 2 ;;
      --env) need_val "$1" "${2:-}"; env_items="${env_items}${env_items:+ }$(printf '%s' "$2" | b64_encode)"; shift 2 ;;
      --allow-static-aws) allow_static_aws=1; shift ;;
      --with-daytona) with_daytona=1; shift ;;
      --no-attach|--detach) attach=0; shift ;;
      --fresh)      fresh=1; shift ;;
      --blank)      blank=1; shift ;;
      --pick)       repo="__PICK__"; shift ;;
      -h|--help)    usage_up; return 0 ;;
      -*)           die "unknown flag for up: $1 (see: devflow up --help)" ;;
      *)            # a positional that names a local file is a script to run
                    if [ -z "$script" ] && [ -f "$1" ]; then script="$1"
                    else repo="$1"; fi
                    shift ;;
    esac
  done
  [ -n "$script" ] && [ ! -f "$script" ] && die "script not found: $script"
  set_forwarding_options "$aws_profile" "$secret_env_names" "$allow_static_aws" "$env_items"
  # Resolve and validate credentials before creating anything billable.
  if [ -n "$aws_profile$secret_env_names$env_items" ]; then harvest_all; fi

  case "$agent" in claude|codex|both|none) ;; *) die "invalid --agent '$agent' (claude|codex|both|none)" ;; esac
  case "$harness" in auto|omc|omx|both|core|none) ;; *) die "invalid --harness '$harness' (auto|omc|omx|both|core|none)" ;; esac
  harness="$(resolve_harness "$agent" "$harness")"

  # --- size (a custom snapshot brings its own; else pick a Daytona size class) ---
  if [ "$size_explicit" = 1 ] && [ "$snapshot_explicit" = 0 ] && [ -n "$snapshot" ]; then
    step "explicit --size overrides configured snapshot '$snapshot'"
    snapshot=""
  fi
  if [ -n "$snapshot" ]; then
    if [ -n "$size" ] || [ "$explicit_resources" = 1 ]; then
      step "note: --size/--cpu/--memory/--disk ignored — snapshot '$snapshot' has its size baked in (want another? devflow snapshot build --size ${size:-small|medium|large}, or --snapshot to pick)"
    fi
  else
    if [ -z "$size" ] && [ "$explicit_resources" = 1 ]; then
      size="$(size_for_resources "$cpu" "$memory" "$disk")"
      step "note: Daytona sizes sandboxes in classes now — --cpu/--memory/--disk map to --size $size ($(size_desc "$size"))"
    elif [ -z "$size" ]; then
      size="$(default_size)"
    fi
    case "$size" in small|medium|large) ;; *) die "invalid --size '$size' (small|medium|large)" ;; esac
  fi

  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup   (or: daytona login)"

  # --- resolve repo ---
  if [ "$blank" = 1 ]; then
    repo=""
  elif [ "$repo" = "__PICK__" ]; then
    pick_repo; repo="$REPO_PICKED"
  elif [ -n "$repo" ]; then
    local norm
    norm="$(repo_from_arg "$repo")"
    [ -n "$norm" ] || die "could not parse repo '$repo' — expected owner/name or a GitHub URL"
    repo="$norm"
  else
    repo="$(current_repo)"
    if [ -n "$repo" ]; then
      step "using current repo: ${C_BOLD}$repo${C_RESET}"
    elif [ -t 0 ]; then
      pick_repo; repo="$REPO_PICKED"
    fi
  fi

  # --- name ---
  if [ -z "$name" ]; then
    if [ -n "$repo" ]; then name="dv-$(sanitize_name "${repo##*/}")"
    else name="dv-scratch"; fi
  else
    name="$(sanitize_name "$name")"
  fi

  # --- existing sandbox? ---
  local st
  st="$(sandbox_state "$name")"
  if [ "$st" != "missing" ]; then
    if [ "$fresh" = 1 ]; then
      step "recreating '$name' (--fresh)…"
      dt delete "$name" >/dev/null 2>&1 || true
    else
      say "sandbox '$name' already exists ($st). (--fresh recreates, -n NAME makes another)"
      local needs_remote=0 reprovisioned=0
      if [ "$with_daytona" = 1 ] || [ -n "$script$task$aws_profile$secret_env_names$env_items" ]; then
        needs_remote=1
      elif [ "$attach" = 1 ] && [ -t 0 ]; then
        needs_remote=1
      fi
      [ "$needs_remote" = 1 ] && ensure_running "$name"
      if [ "$needs_remote" = 1 ] && ! sandbox_is_provisioned "$name"; then
        step "sandbox provisioning is incomplete or outdated — resuming all phases…"
        provision_sandbox "$name" "$agent" "$repo" "$branch" "$task" "$harness"
        ok "provisioned"
        [ -n "$task" ] && verify_agent_task_started "$name"
        reprovisioned=1
      fi
      if [ "$reprovisioned" = 0 ] && [ -n "$aws_profile$secret_env_names$env_items" ]; then
        refresh_forwarded_auth "$name" "$([ -n "$aws_profile" ] && printf 1 || printf 0)"
      fi
      if [ "$reprovisioned" = 0 ] && [ -n "$task" ]; then
        if [ "$agent_explicit" = 1 ]; then
          queue_agent_task "$name" "$task" "$agent"
        else
          queue_agent_task "$name" "$task"
        fi
      fi
      [ "$with_daytona" = 1 ] && { forward_daytona "$name" || warn "daytona forwarding failed"; }
      [ -n "$script" ] && { run_user_script "$name" "$script" || warn "script launch failed"; }
      if [ -n "$task" ]; then
        say "the agent is on it. it keeps working even when you're not attached."
        step "poll state:     ${C_BOLD}devflow status $name${C_RESET}"
        step "peek progress:  ${C_BOLD}devflow peek $name${C_RESET}"
      fi
      if [ "$attach" = 1 ] && [ -t 0 ]; then
        cmd_attach "$name"
        return $?
      fi
      ok "up. attach anytime, from any machine:  ${C_BOLD}devflow attach $name${C_RESET}"
      return 0
    fi
  fi

  local size_note
  size_note="size=$size ($(size_desc "$size"))"
  [ -n "$snapshot" ] && size_note="snapshot=$snapshot"
  say "spinning up ${C_BOLD}$name${C_RESET}  ${C_DIM}agent=$agent harness=$harness repo=${repo:-none} $size_note auto-stop=${auto_stop}m${C_RESET}"
  auth_summary

  # --- create (never pass raw resources: the API rejects them with snapshots,
  # and even the default image is a snapshot — sizes live in the snapshot) ---
  local create_args
  create_args=(create "--name=$name" "--auto-stop=$auto_stop"
               --label devflow=1 --label "devflow.agent=$agent"
               --label "devflow.harness=$harness")
  [ -n "$repo" ] && create_args+=(--label "devflow.repo=$repo")
  if [ -n "$snapshot" ]; then
    create_args+=("--snapshot=$snapshot")
  else
    create_args+=("--snapshot=daytona-$size")
  fi
  [ -n "$DEVFLOW_TARGET" ] && create_args+=("--target=$DEVFLOW_TARGET")

  step "creating sandbox…"
  dt "${create_args[@]}" || die "sandbox create failed (check quota/billing at app.daytona.io)"
  wait_for_state "$name" started 300
  ok "sandbox running"

  provision_sandbox "$name" "$agent" "$repo" "$branch" "$task" "$harness"
  ok "provisioned"
  [ -n "$task" ] && verify_agent_task_started "$name"

  [ "$with_daytona" = 1 ] && { forward_daytona "$name" \
    || warn "daytona forwarding failed — the sandbox can't manage sibling sandboxes"; }
  [ -n "$script" ] && { run_user_script "$name" "$script" \
    || warn "script launch failed — session is still up (retry: devflow up -n $name --script $script)"; }

  [ -n "$DEVFLOW_AUTO_HANDOFF" ] && { auto_handoff "$name" || true; }

  if [ -n "$task" ]; then
    say "the agent is on it. it keeps working even when you're not attached."
    step "poll state:     ${C_BOLD}devflow status $name${C_RESET}"
    step "peek progress:  ${C_BOLD}devflow peek $name${C_RESET}"
    step "join session:   ${C_BOLD}devflow attach $name${C_RESET}"
  fi
  if [ -n "$script" ]; then
    step "script output:  ${C_BOLD}devflow peek $name -w script${C_RESET}"
  fi

  if [ "$attach" = 1 ] && [ -t 0 ]; then
    cmd_attach "$name"
  else
    ok "up. attach anytime, from any machine:  ${C_BOLD}devflow attach $name${C_RESET}"
  fi
}

cmd_attach() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup"
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  [ -n "$name" ] || exit 1
  ensure_running "$name"
  # if the sandbox restarted, this recreates the tmux session + resumes the agent
  dt_run "$name" '"$HOME/.devflow/bin/dv-ensure" 2>/dev/null || true' 60 >/dev/null 2>&1 || true
  say "attaching to ${C_BOLD}$name${C_RESET} ${C_DIM}(detach: Ctrl-b d — the session keeps running)${C_RESET}"
  exec daytona ssh "$name"
}

cmd_ssh() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  ensure_running "$name"
  exec daytona ssh "$name"
}

# Mint a tokenized `ssh …@ssh.app.daytona.io` line via Daytona's ssh-access
# API. Prints ONLY the ssh line on stdout (so it's safe in $(…)); dies on
# stderr on any failure. Caller handles resolve_name + ensure_running.
# Shared by `ssh-command` and `mobile`.
resolve_daytona_api() { # sets DT_API_KEY / DT_API_URL / DT_ORG_ID; rc 1 if no credential
  # browser logins store an OAuth token (api.key is null) — the API accepts it
  # as a Bearer too; api-key logins store api.key. Env vars override the file.
  DT_API_KEY="${DAYTONA_API_KEY:-}"
  DT_API_URL="${DAYTONA_API_URL:-https://app.daytona.io/api}"
  DT_ORG_ID=""
  DT_OAUTH_TOKEN=""
  local cfg u
  for cfg in "$HOME/Library/Application Support/daytona/config.json" \
             "${XDG_CONFIG_HOME:-$HOME/.config}/daytona/config.json"; do
    [ -f "$cfg" ] || continue
    [ -z "$DT_API_KEY" ] && DT_API_KEY="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
               | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
               | (.api.key // .api.token.accessToken // empty)' "$cfg" 2>/dev/null | head -1)"
    DT_OAUTH_TOKEN="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
               | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
               | (.api.token.accessToken // empty)' "$cfg" 2>/dev/null | head -1)"
    u="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
               | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
               | (.api.url // empty)' "$cfg" 2>/dev/null | head -1)"
    [ -n "$u" ] && DT_API_URL="$u"
    DT_ORG_ID="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
               | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
               | (.activeOrganizationId // empty)' "$cfg" 2>/dev/null | head -1)"
    [ -n "$DT_API_KEY" ] && break
  done
  [ -n "$DT_API_KEY" ]
}

dt_key_valid() { # KEY — does the API accept it? (org is implied by the key)
  curl -fsS -o /dev/null -H "Authorization: Bearer $1" "$DT_API_URL/sandbox" 2>/dev/null
}

mint_ssh_command() { # NAME EXPIRES_MIN -> ssh line on stdout
  local name="$1" expires="$2"
  need_cmd jq "brew install jq"
  need_cmd curl "install curl"

  resolve_daytona_api \
    || die "no Daytona API key available — use 'devflow ssh $name' instead, or set DAYTONA_API_KEY"
  local api_key="$DT_API_KEY" api_url="$DT_API_URL"

  local sandbox_id resp
  sandbox_id="$(dt_info_json "$name" | jq -r '.id // .sandboxId // empty')"
  [ -n "$sandbox_id" ] || die "could not resolve sandbox id for '$name'"
  resp="$(curl -fsSL -X POST -H "Authorization: Bearer $api_key" \
          "$api_url/sandbox/$sandbox_id/ssh-access?expiresInMinutes=$expires" 2>/dev/null)" \
    || die "ssh-access API call failed — fall back to: devflow ssh $name  (a stale DAYTONA_API_KEY env var overrides your login — unset it if set)"
  local sshcmd token
  sshcmd="$(printf '%s' "$resp" | jq -r '.sshCommand // empty')"
  token="$(printf '%s' "$resp" | jq -r '.token // empty')"
  if [ -z "$sshcmd" ] && [ -n "$token" ]; then
    sshcmd="ssh $token@ssh.app.daytona.io"
  fi
  [ -n "$sshcmd" ] || die "unexpected ssh-access response — fall back to: devflow ssh $name"
  printf '%s\n' "$sshcmd"
}

cmd_ssh_command() { # print a plain `ssh` command usable from any machine
  local name="" expires=1440
  while [ $# -gt 0 ]; do
    case "$1" in
      --expires) need_val "$1" "${2:-}"; expires="$2"; shift 2 ;;
      *) name="$1"; shift ;;
    esac
  done
  name="$(resolve_name "$name")" || exit 1
  ensure_running "$name"
  local sshcmd
  sshcmd="$(mint_ssh_command "$name" "$expires")" || exit 1
  say "valid for ${expires}m — run from any machine with plain ssh:"
  printf '%s\n' "$sshcmd"
}

# Print FILE minus the managed block delimited by BEGIN/END marker lines.
strip_managed_block() { # FILE BEGIN END
  [ -f "$1" ] || return 0
  awk -v b="$2" -v e="$3" '$0==b{skip=1} !skip{print} $0==e{skip=0}' "$1"
}

# Managed ~/.ssh/config Host block: after this, plain `ssh dv-NAME` works —
# and so does anything built on ssh config: VS Code / Cursor Remote-SSH,
# scp, rsync. Idempotent (re-run replaces the block, e.g. after token
# expiry); --remove deletes it and touches nothing else in the file.
cmd_ssh_config() {
  local name="" expires=1440 cfgfile="$HOME/.ssh/config" remove=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --expires) need_val "$1" "${2:-}"; expires="$2"; shift 2 ;;
      --file)    need_val "$1" "${2:-}"; cfgfile="$2"; shift 2 ;;
      --remove)  remove=1; shift ;;
      -h|--help) printf 'devflow ssh-config [NAME] [--expires MIN] [--file PATH] [--remove] — managed Host block: plain `ssh NAME` + editor Remote-SSH\n'; return 0 ;;
      *)         name="$1"; shift ;;
    esac
  done

  if [ "$remove" = 1 ]; then
    # no resolve/mint — must work even after the sandbox is gone
    [ -n "$name" ] || die "usage: devflow ssh-config NAME --remove"
    local tmp_rm
    tmp_rm="$(mktemp "${TMPDIR:-/tmp}/devflow.XXXXXX")"
    strip_managed_block "$cfgfile" "# >>> devflow $name >>>" "# <<< devflow $name <<<" > "$tmp_rm"
    mv "$tmp_rm" "$cfgfile"
    chmod 600 "$cfgfile" 2>/dev/null || true
    ok "removed Host $name from $cfgfile"
    return 0
  fi

  name="$(resolve_name "$name")" || exit 1
  ensure_running "$name"
  local sshcmd uri target user host port=22
  sshcmd="$(mint_ssh_command "$name" "$expires")" || exit 1
  uri="$(ssh_uri_from_command "$sshcmd")"
  [ -n "$uri" ] || die "couldn't parse user@host from: $sshcmd"
  target="${uri#ssh://}"
  user="${target%%@*}"
  host="${target#*@}"
  case "$host" in *:*) port="${host##*:}"; host="${host%%:*}" ;; esac

  local begin="# >>> devflow $name >>>" end="# <<< devflow $name <<<" tmp
  mkdir -p "$(dirname "$cfgfile")"
  chmod 700 "$(dirname "$cfgfile")" 2>/dev/null || true
  tmp="$(mktemp "${TMPDIR:-/tmp}/devflow.XXXXXX")"
  strip_managed_block "$cfgfile" "$begin" "$end" > "$tmp"
  {
    printf '%s\n' "$begin"
    printf 'Host %s\n' "$name"
    printf '  HostName %s\n' "$host"
    printf '  Port %s\n' "$port"
    printf '  User %s\n' "$user"
    printf '  StrictHostKeyChecking accept-new\n'
    printf '%s\n' "$end"
  } >> "$tmp"
  mv "$tmp" "$cfgfile"
  chmod 600 "$cfgfile"

  ok "ssh config written: ${C_BOLD}Host $name${C_RESET} → $cfgfile ${C_DIM}(token valid ${expires}m)${C_RESET}"
  step "terminal:        ${C_BOLD}ssh $name${C_RESET}   (lands in the live tmux agent)"
  step "VS Code/Cursor:  Remote-SSH: Connect to Host… → $name ${C_DIM}(or: code --remote ssh-remote+$name /home/daytona/$DEVFLOW_WORKROOT)${C_RESET}"
  step "after expiry, refresh with:  ${C_BOLD}devflow ssh-config $name --expires 10080${C_RESET}"
}

# --- phone hand-off helpers (devflow mobile) --------------------------------

# ssh://user@host[:port] URI from an `ssh …` command line. Mobile SSH apps
# (Termius, Blink, ConnectBot, …) register the ssh:// scheme, so a QR of the
# URI opens the session in one camera-tap. Prints nothing if the command has
# no user@host target.
ssh_uri_from_command() { # SSHCMD
  local w target="" port="" prev=""
  # shellcheck disable=SC2086  # word-splitting the command line is the point
  for w in $1; do
    case "$w" in *@*) target="$w" ;; esac
    [ "$prev" = "-p" ] && port="$w"
    prev="$w"
  done
  [ -n "$target" ] || return 0
  printf 'ssh://%s%s' "$target" "${port:+:$port}"
}

# Render PAYLOAD as a terminal QR via qrencode — generated locally, so the
# token never touches a third-party service. Quiet rc-1 when qrencode is
# missing or fails; the caller prints its own fallback hint.
emit_qr() { # PAYLOAD -> indented QR on stdout
  have_cmd qrencode || return 1
  local qrtype=UTF8 out
  [ -n "$C_BOLD" ] && qrtype=ANSIUTF8   # paints true black/white, any theme
  out="$(qrencode -t "$qrtype" "$1" 2>/dev/null)" || return 1
  [ -n "$out" ] || return 1
  printf '%s\n' "$out" | sed 's/^/  /'
}

copy_to_clipboard() { # TEXT -> rc 0 if a clipboard tool took it
  if have_cmd pbcopy;  then printf '%s' "$1" | pbcopy 2>/dev/null && return 0; fi
  if have_cmd wl-copy; then printf '%s' "$1" | wl-copy 2>/dev/null && return 0; fi
  if have_cmd xclip;   then printf '%s' "$1" | xclip -selection clipboard 2>/dev/null && return 0; fi
  return 1
}

open_file() { # FILE -> open in the OS default app (best-effort)
  if have_cmd open; then open "$1" 2>/dev/null
  elif have_cmd xdg-open; then xdg-open "$1" 2>/dev/null
  else return 1; fi
}

# Self-contained HTML "reconnect pass" for when the phone isn't at hand at
# mint time: print it, AirDrop it later, or park it in a synced folder and
# open it from the phone's Files app. 0600 — it embeds a live token.
write_mobile_pass() { # FILE NAME SSHCMD URI EXPIRES_MIN
  local file="$1" name="$2" sshcmd="$3" uri="$4" expires="$5"
  local svg="" qrblock minted
  if [ -n "$uri" ] && have_cmd qrencode; then
    svg="$(qrencode -t SVG -s 8 -o - "$uri" 2>/dev/null)" || svg=""
  fi
  if [ -n "$svg" ]; then
    qrblock="<div class=\"qr\">$svg</div>"
  else
    qrblock="<p class=\"dim\"><em>(no QR — qrencode wasn't available when this pass was minted)</em></p>"
  fi
  minted="$(date)"
  ( umask 177
    cat > "$file" <<DV_MOBILE_PASS
<!doctype html>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>devflow reconnect pass — $name</title>
<style>
  body{font-family:-apple-system,system-ui,sans-serif;max-width:34em;margin:3em auto;padding:0 1em;color:#111;background:#fff}
  h1{font-size:1.3em}
  code{font-family:ui-monospace,Menlo,monospace;background:#f4f4f4;padding:.5em .7em;border-radius:6px;display:block;word-break:break-all;font-size:1.05em}
  .qr{margin:1.2em 0}
  .dim{color:#666;font-size:.9em}
  .warn{color:#8a4b00;background:#fff4e0;padding:.6em .8em;border-radius:6px;font-size:.9em}
</style>
<h1>devflow reconnect pass — $name</h1>
<p class="dim">minted $minted · token valid $expires minutes · any SSH login lands in the
live tmux agent (detach: Ctrl-b d)</p>
$qrblock
<p>scan with a phone camera (opens in Termius / Blink / ConnectBot), or run:</p>
<code>$sshcmd</code>
<p class="dim">no SSH app? browser terminal: <a href="https://app.daytona.io">app.daytona.io</a> → $name → Terminal</p>
<p class="warn">this file contains a live SSH token — treat it like a password; it expires
on its own, but delete it after use anyway.</p>
DV_MOBILE_PASS
  ) || die "could not write $file"
  chmod 600 "$file" 2>/dev/null || true
}

# One-time pairing for the push channel: mint a private high-entropy ntfy
# topic (the topic IS the password — ntfy's documented model), store it in
# the 0600 secrets file, and walk the phone through subscribing. Works for
# every laptop/phone combo: curl on macOS/Linux, ntfy app on Android/iOS.
setup_push_channel() {
  need_cmd curl "install curl"
  local topic="${DEVFLOW_NTFY_TOPIC:-}"
  if [ -z "$topic" ]; then
    topic="devflow-$(od -An -tx1 -N16 /dev/urandom | tr -d ' \n')"
    config_set "$SECRETS_FILE" DEVFLOW_NTFY_TOPIC "$topic"
    DEVFLOW_NTFY_TOPIC="$topic"
  fi
  say "push channel — one-time phone setup (works Android + iPhone, from macOS + Linux)"
  printf '\n'
  step "1) install the ${C_BOLD}ntfy${C_RESET} app — Android: Play/F-Droid · iPhone: App Store (free, open source)"
  step "2) in the app: Subscribe to topic — scan this or type it:"
  emit_qr "$DEVFLOW_NTFY_URL/$topic" || true
  printf '     %s%s/%s%s\n' "$C_BOLD" "$DEVFLOW_NTFY_URL" "$topic" "$C_RESET"
  printf '     %sthe topic name is the password — anyone who has it can read your pushes (kept 0600 in devflow secrets)%s\n' "$C_DIM" "$C_RESET"
  step "3) repeat on any other phone/tablet — same topic, they all get the pushes"
  printf '\n'
  if curl -fsS -X POST -H "X-Title: devflow" \
       -d "push channel works — 'devflow mobile --send push' lands here from any of your machines" \
       "$DEVFLOW_NTFY_URL/$topic" >/dev/null 2>&1; then
    ok "test notification sent — it should be on your phone now"
  else
    warn "test push failed — check network, then: devflow mobile --send push"
  fi
  step "self-hosting? point it at your server:  devflow config set DEVFLOW_NTFY_URL https://ntfy.example.com"
}

handoff_body() { # NAME SSHCMD URI EXPIRES_MIN -> message body on stdout
  printf 'devflow reconnect — %s\n%s\n' "$1" "$2"
  [ -n "$3" ] && printf 'one-tap: %s\n' "$3"
  printf 'minted %s · valid %sm · lands in the live tmux agent (detach: Ctrl-b d)\nno SSH app? https://app.daytona.io → %s → Terminal' "$(date)" "$4" "$1"
}

# Send the reconnect info through a channel that already syncs to the phone —
# no phone-in-hand needed at mint time; it's waiting there when you pick it
# up. Channels: ntfy push (any laptop → any phone, tap opens the SSH app),
# 1Password CLI (op), Bitwarden CLI (bw, needs BW_SESSION), Apple Notes via
# iCloud (osascript). auto = first available in that order. Prints the
# channel label on success; dies with a fix-it hint on an explicit target,
# falls through silently in auto mode.
send_handoff() { # TARGET(auto|push|op|bw|note) TITLE BODY URI -> channel label on stdout
  local target="$1" title="$2" body="$3" uri="$4"
  if [ "$target" = push ] || { [ "$target" = auto ] && [ -n "${DEVFLOW_NTFY_TOPIC:-}" ]; }; then
    if [ "$target" = push ] && [ -z "${DEVFLOW_NTFY_TOPIC:-}" ]; then
      die "push channel not set up — run: devflow mobile --setup-push"
    fi
    need_cmd curl "install curl"
    # X-Click: tapping the notification opens the SSH app via the ssh:// URI
    if curl -fsS -X POST -H "X-Title: $title" -H "X-Click: ${uri:-https://app.daytona.io}" \
         -d "$body" "$DEVFLOW_NTFY_URL/$DEVFLOW_NTFY_TOPIC" >/dev/null 2>&1; then
      printf 'push (ntfy)'; return 0
    fi
    [ "$target" = push ] && die "push failed — check network / DEVFLOW_NTFY_URL ($DEVFLOW_NTFY_URL)"
  fi
  if [ "$target" = op ] || { [ "$target" = auto ] && have_cmd op; }; then
    [ "$target" = op ] && need_cmd op "brew install 1password-cli"
    local operr=""
    if operr="$(op item create --category "Secure Note" --title "$title" "notesPlain=$body" 2>&1 >/dev/null)"; then
      printf '1Password'; return 0
    fi
    [ "$target" = op ] && die "op item create failed: ${operr:-unknown error} — try 'op signin' (or enable the 1Password app's CLI integration)"
  fi
  if [ "$target" = bw ] || { [ "$target" = auto ] && have_cmd bw && [ -n "${BW_SESSION:-}" ]; }; then
    [ "$target" = bw ] && need_cmd bw "brew install bitwarden-cli"
    local enc=""
    if enc="$(bw --nointeraction get template item 2>/dev/null \
          | jq --arg t "$title" --arg n "$body" '.type=2 | .secureNote={type:0} | .name=$t | .notes=$n' 2>/dev/null \
          | bw --nointeraction encode 2>/dev/null)" \
        && [ -n "$enc" ] && bw --nointeraction create item "$enc" >/dev/null 2>&1; then
      printf 'Bitwarden'; return 0
    fi
    [ "$target" = bw ] && die "bw create failed — unlock first: export BW_SESSION=\"\$(bw unlock --raw)\""
  fi
  if [ "$target" = note ] || { [ "$target" = auto ] && [ "$(uname 2>/dev/null)" = Darwin ] && have_cmd osascript; }; then
    [ "$target" = note ] && need_cmd osascript "Apple Notes hand-off is macOS-only"
    local body_html
    body_html="$(printf '%s\n' "$body" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' | awk '{printf "%s<br>", $0}')"
    if osascript - "$title" "$body_html" >/dev/null 2>&1 <<'DV_NOTE_AS'
on run argv
  tell application "Notes" to make new note with properties {name:(item 1 of argv), body:(item 2 of argv)}
end run
DV_NOTE_AS
    then printf 'Apple Notes (iCloud)'; return 0; fi
    [ "$target" = note ] && die "couldn't create the note — allow Terminal to control Notes (System Settings → Privacy & Security → Automation)"
  fi
  die "no hand-off channel available — install the 1Password CLI (op) or Bitwarden CLI (bw + BW_SESSION), or use Apple Notes on macOS. Zero-prep fallbacks: app.daytona.io from any browser, or 'devflow mobile --out FILE'"
}

# DEVFLOW_AUTO_HANDOFF: fire-and-forget hand-off at the end of every `up` —
# the reconnect line lands on the phone without being asked, so forgetting to
# run `devflow mobile` before leaving costs nothing. Best-effort by design:
# a failed mint/send warns and never blocks the session.
auto_handoff() { # NAME
  local name="$1" sshcmd="" uri="" body="" chan=""
  sshcmd="$(mint_ssh_command "$name" 1440 2>/dev/null)" \
    || { warn "auto-handoff: couldn't mint an ssh token — run 'devflow mobile' manually"; return 1; }
  uri="$(ssh_uri_from_command "$sshcmd")"
  body="$(handoff_body "$name" "$sshcmd" "$uri" 1440)"
  chan="$(send_handoff "$DEVFLOW_AUTO_HANDOFF" "devflow · $name" "$body" "$uri" 2>/dev/null)" \
    || { warn "auto-handoff: send failed (channel: $DEVFLOW_AUTO_HANDOFF) — run 'devflow mobile --send'"; return 1; }
  ok "auto-handoff: reconnect line sent via $chan"
}

cmd_mobile() { # hand the session to your phone: camera-scannable QR + ssh line + fallbacks
  local name="" expires=1440 want_qr=1 want_copy=1 want_open=0 outfile="" send_target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --expires)   need_val "$1" "${2:-}"; expires="$2"; shift 2 ;;
      --out)       need_val "$1" "${2:-}"; outfile="$2"; shift 2 ;;
      --open)      want_open=1; shift ;;
      --send)      send_target=auto
                   case "${2:-}" in push|op|bw|note) send_target="$2"; shift ;; esac
                   shift ;;
      --setup-push) setup_push_channel; return $? ;;
      --no-qr)     want_qr=0; shift ;;
      --no-copy)   want_copy=0; shift ;;
      -h|--help)   printf 'devflow mobile [NAME] [--expires MIN] [--send [push|op|bw|note]] [--setup-push] [--out FILE [--open]] [--no-qr] [--no-copy] — hand the session to your phone\n'; return 0 ;;
      *)           name="$1"; shift ;;
    esac
  done
  [ "$want_open" = 1 ] && [ -z "$outfile" ] && die "--open requires --out FILE"
  name="$(resolve_name "$name")" || exit 1
  ensure_running "$name"
  local sshcmd
  sshcmd="$(mint_ssh_command "$name" "$expires")" || exit 1

  local uri="" copied=0
  uri="$(ssh_uri_from_command "$sshcmd")"
  [ -n "$outfile" ] && write_mobile_pass "$outfile" "$name" "$sshcmd" "$uri" "$expires"
  local sent_via=""
  if [ -n "$send_target" ]; then
    local body
    body="$(handoff_body "$name" "$sshcmd" "$uri" "$expires")"
    sent_via="$(send_handoff "$send_target" "devflow · $name" "$body" "$uri")" || exit 1
  fi
  [ "$want_copy" = 1 ] && copy_to_clipboard "$sshcmd" && copied=1

  say "reconnect to ${C_BOLD}$name${C_RESET} from your phone or any other machine"
  printf '\n'
  if [ "$want_qr" = 1 ]; then
    local qr=""
    [ -n "$uri" ] && qr="$(emit_qr "$uri")" || true
    if [ -n "$qr" ]; then
      step "point your phone's camera at the QR — one tap opens the live session"
      printf '     %sworks with any ssh:// app: Termius · Blink · ConnectBot (Termux: use the line below)%s\n' "$C_DIM" "$C_RESET"
      printf '\n%s\n\n' "$qr"
    else
      warn "no QR — install qrencode (brew install qrencode / apt install qrencode); the paths below still work"
    fi
  fi
  step "1) Any SSH app — Android: Termux · iOS: Blink/Termius · Mac/Linux: built-in ssh"
  printf '     %s%s%s\n' "$C_BOLD" "$sshcmd" "$C_RESET"
  [ "$copied" = 1 ] && printf '     %s→ already on your clipboard (Universal Clipboard pastes it on a nearby iPhone/iPad)%s\n' \
         "$C_DIM" "$C_RESET"
  printf '     %svalid %sm (pass --expires MIN for longer) · lands straight in the live agent · detach: Ctrl-b d%s\n' \
         "$C_DIM" "$expires" "$C_RESET"
  printf '\n'
  step "2) Full devflow — Android (Termux / UserLAnd Ubuntu) or another Mac/Linux"
  printf '     %scurl -fsSL https://raw.githubusercontent.com/dalinkstone/devflow/main/install.sh | bash%s\n' "$C_DIM" "$C_RESET"
  printf '     %sdaytona login && devflow attach %s%s   (also restarts it if stopped)\n' "$C_DIM" "$name" "$C_RESET"
  printf '\n'
  step "3) Just a browser — https://app.daytona.io → $name → open its Terminal"
  printf '\n'
  if [ -n "$sent_via" ]; then
    ok "sent via ${C_BOLD}$sent_via${C_RESET} — it's already waiting on your phone"
  fi
  if [ -n "$outfile" ]; then
    ok "reconnect pass saved: ${C_BOLD}$outfile${C_RESET} — AirDrop it later, park it in a synced folder, or print it"
    printf '     %scontains the live token (chmod 600) — treat it like a password%s\n' "$C_DIM" "$C_RESET"
    if [ "$want_open" = 1 ]; then
      open_file "$outfile" || warn "couldn't auto-open $outfile"
    fi
  fi
  if [ -z "$sent_via" ] && [ -z "$outfile" ]; then
    step "phone not on you right now?  ${C_BOLD}devflow mobile --send${C_RESET} → push notification / password manager / Apple Notes ${C_DIM}(one-time: --setup-push)${C_RESET}"
  fi
  step "peek without attaching:  ${C_BOLD}devflow peek $name${C_RESET}"
}

cmd_exec() {
  local name="${1:-}"
  [ -n "$name" ] || die "usage: devflow exec NAME -- CMD…"
  shift
  [ "${1:-}" = "--" ] && shift
  [ $# -gt 0 ] || die "usage: devflow exec NAME -- CMD…"
  ensure_running "$name"
  dt_run "$name" "$*" 0
}

cmd_peek() {
  local name="" lines=40 window=agent
  while [ $# -gt 0 ]; do
    case "$1" in
      --lines) need_val "$1" "${2:-}"; lines="$2"; shift 2 ;;
      -w|--window) need_val "$1" "${2:-}"; window="$2"; shift 2 ;;
      *) name="$1"; shift ;;
    esac
  done
  name="$(resolve_name "$name")" || exit 1
  local st
  st="$(sandbox_state "$name")"
  if [ "$st" != "started" ]; then
    say "'$name' is ${st} — nothing running to peek at. ${C_DIM}devflow attach $name restarts it.${C_RESET}"
    return 0
  fi
  say "$window pane in ${C_BOLD}$name${C_RESET} (last $lines lines):"
  dt_run "$name" "tmux capture-pane -p -t dv:$window -S -$lines 2>/dev/null || echo '(no $window window — windows: agent/shell, plus codex/script when used)'" 60
}

cmd_status() {
  local name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) echo "usage: devflow status [NAME]"; return 0 ;;
      -*) die "unknown flag for status: $1" ;;
      *) [ -z "$name" ] || die "status accepts at most one sandbox name"; name="$1"; shift ;;
    esac
  done
  name="$(resolve_name "$name")" || exit 1
  local st
  st="$(sandbox_state "$name")"
  say "status for ${C_BOLD}$name${C_RESET}"
  printf 'sandbox_state=%s\n' "$st"
  [ "$st" = "started" ] || return 0
  dt_run "$name" 'run="$HOME/.devflow/run"; field() { sed -n "s/^$1=//p" "$run/status" 2>/dev/null | head -1; }; state="$(field state)"; agent="$(field agent)"; pid="$(field pid)"; started="$(field started_at)"; completed="$(field completed_at)"; exit_code="$(field exit_code)"; prompt_sha="$(field prompt_sha256)"; alive=no; [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && alive=yes; [ "$state" = running ] && [ "$alive" = no ] && state=stale; [ -n "$state" ] || state=not-started; tmux_state=absent; tmux has-session -t dv 2>/dev/null && tmux_state=running; printf "agent_state=%s\nagent=%s\nprocess_alive=%s\ntmux_session=%s\nstarted_at=%s\ncompleted_at=%s\nexit_code=%s\nprompt_sha256=%s\n" "$state" "${agent:-unknown}" "$alive" "$tmux_state" "${started:-}" "${completed:-}" "${exit_code:-}" "${prompt_sha:-}"' 60
}

cmd_ls() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup"
  local json count
  json="$(devflow_sandboxes_json)"
  count="$(printf '%s' "$json" | jq 'length')"
  if [ "$count" = "0" ]; then
    say "no devflow sandboxes yet. start one:  ${C_BOLD}devflow up${C_RESET}"
    return 0
  fi
  printf '%s\n' "${C_BOLD}NAME                     STATE      AGENT   REPO                              CPU/MEM${C_RESET}"
  printf '%s' "$json" | jq -r '.[] | [
      (.name // .id // "?"),
      (.state // .status // "?"),
      ((.labels // {})["devflow.agent"] // "-"),
      ((.labels // {})["devflow.repo"] // "-"),
      (((.cpu // "?") | tostring) + "c/" + ((.memory // "?") | tostring) + "g")
    ] | @tsv' \
  | while IFS=$'\t' read -r n s a r c; do
      local color="$C_DIM"
      [ "$s" = "started" ] && color="$C_GREEN"
      printf '%-24s %s%-10s%s %-7s %-33s %s\n' "$n" "$color" "$s" "$C_RESET" "$a" "$r" "$c"
    done
}

cmd_stop() {
  need_cmd jq "brew install jq"
  if [ "${1:-}" = "--all" ]; then
    local n
    devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' | while read -r n; do
      [ -n "$n" ] || continue
      step "stopping $n…"
      dt stop "$n" </dev/null >/dev/null 2>&1 || true
    done
    ok "all devflow sandboxes stopped"
    return 0
  fi
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  dt stop "$name"
  ok "stopped '$name' — disk preserved; 'devflow attach $name' restarts and resumes the agent"
}

cmd_rm() {
  need_cmd jq "brew install jq"
  local force=0 all=0 name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      --all) all=1; shift ;;
      *) name="$1"; shift ;;
    esac
  done
  if [ "$all" = 1 ]; then
    if [ "$force" != 1 ]; then confirm "delete ALL devflow sandboxes (unpushed work in them is lost)?" || exit 1; fi
    local n
    devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' | while read -r n; do
      [ -n "$n" ] || continue
      step "deleting $n…"
      dt delete "$n" </dev/null >/dev/null 2>&1 || true
    done
    ok "all devflow sandboxes deleted"
    return 0
  fi
  name="$(resolve_name "$name")" || exit 1
  if [ "$force" != 1 ]; then confirm "delete sandbox '$name'? unpushed work in it is lost" || exit 1; fi
  dt delete "$name"
  ok "deleted '$name'"
}

cmd_sync() {
  need_cmd jq "brew install jq"
  local name="" aws_profile="" secret_env_names="" env_items="" allow_static_aws=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --aws-profile) need_val "$1" "${2:-}"; aws_profile="$2"; shift 2 ;;
      --secret-env) need_val "$1" "${2:-}"; secret_env_names="${secret_env_names}${secret_env_names:+ }$2"; shift 2 ;;
      --env) need_val "$1" "${2:-}"; env_items="${env_items}${env_items:+ }$(printf '%s' "$2" | b64_encode)"; shift 2 ;;
      --allow-static-aws) allow_static_aws=1; shift ;;
      -h|--help)
        echo "usage: devflow sync [NAME] [--aws-profile PROFILE] [--secret-env VARIABLE] [--env NAME=VALUE] [--allow-static-aws]"
        return 0 ;;
      -*) die "unknown flag for sync: $1" ;;
      *) [ -z "$name" ] || die "sync accepts at most one sandbox name"; name="$1"; shift ;;
    esac
  done
  set_forwarding_options "$aws_profile" "$secret_env_names" "$allow_static_aws" "$env_items"
  [ -n "$aws_profile$secret_env_names$env_items" ] && harvest_all
  name="$(resolve_name "$name")" || exit 1
  refresh_forwarded_auth "$name" "$([ -n "$aws_profile" ] && printf 1 || printf 0)"
}

cmd_token() {
  need_cmd claude "curl -fsSL https://claude.ai/install.sh | bash"
  say "launching ${C_BOLD}claude setup-token${C_RESET} — approve in the browser, then copy the token it prints."
  claude setup-token || warn "setup-token exited non-zero"
  printf '%s' "paste token (sk-ant-oat01-…, input hidden): "
  local tok
  read -rs tok || true
  printf '\n'
  [ -n "$tok" ] || die "no token entered"
  case "$tok" in
    sk-ant-oat01-*) ;;
    *) warn "that doesn't look like a setup-token (expected sk-ant-oat01-…) — storing anyway" ;;
  esac
  config_set "$SECRETS_FILE" DEVFLOW_CLAUDE_TOKEN "$tok"
  ok "stored in $SECRETS_FILE (600). New sandboxes use it; refresh existing ones with: devflow sync"
}

cmd_config() {
  case "${1:-list}" in
    list)
      say "config file: $CONFIG_FILE"
      if [ -f "$CONFIG_FILE" ]; then sed 's/^/  /' "$CONFIG_FILE"; else echo "  (defaults — nothing set)"; fi
      ;;
    get)  [ -n "${2:-}" ] || die "usage: devflow config get KEY"
          eval "printf '%s\n' \"\${$2:-}\"" ;;
    set)  [ -n "${2:-}" ] && [ -n "${3:-}" ] || die "usage: devflow config set KEY VALUE"
          config_set "$CONFIG_FILE" "$2" "$3"; ok "$2 set" ;;
    edit) mkdir -p "$CONFIG_DIR"; "${EDITOR:-vi}" "$CONFIG_FILE" ;;
    *)    die "usage: devflow config [list|get KEY|set KEY VALUE|edit]" ;;
  esac
}

cmd_dashboard() {
  local url="https://app.daytona.io"
  if have_cmd open; then open "$url"; elif have_cmd xdg-open; then xdg-open "$url"; else say "$url"; fi
}

# ----------------------------------------------------------------------------
# setup & doctor
# ----------------------------------------------------------------------------
check_row() { # LABEL STATUS DETAIL
  local label="$1" status="$2" detail="${3:-}"
  case "$status" in
    ok)   printf '  %s %-26s %s\n' "${C_GREEN}✓${C_RESET}" "$label" "${C_DIM}$detail${C_RESET}" ;;
    warn) printf '  %s %-26s %s\n' "${C_YELLOW}!${C_RESET}" "$label" "$detail" ;;
    fail) printf '  %s %-26s %s\n' "${C_RED}✗${C_RESET}" "$label" "$detail" ;;
  esac
}

cmd_doctor() {
  say "$DEVFLOW_VERSION — environment check"
  echo
  printf '%s\n' "${C_BOLD}local tools${C_RESET}"
  local spec c fix
  for spec in "daytona|brew install daytonaio/cli/daytona" "jq|brew install jq" "git|xcode-select --install / apt install git" "gh|brew install gh" "fzf|brew install fzf (optional: nicer pickers)" "qrencode|brew install qrencode (optional: scan-to-phone QR in 'devflow mobile')"; do
    c="${spec%%|*}"; fix="${spec#*|}"
    if have_cmd "$c"; then check_row "$c" ok "$(command -v "$c")"
    else
      case "$c" in fzf|qrencode) check_row "$c" warn "missing — $fix" ;; *) check_row "$c" fail "missing — $fix" ;; esac
    fi
  done
  local handoff=""
  [ -n "${DEVFLOW_NTFY_TOPIC:-}" ] && handoff="push (ntfy)"
  have_cmd op && handoff="${handoff:+$handoff · }1Password"
  have_cmd bw && handoff="${handoff:+$handoff · }Bitwarden"
  [ "$(uname 2>/dev/null)" = Darwin ] && have_cmd osascript && handoff="${handoff:+$handoff · }Apple Notes"
  if [ -n "$handoff" ]; then
    check_row "phone hand-off" ok "devflow mobile --send → $handoff"
  else
    check_row "phone hand-off" warn "none — run 'devflow mobile --setup-push' (any phone), or brew install 1password-cli"
  fi
  echo
  printf '%s\n' "${C_BOLD}accounts${C_RESET}"
  if have_cmd daytona && dt_auth_check; then
    check_row "daytona" ok "logged in"
  else
    check_row "daytona" fail "daytona login   (API keys: app.daytona.io/dashboard/keys)"
  fi
  if have_cmd gh && gh auth status >/dev/null 2>&1; then
    check_row "github (gh)" ok "$(gh api user -q .login 2>/dev/null || echo 'logged in')"
  else
    check_row "github (gh)" fail "gh auth login"
  fi
  harvest_all
  case "$CLAUDE_MODE" in
    token) check_row "claude (subscription)" ok "long-lived token configured" ;;
    creds) check_row "claude (subscription)" ok "local credentials found (tip: devflow token)" ;;
    *)     check_row "claude (subscription)" warn "none — run 'devflow token' (or log in to claude locally)" ;;
  esac
  # shellcheck disable=SC2088  # display text, not a path
  if [ -n "$CODEX_AUTH_B64" ]; then check_row "codex (chatgpt)" ok "~/.codex/auth.json present"
  else check_row "codex (chatgpt)" warn "none — run 'codex' locally, sign in with ChatGPT"; fi
  echo
  printf '%s\n' "${C_BOLD}defaults${C_RESET}"
  check_row "agent" ok "$DEVFLOW_AGENT"
  check_row "harness" ok "$DEVFLOW_HARNESS (auto → omc for claude, omx for codex)"
  local dsize; dsize="$(default_size)"
  check_row "size" ok "$dsize ($(size_desc "$dsize"))"
  check_row "auto-stop" ok "${DEVFLOW_AUTO_STOP}m (0 = runs until 'devflow stop')"
  [ -n "$DEVFLOW_AUTO_HANDOFF" ] && check_row "auto-handoff" ok "$DEVFLOW_AUTO_HANDOFF (every 'up' sends the reconnect line to your phone)"
  [ -n "$DEVFLOW_SNAPSHOT" ] && check_row "snapshot" ok "$DEVFLOW_SNAPSHOT"
  echo
  say "ready? try:  ${C_BOLD}devflow up${C_RESET}"
}

cmd_setup() {
  say "$DEVFLOW_VERSION setup — cloud agent sessions on your subscriptions"
  mkdir -p "$CONFIG_DIR"; chmod 700 "$CONFIG_DIR"
  echo

  step "1/5 dependencies…"
  local missing="" c
  for c in daytona jq git gh qrencode; do have_cmd "$c" || missing="$missing $c"; done
  if [ -n "$missing" ]; then
    if have_cmd brew; then
      if confirm "install missing tools via Homebrew:$missing?"; then
        for c in $missing; do
          case "$c" in
            daytona) brew install daytonaio/cli/daytona ;;
            *)       brew install "$c" ;;
          esac
        done
      fi
    else
      warn "missing:$missing — install them and re-run devflow setup"
    fi
  fi
  ok "dependencies"

  step "2/5 Daytona account (sandbox cloud — \$200 free compute for new accounts)…"
  if have_cmd daytona && dt_auth_check; then
    ok "already logged in to Daytona"
  else
    say "a browser opens to sign in / sign up at app.daytona.io"
    if confirm "run 'daytona login' now?"; then
      dt login || warn "login failed — alternative: daytona login --api-key KEY (app.daytona.io/dashboard/keys)"
    else
      warn "skipped — run 'daytona login' before 'devflow up'"
    fi
  fi

  step "3/5 Claude Code subscription auth…"
  harvest_all
  case "$CLAUDE_MODE" in
    token) ok "long-lived token already configured" ;;
    creds)
      ok "local subscription credentials detected — they'll be copied into sandboxes"
      say "recommended: a dedicated 1-year token avoids login races between laptop and sandbox."
      if confirm "create one now with 'claude setup-token'?"; then cmd_token; fi
      ;;
    *)
      warn "no Claude credentials found"
      if have_cmd claude && confirm "run 'claude setup-token' now (needs Pro/Max subscription)?"; then cmd_token; fi
      ;;
  esac

  step "4/5 Codex (ChatGPT) auth…"
  if [ -n "${CODEX_AUTH_B64:-}" ]; then
    # shellcheck disable=SC2088  # display text, not a path
    ok "~/.codex/auth.json found — it'll be copied into sandboxes"
  else
    warn "not signed in to Codex — run 'codex', pick 'Sign in with ChatGPT', then re-run setup"
  fi

  step "5/5 GitHub + defaults…"
  if have_cmd gh && gh auth status >/dev/null 2>&1; then
    ok "gh authenticated"
  else
    if have_cmd gh && confirm "run 'gh auth login' now?"; then gh auth login; fi
  fi
  if [ -t 0 ]; then
    printf 'default agent [claude/codex/both] (claude): '
    local a; read -r a || true
    case "$a" in codex|both) config_set "$CONFIG_FILE" DEVFLOW_AGENT "$a"; ok "default agent: $a" ;; *) ;; esac
  fi
  echo
  ok "setup complete — verify with ${C_BOLD}devflow doctor${C_RESET}, then run ${C_BOLD}devflow up${C_RESET}"
}

# ----------------------------------------------------------------------------
# Custom snapshot (optional: instant starts)
# ----------------------------------------------------------------------------
emit_dockerfile() {
cat <<'DV_DOCKERFILE'
# devflow base snapshot — agents + toolchains prebaked for instant session
# starts (claude, codex, gh, tmux, node, go, bun, uv, build tools, harnesses).
# Built server-side by Daytona:  devflow snapshot build [--size S]
FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash ca-certificates curl git jq ripgrep sudo tmux unzip xz-utils \
      python3 python3-pip openssh-client less nano vim-tiny locales \
      build-essential pkg-config \
    && rm -rf /var/lib/apt/lists/*
# Go toolchain — /usr/local/bin is on every shell's PATH, login or not
RUN GO_V=1.26.5 && \
    curl -fsSL "https://go.dev/dl/go${GO_V}.linux-amd64.tar.gz" | tar -xz -C /usr/local && \
    ln -s /usr/local/go/bin/go /usr/local/bin/go && \
    ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt
# non-root user with passwordless sudo (claude bypass mode refuses root)
RUN userdel -r ubuntu 2>/dev/null || true; \
    useradd -m -s /bin/bash -u 1000 daytona && \
    echo 'daytona ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/91-daytona
USER daytona
WORKDIR /home/daytona
ENV HOME=/home/daytona
ENV PATH="/home/daytona/.local/bin:${PATH}"
RUN mkdir -p "$HOME/.local/bin" && \
    curl -fsSL https://claude.ai/install.sh | bash && \
    GH_V=2.96.0 && \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_V}/gh_${GH_V}_linux_amd64.tar.gz" | tar -xz -C /tmp && \
    cp "/tmp/gh_${GH_V}_linux_amd64/bin/gh" "$HOME/.local/bin/gh" && \
    curl -fsSL "https://github.com/openai/codex/releases/download/rust-v0.142.5/codex-x86_64-unknown-linux-musl.tar.gz" | tar -xz -C /tmp && \
    find /tmp -maxdepth 1 -name 'codex*' -type f -exec cp {} "$HOME/.local/bin/codex" \; && \
    chmod +x "$HOME"/.local/bin/* && \
    "$HOME/.local/bin/claude" --version && "$HOME/.local/bin/codex" --version && "$HOME/.local/bin/gh" --version
# bun + uv — linked into ~/.local/bin so non-interactive shells find them too
RUN curl -fsSL https://bun.sh/install | bash && \
    ln -sf "$HOME/.bun/bin/bun" "$HOME/.local/bin/bun" && \
    ln -sf "$HOME/.bun/bin/bun" "$HOME/.local/bin/bunx" && \
    curl -LsSf https://astral.sh/uv/install.sh | sh && \
    go version && "$HOME/.local/bin/bun" --version && "$HOME/.local/bin/uv" --version
# node + the oh-my-* multi-agent harnesses, prebaked for instant session starts.
# node/npm/npx get linked into ~/.local/bin — nvm only loads in interactive
# shells, and agents shell out non-interactively (the classic nvm PATH trap)
RUN export NVM_DIR="$HOME/.nvm" && \
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash && \
    . "$NVM_DIR/nvm.sh" && nvm install 22 && \
    NODE_DIR="$(dirname "$(nvm which 22)")" && \
    ln -sf "$NODE_DIR/node" "$HOME/.local/bin/node" && \
    ln -sf "$NODE_DIR/npm"  "$HOME/.local/bin/npm" && \
    ln -sf "$NODE_DIR/npx"  "$HOME/.local/bin/npx" && \
    npm config set prefix "$HOME/.local" && \
    npm install -g oh-my-claude-sisyphus@latest oh-my-codex@latest && \
    "$HOME/.local/bin/omc" --version && "$HOME/.local/bin/omx" --version && \
    "$HOME/.local/bin/node" --version && "$HOME/.local/bin/npm" --version && \
    sed -i '/NVM_DIR/d' "$HOME/.bashrc"
# ^ drop nvm's login-shell loader: node is symlinked above, and nvm + the npm
#   prefix we set would print a warning on every interactive login otherwise
CMD ["sleep", "infinity"]
DV_DOCKERFILE
}

cmd_snapshot() {
  local sub="${1:-}"
  [ $# -gt 0 ] && shift
  case "$sub" in
    build)
      local size=""
      while [ $# -gt 0 ]; do
        case "$1" in
          -s|--size) need_val "$1" "${2:-}"; size="$2"; shift 2 ;;
          *) die "unknown flag for snapshot build: $1 (usage: devflow snapshot build [--size small|medium|large])" ;;
        esac
      done
      [ -n "$size" ] || size="$(default_size)"
      local cpu mem_gb disk_gb
      case "$size" in   # a snapshot bakes its resources ('snapshot create' memory is GB)
        small)  cpu=1 mem_gb=1 disk_gb=3 ;;
        medium) cpu=2 mem_gb=4 disk_gb=8 ;;
        large)  cpu=4 mem_gb=8 disk_gb=10 ;;
        *) die "invalid size '$size' (small|medium|large)" ;;
      esac
      need_cmd daytona "brew install daytonaio/cli/daytona"
      dt_auth_check || die "not logged in to Daytona — run: devflow setup"
      local snap_name="devflow-base-$DEVFLOW_VERSION-$size" tmp
      tmp="$(mktemp -d "${TMPDIR:-/tmp}/devflow-snap.XXXXXX")"
      emit_dockerfile >"$tmp/Dockerfile"
      say "building snapshot ${C_BOLD}$snap_name${C_RESET} ($(size_desc "$size")) on Daytona (one-time, a few minutes)…"
      if dt snapshot create "$snap_name" --dockerfile "$tmp/Dockerfile" \
           "--cpu=$cpu" "--memory=$mem_gb" "--disk=$disk_gb"; then
        config_set "$CONFIG_FILE" DEVFLOW_SNAPSHOT "$snap_name"
        rm -rf "$tmp"
        ok "snapshot built + set as default — new sandboxes now start in seconds"
        step "want another size too? ${C_BOLD}devflow snapshot build --size small|medium|large${C_RESET} (they coexist; DEVFLOW_SNAPSHOT picks)"
      else
        rm -rf "$tmp"
        die "snapshot build failed (see output above)"
      fi
      ;;
    dockerfile) emit_dockerfile ;;
    *) die "usage: devflow snapshot [build [--size small|medium|large] | dockerfile]" ;;
  esac
}

# ----------------------------------------------------------------------------
# Help
# ----------------------------------------------------------------------------
usage_up() {
cat <<EOF
${C_BOLD}devflow up${C_RESET} [REPO] [flags] — create (or reattach to) a cloud agent session

  REPO                owner/name or GitHub URL; omit to use the current repo,
                      or get a picker of your GitHub repos

  -a, --agent A       claude | codex | both | none     (default: $DEVFLOW_AGENT)
  -H, --harness H     multi-agent harness: auto | omc | omx | both | core (none≡core)
                      (default: $DEVFLOW_HARNESS — auto matches the agent:
                      oh-my-claudecode for claude, oh-my-codex for codex;
                      core = devflow's built-in dv-engineer/designer/security)
  -m, --task "…"      hand the agent a task right away; add --no-attach to
                      fire-and-forget; poll with 'devflow status' or 'peek'
      --script FILE   run a local script inside the sandbox (tmux window
                      'script'; log ~/.devflow/script.log). A bare positional
                      arg that names an existing file works too:
                      devflow up repro.sh
      --with-daytona  give the sandbox your Daytona CLI + API key + devflow,
                      so scripts/agents in it can spin up SIBLING sandboxes
                      (they bill your account — clean up with devflow rm)
      --aws-profile P resolve and forward profile P as a temporary AWS session;
                      also installs aws/eksctl/kubectl/helm/yq/envsubst,
                      helm-unittest, shellcheck, Docker, and supporting tools
      --secret-env V  forward the named local environment variable through the
                      encrypted 0600 auth bundle (repeatable; values never log)
      --env N=V       forward a non-secret runtime setting through the same
                      0600 bundle (repeatable; useful for domains/API URLs)
      --allow-static-aws
                      explicitly permit non-expiring AWS credentials (unsafe;
                      an assumed-role profile with an STS session is preferred)
  -b, --branch B      checkout (or create) branch B
  -n, --name N        sandbox name (default: dv-<repo>)
      --blank         no repo — empty scratch sandbox
      --pick          force the repo picker
      --fresh         delete + recreate if the sandbox already exists
      --no-attach     don't SSH in after starting
      --detach        alias for --no-attach
  -s, --size S        small | medium | large   (default: $(default_size))
                      small=1cpu/1gb/3gb · medium=2cpu/4gb/8gb · large=4cpu/8gb/10gb
                      (--cpu/--memory/--disk are deprecated: they map to the
                      smallest size that fits)
      --auto-stop MIN 0 = keep running until 'devflow stop' (default ${DEVFLOW_AUTO_STOP})
      --snapshot S    custom snapshot — brings its own size (see: devflow snapshot build)
EOF
}

usage() {
cat <<EOF
${C_CYAN}${C_BOLD}devflow${C_RESET} $DEVFLOW_VERSION — agentic cloud dev sessions on Daytona, powered by your subscriptions

${C_BOLD}start here${C_RESET}
  devflow setup                 one-time: accounts + auth (no API keys needed)
  devflow up [REPO]             spin up Claude Code / Codex on a repo & attach
  devflow up -m "fix bug X" --detach       fire-and-forget, close your laptop
  devflow up repro.sh --with-daytona       run a script in a sandbox; it can
                                           even spin up sibling sandboxes

  every sandbox gets a multi-agent harness: oh-my-claudecode (/autopilot,
  /team, 29 agents) with claude, oh-my-codex with codex, plus devflow's own
  dv-engineer / dv-designer / dv-security subagents. tune: --harness

${C_BOLD}daily driving${C_RESET}
  devflow attach [NAME]   (a)   reattach from anywhere — tmux keeps it alive
  devflow status [NAME]         poll detached task state (queued/running/completed/failed)
  devflow peek [NAME] [-w W]    glance at the agent (or window W, e.g. script)
  devflow ls                    list sandboxes
  devflow stop [NAME|--all]     stop (disk kept) — attach restarts + resumes
  devflow rm [NAME|--all]       delete sandbox
  devflow sync [NAME] [flags]   re-sync auth; accepts --aws-profile P,
                                repeatable --secret-env V / --env N=V,
                                --allow-static-aws

${C_BOLD}more${C_RESET}
  devflow ssh [NAME]            SSH in (lands in tmux; detach: Ctrl-b d)
  devflow ssh-command [NAME]    print a plain ssh command for any machine
  devflow ssh-config [NAME]     managed ~/.ssh/config Host block — plain
                                `ssh NAME`, VS Code/Cursor Remote-SSH, scp
  devflow mobile [NAME]         hand the session to your phone — camera QR +
                                ssh line; --send pushes it to the phone
                                (ntfy notification / 1Password / Apple Notes)
  devflow exec NAME -- CMD      run a one-off command in a sandbox
  devflow token                 store a 1-year Claude subscription token
  devflow snapshot build        prebake a custom snapshot (agents + go/bun/uv/
                                build tools) for instant starts; --size S per size
  devflow doctor                check local setup
  devflow config [set K V]      defaults (agent, resources, auto-stop…)
  devflow dashboard             open app.daytona.io

Docs: https://github.com/dalinkstone/devflow
EOF
}

# ----------------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  [ $# -gt 0 ] && shift
  load_config

  case "$cmd" in
    up|start|new)         cmd_up "$@" ;;
    attach|a|open)        cmd_attach "$@" ;;
    ssh)                  cmd_ssh "$@" ;;
    ssh-command|ssh-cmd)  cmd_ssh_command "$@" ;;
    ssh-config|sshconfig) cmd_ssh_config "$@" ;;
    mobile|phone|qr)      cmd_mobile "$@" ;;
    exec)                 cmd_exec "$@" ;;
    peek|watch)           cmd_peek "$@" ;;
    status|state)         cmd_status "$@" ;;
    ls|list|ps)           cmd_ls "$@" ;;
    stop)                 cmd_stop "$@" ;;
    rm|delete|down)       cmd_rm "$@" ;;
    sync)                 cmd_sync "$@" ;;
    token)                cmd_token "$@" ;;
    setup|init)           cmd_setup "$@" ;;
    doctor|check)         cmd_doctor "$@" ;;
    config)               cmd_config "$@" ;;
    snapshot)             cmd_snapshot "$@" ;;
    dashboard)            cmd_dashboard "$@" ;;
    __provision-script)   emit_provision_script ;;
    __dockerfile)         emit_dockerfile ;;
    version|--version|-v) echo "devflow $DEVFLOW_VERSION" ;;
    help|--help|-h)       usage ;;
    *)                    err "unknown command: $cmd"; echo; usage; exit 1 ;;
  esac
}

main "$@"
