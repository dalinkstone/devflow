#!/usr/bin/env bash
# ============================================================================
#  devflow — your agentic cloud dev environment
#
#  Spin up Claude Code or Codex in a Daytona sandbox using your existing
#  subscriptions (Claude Max / ChatGPT Pro) — no API keys. Sessions live in
#  tmux inside the sandbox, so you can close your laptop and reattach from
#  anywhere with `devflow attach`.
#
#  https://github.com/dalinkstone/devflow
# ============================================================================
set -u
set -o pipefail

DEVFLOW_VERSION="0.2.0"

# ----------------------------------------------------------------------------
# Config (precedence: environment > config file > built-in default)
# ----------------------------------------------------------------------------
CONFIG_DIR="${DEVFLOW_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/devflow}"
CONFIG_FILE="$CONFIG_DIR/config"
SECRETS_FILE="$CONFIG_DIR/secrets"

GH_PIN_VERSION="2.96.0"          # fallback for in-sandbox gh install
CODEX_PIN_TAG="rust-v0.142.5"    # fallback for in-sandbox codex install

_CONFIG_KEYS="DEVFLOW_AGENT DEVFLOW_CPU DEVFLOW_MEMORY DEVFLOW_DISK DEVFLOW_AUTO_STOP DEVFLOW_TARGET DEVFLOW_SNAPSHOT DEVFLOW_CLAUDE_AUTH DEVFLOW_EXEC_STYLE DEVFLOW_WORKROOT DEVFLOW_HARNESS"

load_config() {
  # 1) preserve values that came from the caller's environment
  local k v _envsaved=""
  for k in $_CONFIG_KEYS DEVFLOW_CLAUDE_TOKEN; do
    eval "v=\${$k-__devflow_unset__}"
    if [ "$v" != "__devflow_unset__" ]; then
      _envsaved="$_envsaved $k=$(printf '%q' "$v")"
    fi
  done
  # 2) config + secrets files (user-owned, chmod 600)
  # shellcheck disable=SC1090
  [ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"
  # shellcheck disable=SC1090
  [ -f "$SECRETS_FILE" ] && . "$SECRETS_FILE"
  # 3) environment wins
  [ -n "$_envsaved" ] && eval "$_envsaved"
  # 4) defaults fill the gaps
  : "${DEVFLOW_AGENT:=claude}"          # claude | codex | both | none
  : "${DEVFLOW_CPU:=2}"                 # cores (Daytona no-quota max: 4)
  : "${DEVFLOW_MEMORY:=4096}"           # MB    (Daytona no-quota max: 8192)
  : "${DEVFLOW_DISK:=10}"               # GB    (Daytona no-quota max: 10)
  : "${DEVFLOW_AUTO_STOP:=0}"           # minutes; 0 = never (close your laptop safely)
  : "${DEVFLOW_TARGET:=}"               # us | eu | "" = org default
  : "${DEVFLOW_SNAPSHOT:=}"             # custom snapshot; "" = Daytona default image
  : "${DEVFLOW_CLAUDE_AUTH:=auto}"      # auto | token | creds
  : "${DEVFLOW_EXEC_STYLE:=}"           # join | argv | "" = auto-probe
  : "${DEVFLOW_WORKROOT:=work}"         # dir under $HOME in the sandbox
  : "${DEVFLOW_HARNESS:=auto}"          # auto | omc | omx | both | core
  : "${DEVFLOW_CLAUDE_TOKEN:=}"
  return 0
}

resolve_harness() { # AGENT REQUESTED -> effective harness
  local agent="$1" req="$2"
  case "$req" in
    auto)
      case "$agent" in
        claude) printf 'omc' ;;
        codex)  printf 'omx' ;;
        both)   printf 'both' ;;
        *)      printf 'core' ;;
      esac ;;
    none) printf 'core' ;;
    *)    printf '%s' "$req" ;;
  esac
}

config_set() { # config_set FILE KEY VALUE
  local file="$1" key="$2" val="$3" tmp
  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR" 2>/dev/null || true
  touch "$file"
  chmod 600 "$file"
  tmp="$(mktemp "${TMPDIR:-/tmp}/devflow.XXXXXX")"
  grep -v "^${key}=" "$file" >"$tmp" 2>/dev/null || true
  printf '%s=%q\n' "$key" "$val" >>"$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file"
}

# ----------------------------------------------------------------------------
# UI helpers
# ----------------------------------------------------------------------------
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_BLUE=$'\033[34m'; C_CYAN=$'\033[36m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_DIM=""; C_BLUE=""; C_CYAN=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_RESET=""
fi

say()  { printf '%s\n' "${C_CYAN}${C_BOLD}devflow${C_RESET} $*"; }
step() { printf '%s\n' "${C_BLUE}▸${C_RESET} $*"; }
ok()   { printf '%s\n' "${C_GREEN}✓${C_RESET} $*"; }
warn() { printf '%s\n' "${C_YELLOW}!${C_RESET} $*" >&2; }
err()  { printf '%s\n' "${C_RED}✗${C_RESET} $*" >&2; }
die()  { err "$@"; exit 1; }

confirm() { # confirm "question" -> 0 yes / 1 no
  local ans
  printf '%s' "${C_YELLOW}?${C_RESET} $1 [y/N] "
  read -r ans || true
  case "$ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

# ----------------------------------------------------------------------------
# Small utilities
# ----------------------------------------------------------------------------
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1 — run 'devflow setup' (or: $2)"; }
have_cmd() { command -v "$1" >/dev/null 2>&1; }
need_val() { [ -n "${2:-}" ] || die "flag $1 requires a value"; }

b64_encode() { # portable, single-line output
  if base64 --help 2>&1 | grep -q -- '-w'; then base64 -w0; else base64 | tr -d '\n'; fi
}

sanitize_name() {
  local out
  out="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-z0-9-]/-/g' -e 's/--*/-/g' -e 's/^-//' -e 's/-$//' | cut -c1-40)"
  [ -n "$out" ] && printf '%s' "$out" || printf 'sandbox'
}

repo_from_arg() { # normalize repo arg -> owner/name (empty if not repo-ish)
  local a="$1"
  a="${a%.git}"
  case "$a" in
    https://github.com/*) a="${a#https://github.com/}" ;;
    http://github.com/*)  a="${a#http://github.com/}" ;;
    git@github.com:*)     a="${a#git@github.com:}" ;;
  esac
  case "$a" in
    */*/*) printf '' ;;
    ?*/?*) printf '%s' "$a" ;;
    *)     printf '' ;;
  esac
}

current_repo() { # owner/name of cwd's github origin, or empty
  local url
  url="$(git config --get remote.origin.url 2>/dev/null || true)"
  [ -n "$url" ] || { printf ''; return 0; }
  repo_from_arg "$url"
}

# ----------------------------------------------------------------------------
# Daytona wrappers
# ----------------------------------------------------------------------------
dt() { command daytona "$@"; }

dt_auth_check() { dt organization list >/dev/null 2>&1; }

dt_info_json() { dt info "$1" -f json 2>/dev/null; }

sandbox_state() { # NAME -> state string or "missing"
  local j
  j="$(dt_info_json "$1")" || { printf 'missing'; return 0; }
  printf '%s' "$j" | jq -r '.state // .status // "unknown"'
}

wait_for_state() { # NAME WANT TIMEOUT_S
  local name="$1" want="$2" timeout="${3:-180}" waited=0 st=""
  while [ "$waited" -lt "$timeout" ]; do
    st="$(sandbox_state "$name")"
    case "$st" in
      "$want") return 0 ;;
      error|build_failed|destroyed) die "sandbox '$name' entered state: $st" ;;
    esac
    sleep 2
    waited=$((waited + 2))
  done
  die "timed out waiting for sandbox '$name' to be $want (last state: ${st:-unknown})"
}

# --- remote exec ------------------------------------------------------------
# Different daytona CLI builds pass `exec … -- args` through differently: some
# join args into one shell string, some preserve argv. Probe once, cache.
probe_exec_style() { # NAME (sandbox must be started)
  local out
  out="$(dt exec "$1" --timeout 30 -- printf %s 'x y' 2>/dev/null || true)"
  case "$out" in
    "x y") DEVFLOW_EXEC_STYLE="argv" ;;
    "xy")  DEVFLOW_EXEC_STYLE="join" ;;
    *)
      out="$(dt exec "$1" --timeout 30 -- echo 'dv probe' 2>/dev/null || true)"
      case "$out" in
        *"dv probe"*) DEVFLOW_EXEC_STYLE="argv" ;;
        *)            DEVFLOW_EXEC_STYLE="join" ;;
      esac
      ;;
  esac
  config_set "$CONFIG_FILE" DEVFLOW_EXEC_STYLE "$DEVFLOW_EXEC_STYLE"
}

dt_run() { # NAME SCRIPT [TIMEOUT] — run a (newline-free) bash command string
  local name="$1" script="$2" timeout="${3:-0}"
  [ -n "$DEVFLOW_EXEC_STYLE" ] || probe_exec_style "$name"
  if [ "$DEVFLOW_EXEC_STYLE" = "argv" ]; then
    dt exec "$name" --timeout "$timeout" -- bash -lc "$script"
  else
    local quoted
    quoted="$(printf '%q' "$script")"
    dt exec "$name" --timeout "$timeout" -- "bash -lc $quoted"
  fi
}

dt_push_file() { # NAME REMOTE_PATH  (content on stdin) — chunked base64 upload
  local name="$1" remote="$2" b64 len off=0 chunk=6000 part first=1
  b64="$(b64_encode)"
  len=${#b64}
  while [ "$off" -lt "$len" ]; do
    part="${b64:$off:$chunk}"
    if [ "$first" = 1 ]; then
      dt_run "$name" "umask 077 && printf %s '$part' > '$remote.b64'" 120 >/dev/null
      first=0
    else
      dt_run "$name" "printf %s '$part' >> '$remote.b64'" 120 >/dev/null
    fi
    off=$((off + chunk))
  done
  dt_run "$name" "umask 077 && base64 -d '$remote.b64' > '$remote' && rm -f '$remote.b64'" 60 >/dev/null
}

# ----------------------------------------------------------------------------
# Local auth harvesting (memoized; secrets never printed or logged)
# ----------------------------------------------------------------------------
_HARVESTED=0
harvest_all() {
  [ "$_HARVESTED" = 1 ] && return 0
  _HARVESTED=1
  # --- claude: token (preferred) or credentials copy ---
  CLAUDE_MODE="none"; CLAUDE_TOKEN=""; CLAUDE_CREDS_B64=""
  if [ "$DEVFLOW_CLAUDE_AUTH" != "creds" ] && [ -n "$DEVFLOW_CLAUDE_TOKEN" ]; then
    CLAUDE_MODE="token"; CLAUDE_TOKEN="$DEVFLOW_CLAUDE_TOKEN"
  elif [ "$DEVFLOW_CLAUDE_AUTH" != "token" ]; then
    local creds=""
    if [ "$(uname -s)" = "Darwin" ]; then
      creds="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)"
    fi
    if [ -z "$creds" ] && [ -f "$HOME/.claude/.credentials.json" ]; then
      creds="$(cat "$HOME/.claude/.credentials.json")"
    fi
    if [ -n "$creds" ]; then
      CLAUDE_MODE="creds"
      CLAUDE_CREDS_B64="$(printf '%s' "$creds" | b64_encode)"
    fi
  fi
  # --- codex: ChatGPT sign-in file ---
  CODEX_AUTH_B64=""
  local cf="${CODEX_HOME:-$HOME/.codex}/auth.json"
  [ -f "$cf" ] && CODEX_AUTH_B64="$(b64_encode <"$cf")"
  # --- github ---
  GH_TOKEN_VAL=""
  have_cmd gh && GH_TOKEN_VAL="$(gh auth token 2>/dev/null || true)"
  # --- git identity ---
  GIT_NAME="$(git config --global user.name 2>/dev/null || git config user.name 2>/dev/null || true)"
  GIT_EMAIL="$(git config --global user.email 2>/dev/null || git config user.email 2>/dev/null || true)"
  return 0
}

build_secrets_bundle() { # stdout: env file consumed by the sandbox provisioner
  harvest_all
  printf 'DV_CLAUDE_MODE=%s\n' "$CLAUDE_MODE"
  printf 'DV_CLAUDE_TOKEN=%s\n' "$CLAUDE_TOKEN"
  printf 'DV_CLAUDE_CREDS_B64=%s\n' "$CLAUDE_CREDS_B64"
  printf 'DV_CODEX_AUTH_B64=%s\n' "$CODEX_AUTH_B64"
  printf 'DV_GH_TOKEN=%s\n' "$GH_TOKEN_VAL"
  printf 'DV_GIT_NAME=%q\n' "${GIT_NAME:-}"
  printf 'DV_GIT_EMAIL=%q\n' "${GIT_EMAIL:-}"
  printf 'DV_GH_PIN=%s\n' "$GH_PIN_VERSION"
  printf 'DV_CODEX_PIN=%s\n' "$CODEX_PIN_TAG"
}

auth_summary() { # print what will be synced (no secret values)
  harvest_all
  case "$CLAUDE_MODE" in
    token) ok "Claude Code: long-lived subscription token" ;;
    creds) ok "Claude Code: local subscription credentials will be copied"
           step "${C_DIM}tip: 'devflow token' creates a dedicated 1-year token (avoids logout races)${C_RESET}" ;;
    none)  warn "Claude Code: no subscription auth found — run 'devflow token' (or log in to claude locally)" ;;
  esac
  if [ -n "$CODEX_AUTH_B64" ]; then ok "Codex: ChatGPT sign-in will be copied"
  else warn "Codex: no ~/.codex/auth.json — run 'codex' locally and sign in with ChatGPT first"; fi
  if [ -n "$GH_TOKEN_VAL" ]; then ok "GitHub: gh token will be forwarded"
  else warn "GitHub: gh not authenticated — private clones/pushes won't work (gh auth login)"; fi
}

# ----------------------------------------------------------------------------
# Repo selection
# ----------------------------------------------------------------------------
pick_repo() { # sets REPO_PICKED (owner/name, may be "")
  REPO_PICKED=""
  need_cmd gh "brew install gh"
  step "fetching your repositories…" >&2
  local list
  list="$(gh repo list --limit 200 --json nameWithOwner,description \
          --template '{{range .}}{{.nameWithOwner}}{{"\t"}}{{.description}}{{"\n"}}{{end}}' 2>/dev/null || true)"
  [ -n "$list" ] || die "could not list repos via gh — is 'gh auth login' done?"
  if have_cmd fzf; then
    local sel
    sel="$(printf '%s\n' "$list" | fzf --height=60% --reverse --prompt='repo> ' \
          --header='pick a repo (esc = blank sandbox)' --delimiter='\t' --with-nth=1,2 || true)"
    REPO_PICKED="$(printf '%s' "$sel" | cut -f1)"
  else
    say "pick a repo (number), or 0 for a blank sandbox:"
    printf '%s\n' "$list" | head -30 | nl -w3 -s') ' | cut -c1-100
    printf 'repo #: '
    local n
    read -r n || true
    if [ -n "$n" ] && [ "$n" != "0" ]; then
      REPO_PICKED="$(printf '%s\n' "$list" | sed -n "${n}p" | cut -f1)"
    fi
  fi
  return 0
}

# ----------------------------------------------------------------------------
# Embedded payload: sandbox provisioner (phased; runs INSIDE the sandbox)
# ----------------------------------------------------------------------------
emit_provision_script() {
cat <<'DVPROV_EOF'
#!/usr/bin/env bash
# devflow sandbox provisioner — runs INSIDE the Daytona sandbox. Idempotent.
# Phases (DV_PHASE): tools | auth | workspace | all
set -u
set -o pipefail

DV_DIR="$HOME/.devflow"
DV_BIN="$DV_DIR/bin"
DV_STAGE="$DV_DIR/stage"
DV_PROVISION_VERSION=1
export PATH="$HOME/.local/bin:$DV_BIN:$PATH"

: "${DV_PHASE:=all}"
: "${DV_AGENT:=claude}"
: "${DV_REPO:=}"
: "${DV_BRANCH:=}"
: "${DV_NAME:=sandbox}"
: "${DV_TASK_B64:=}"
: "${DV_WORKROOT:=work}"
: "${DV_HARNESS:=core}"   # core | omc | omx | both

log()  { printf '[devflow] %s\n' "$*"; }
fail() { printf '[devflow] ERROR: %s\n' "$*" >&2; exit 1; }

mkdir -p "$DV_DIR" "$DV_BIN" "$DV_STAGE" "$HOME/.local/bin"
chmod 700 "$DV_DIR" "$DV_STAGE"
cd "$HOME" || true   # tools that drop state in cwd (omx setup) must land in $HOME

SUDO=""
if [ "$(id -u)" != "0" ] && command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
  SUDO="sudo"
fi

apt_install() { # best-effort package install (root or passwordless sudo)
  command -v apt-get >/dev/null 2>&1 || return 1
  if [ "$(id -u)" = "0" ]; then
    apt-get update -qq >/dev/null 2>&1 || true
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq "$@" >/dev/null 2>&1
  elif [ -n "$SUDO" ]; then
    $SUDO apt-get update -qq >/dev/null 2>&1 || true
    DEBIAN_FRONTEND=noninteractive $SUDO apt-get install -y -qq "$@" >/dev/null 2>&1
  else
    return 1
  fi
}

ensure_node_path() { # surface nvm-installed node (default Daytona image uses nvm)
  command -v node >/dev/null 2>&1 && return 0
  if [ -s "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
  fi
  command -v node >/dev/null 2>&1 && return 0
  local d
  for d in "$HOME"/.nvm/versions/node/*/bin /usr/local/share/nvm/versions/node/*/bin; do
    if [ -x "$d/node" ]; then export PATH="$d:$PATH"; return 0; fi
  done
  return 0
}

arch_triple() { case "$(uname -m)" in aarch64|arm64) printf 'aarch64' ;; *) printf 'x86_64' ;; esac; }
arch_gh()     { case "$(uname -m)" in aarch64|arm64) printf 'arm64'   ;; *) printf 'amd64'  ;; esac; }

gh_curl() { # authenticated GitHub download when possible (rate limits)
  if [ -n "${DV_GH_TOKEN:-}" ]; then
    curl -fsSL -H "Authorization: Bearer $DV_GH_TOKEN" "$@"
  else
    curl -fsSL "$@"
  fi
}

load_secrets() {
  DV_CLAUDE_MODE=none DV_CLAUDE_TOKEN="" DV_CLAUDE_CREDS_B64="" DV_CODEX_AUTH_B64=""
  DV_GH_TOKEN="" DV_GIT_NAME="" DV_GIT_EMAIL="" DV_GH_PIN="2.96.0" DV_CODEX_PIN="rust-v0.142.5"
  if [ -f "$DV_STAGE/secrets.env" ]; then
    # shellcheck disable=SC1090
    . "$DV_STAGE/secrets.env"
  fi
}

ensure_npm() { # make npm usable (nvm-installed or fresh nvm install); rc 1 if impossible
  ensure_node_path
  if ! command -v npm >/dev/null 2>&1; then
    log "installing node 22 via nvm (needed for the multi-agent harness)…"
    export NVM_DIR="$HOME/.nvm"
    if [ ! -s "$NVM_DIR/nvm.sh" ]; then
      curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash > "$DV_DIR/nvm-install.log" 2>&1 || true
    fi
    # shellcheck disable=SC1091
    [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" >/dev/null 2>&1
    command -v nvm >/dev/null 2>&1 && nvm install 22 >> "$DV_DIR/nvm-install.log" 2>&1
    ensure_node_path
  fi
  command -v npm >/dev/null 2>&1 || return 1
  # non-root global installs need a user-writable prefix (skip under nvm,
  # which manages its own prefix and rejects overrides)
  local proot
  proot="$(npm root -g 2>/dev/null || true)"
  if [ -n "$proot" ] && [ ! -w "$(dirname "$proot")" ] && [ "$(id -u)" != "0" ]; then
    npm config set prefix "$HOME/.local" >/dev/null 2>&1 || true
  fi
  # nvm's bin dir is invisible to non-interactive login shells (ubuntu's
  # .bashrc returns early), so expose the runtime on a stable PATH
  link_global_bin node
  link_global_bin npm
  link_global_bin npx
  return 0
}

link_global_bin() { # expose an npm-global binary at ~/.local/bin
  local src
  src="$(npm prefix -g 2>/dev/null)/bin/$1"
  [ -x "$src" ] && [ "$src" != "$HOME/.local/bin/$1" ] && ln -sf "$src" "$HOME/.local/bin/$1"
  return 0
}

# ============================ phase: tools ===================================
phase_tools() {
  log "phase 1/4 tools: checking base packages…"
  local missing=""
  for t in tmux git curl; do command -v "$t" >/dev/null 2>&1 || missing="$missing $t"; done
  if [ -n "$missing" ]; then
    log "installing:$missing"
    # shellcheck disable=SC2086
    apt_install $missing ca-certificates || log "warn: could not apt-install$missing"
  fi
  command -v git  >/dev/null 2>&1 || fail "git missing and not installable in this image"
  command -v curl >/dev/null 2>&1 || fail "curl missing and not installable in this image"
  command -v tmux >/dev/null 2>&1 || log "warn: no tmux — sessions won't survive disconnects"
  command -v jq   >/dev/null 2>&1 || apt_install jq || true
  command -v rg   >/dev/null 2>&1 || apt_install ripgrep || true

  # ---- gh CLI ----
  if ! command -v gh >/dev/null 2>&1; then
    log "installing gh v$DV_GH_PIN…"
    local a t
    a="$(arch_gh)"
    t="$(mktemp -d)"
    if gh_curl "https://github.com/cli/cli/releases/download/v${DV_GH_PIN}/gh_${DV_GH_PIN}_linux_${a}.tar.gz" -o "$t/gh.tgz" \
       && tar -xzf "$t/gh.tgz" -C "$t"; then
      cp "$t/gh_${DV_GH_PIN}_linux_${a}/bin/gh" "$HOME/.local/bin/gh" && chmod +x "$HOME/.local/bin/gh"
    else
      log "warn: gh install failed (private-repo clone won't work)"
    fi
    rm -rf "$t"
  fi

  # ---- Claude Code ----
  ensure_node_path
  if ! command -v claude >/dev/null 2>&1; then
    log "installing Claude Code (native)…"
    curl -fsSL https://claude.ai/install.sh | bash > "$DV_DIR/claude-install.log" 2>&1 || true
    export PATH="$HOME/.local/bin:$PATH"
    if ! command -v claude >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
      log "native install unavailable — falling back to npm…"
      npm install -g @anthropic-ai/claude-code >> "$DV_DIR/claude-install.log" 2>&1 || true
    fi
  fi

  # ---- Codex CLI ----
  if ! command -v codex >/dev/null 2>&1; then
    log "installing Codex CLI…"
    local triple tag t bin
    triple="$(arch_triple)-unknown-linux-musl"
    tag=""
    if [ -n "${DV_GH_TOKEN:-}" ]; then
      tag="$(gh_curl https://api.github.com/repos/openai/codex/releases/latest 2>/dev/null | grep -m1 '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/' || true)"
    fi
    [ -n "$tag" ] || tag="$DV_CODEX_PIN"
    t="$(mktemp -d)"
    if gh_curl "https://github.com/openai/codex/releases/download/${tag}/codex-${triple}.tar.gz" -o "$t/codex.tgz" \
       && tar -xzf "$t/codex.tgz" -C "$t"; then
      bin="$(find "$t" -maxdepth 2 -type f -name 'codex*' ! -name '*.tar.gz' | head -1)"
      [ -n "$bin" ] && cp "$bin" "$HOME/.local/bin/codex" && chmod +x "$HOME/.local/bin/codex"
    fi
    rm -rf "$t"
    if ! command -v codex >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
      log "binary install unavailable — falling back to npm…"
      npm install -g @openai/codex > "$DV_DIR/codex-install.log" 2>&1 || true
    fi
  fi

  # only hard-fail if the selected agent is unusable
  case "$DV_AGENT" in
    claude) command -v claude >/dev/null 2>&1 || fail "claude install failed (see ~/.devflow/claude-install.log)" ;;
    codex)  command -v codex  >/dev/null 2>&1 || fail "codex install failed" ;;
    both)   command -v claude >/dev/null 2>&1 || fail "claude install failed"
            command -v codex  >/dev/null 2>&1 || fail "codex install failed" ;;
  esac
  log "tools ready: $(command -v claude >/dev/null 2>&1 && printf 'claude ')$(command -v codex >/dev/null 2>&1 && printf 'codex ')$(command -v gh >/dev/null 2>&1 && printf 'gh ')$(command -v tmux >/dev/null 2>&1 && printf 'tmux')"
}

# ============================ phase: auth ====================================
phase_auth() {
  log "phase 2/4 auth: applying subscription credentials…"
  load_secrets
  umask 077
  mkdir -p "$HOME/.claude" "$HOME/.codex"

  : > "$DV_DIR/env"
  chmod 600 "$DV_DIR/env"
  case "$DV_CLAUDE_MODE" in
    token)
      printf 'export CLAUDE_CODE_OAUTH_TOKEN=%q\n' "$DV_CLAUDE_TOKEN" >> "$DV_DIR/env"
      log "claude auth: long-lived subscription token"
      ;;
    creds)
      printf '%s' "$DV_CLAUDE_CREDS_B64" | base64 -d > "$HOME/.claude/.credentials.json"
      chmod 600 "$HOME/.claude/.credentials.json"
      log "claude auth: subscription credentials copied"
      ;;
    *) log "claude auth: none provided (claude will ask to log in)" ;;
  esac

  if [ -n "$DV_CODEX_AUTH_B64" ]; then
    printf '%s' "$DV_CODEX_AUTH_B64" | base64 -d > "$HOME/.codex/auth.json"
    chmod 600 "$HOME/.codex/auth.json"
    log "codex auth: ChatGPT sign-in copied"
  else
    log "codex auth: none provided (use 'codex login --device-auth' in the sandbox)"
  fi

  if [ -n "$DV_GH_TOKEN" ] && command -v gh >/dev/null 2>&1; then
    printf '%s' "$DV_GH_TOKEN" | gh auth login --with-token 2>/dev/null || true
    gh auth setup-git 2>/dev/null || true
    log "github auth: $(gh api user -q .login 2>/dev/null || echo 'token applied')"
  fi

  [ -n "$DV_GIT_NAME" ]  && git config --global user.name  "$DV_GIT_NAME"
  [ -n "$DV_GIT_EMAIL" ] && git config --global user.email "$DV_GIT_EMAIL"
  git config --global init.defaultBranch main 2>/dev/null || true
  git config --global push.autoSetupRemote true 2>/dev/null || true

  rm -f "$DV_STAGE/secrets.env"
  umask 022
  log "auth done."
}

# ============================ phase: workspace ================================
phase_workspace() {
  log "phase 3/4 workspace: repo + dotfiles + session…"

  # ---- repo ----
  local WORKDIR
  if [ -n "$DV_REPO" ]; then
    WORKDIR="$HOME/$DV_WORKROOT/${DV_REPO##*/}"
    if [ ! -d "$WORKDIR/.git" ]; then
      log "cloning $DV_REPO…"
      mkdir -p "$HOME/$DV_WORKROOT"
      if [ -n "$DV_BRANCH" ]; then
        git clone --branch "$DV_BRANCH" "https://github.com/$DV_REPO.git" "$WORKDIR" 2>/dev/null \
          || { git clone "https://github.com/$DV_REPO.git" "$WORKDIR" \
               && git -C "$WORKDIR" checkout -b "$DV_BRANCH"; } \
          || fail "clone failed for $DV_REPO (private? check gh auth)"
      else
        git clone "https://github.com/$DV_REPO.git" "$WORKDIR" || fail "clone failed for $DV_REPO"
      fi
    elif [ -n "$DV_BRANCH" ]; then
      git -C "$WORKDIR" checkout "$DV_BRANCH" 2>/dev/null || git -C "$WORKDIR" checkout -b "$DV_BRANCH" || true
    fi
  else
    WORKDIR="$HOME/$DV_WORKROOT/scratch"
    mkdir -p "$WORKDIR"
  fi
  printf '%s' "$WORKDIR"        > "$DV_DIR/workdir"
  printf '%s' "$DV_AGENT"       > "$DV_DIR/agent"
  printf '%s' "$DV_NAME"        > "$DV_DIR/name"
  printf '%s' "${DV_REPO:-}"    > "$DV_DIR/repo"
  touch "$DV_DIR/autotmux"

  if [ -n "$DV_TASK_B64" ]; then
    umask 077
    printf '%s' "$DV_TASK_B64" | base64 -d > "$DV_DIR/task"
    umask 022
    log "task queued for the agent"
  fi

  # ---- claude harness ----
  if [ ! -f "$HOME/.claude.json" ]; then
    cat > "$HOME/.claude.json" <<DV_CLAUDEJSON
{
  "hasCompletedOnboarding": true,
  "bypassPermissionsModeAccepted": true,
  "theme": "dark",
  "projects": {
    "$WORKDIR": {
      "hasTrustDialogAccepted": true,
      "hasCompletedProjectOnboarding": true
    }
  }
}
DV_CLAUDEJSON
  elif command -v jq >/dev/null 2>&1; then
    local tmpj
    tmpj="$(mktemp)"
    jq --arg wd "$WORKDIR" '.hasCompletedOnboarding = true
      | .bypassPermissionsModeAccepted = true
      | .projects[$wd] = ((.projects[$wd] // {}) + {hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true})' \
      "$HOME/.claude.json" > "$tmpj" && mv "$tmpj" "$HOME/.claude.json"
  fi

  if [ ! -f "$HOME/.claude/settings.json" ]; then
    cat > "$HOME/.claude/settings.json" <<'DV_SETTINGS'
{
  "statusLine": {
    "type": "command",
    "command": "~/.devflow/bin/dv-statusline",
    "padding": 0
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  }
}
DV_SETTINGS
  fi

  if [ ! -f "$HOME/.claude/CLAUDE.md" ]; then
    cat > "$HOME/.claude/CLAUDE.md" <<'DV_CLAUDEMD'
# devflow sandbox

You are running inside a disposable **Daytona cloud sandbox** provisioned by
devflow. Facts about this environment:

- The sandbox is yours alone: installing packages, editing system config, and
  long-running processes are all fine. Prefer acting over asking.
- The working repository is checked out under `~/work/`. Do your work there.
- `gh` is authenticated as the sandbox owner. Push to feature branches and
  open PRs with `gh pr create`; never force-push `main` unless explicitly
  asked.
- Git identity is already configured. Commit early and often — committed and
  pushed work is the only durable work if the sandbox is deleted.
- The session runs inside tmux (session `dv`). The user may detach and
  reattach at any time; you may be resumed mid-task. If resumed, run
  `git status` and skim recent commits to re-establish context first.
- Permission prompts are bypassed. Be deliberate with destructive commands;
  prefer reversible operations.

## Multi-agent

Specialized subagents are installed — delegate instead of doing everything
in one context:

- `dv-engineer` (implementation), `dv-designer` (UX/API design),
  `dv-security` (security review) are always available. Use dv-security
  proactively after changes that touch auth, input handling, or secrets.
- If oh-my-claudecode is installed (check: `/help` lists `/autopilot`),
  prefer its workflows for big tasks: `/autopilot "…"` for autonomous
  builds, `/team N:executor "…"` for parallel work, `/ultrawork` for
  max-effort passes; its roster includes architect, designer,
  security-reviewer, test-engineer, and more.
DV_CLAUDEMD
  fi

  # ---- codex harness ----
  if [ ! -f "$HOME/.codex/config.toml" ]; then
    cat > "$HOME/.codex/config.toml" <<DV_CODEXCFG
# devflow harness — the Daytona sandbox is the isolation boundary, so codex
# itself runs with full autonomy inside it.
approval_policy = "never"
sandbox_mode = "danger-full-access"
forced_login_method = "chatgpt"
cli_auth_credentials_store = "file"

[projects."$WORKDIR"]
trust_level = "trusted"
DV_CODEXCFG
  fi

  if [ ! -f "$HOME/.codex/AGENTS.md" ]; then
    cat > "$HOME/.codex/AGENTS.md" <<'DV_AGENTSMD'
# devflow sandbox

You are running inside a disposable Daytona cloud sandbox provisioned by
devflow. The working repository is under `~/work/`. `gh` is authenticated —
push to feature branches and open PRs with `gh pr create`. Git identity is
configured; commit early and often since only pushed work survives sandbox
deletion. You run with full autonomy (no approval prompts) — be deliberate
with destructive commands. You may be detached from and resumed at any time;
on resume, check `git status` first.

If oh-my-codex is installed (the `omx` command exists), its workflows and
agent teams are available — prefer `$ultragoal`-style structured workflows
for large tasks, and consult its skills before hand-rolling orchestration.
DV_AGENTSMD
  fi

  # ---- tmux ----
  if [ ! -f "$HOME/.tmux.conf" ]; then
    cat > "$HOME/.tmux.conf" <<'DV_TMUXCONF'
# devflow tmux defaults
set -g mouse on
set -g history-limit 100000
set -g default-terminal "screen-256color"
set -g status-style "bg=colour24,fg=colour255"
set -g status-left "#[bold] devflow:#S "
set -g status-left-length 30
set -g status-right "#[fg=colour255]%H:%M "
set -g allow-rename off
set -g automatic-rename off
setw -g aggressive-resize on
DV_TMUXCONF
  fi

  # ---- shell integration ----
  cat > "$DV_DIR/shellrc" <<'DV_SHELLRC'
# devflow shell integration (sourced from ~/.bashrc and ~/.profile)
[ -n "${DEVFLOW_SHELLRC_RAN:-}" ] && return 0
DEVFLOW_SHELLRC_RAN=1; export DEVFLOW_SHELLRC_RAN

export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"
[ -f "$HOME/.devflow/env" ] && . "$HOME/.devflow/env"
export DEVFLOW_SANDBOX=1
DEVFLOW_NAME="$(cat "$HOME/.devflow/name" 2>/dev/null || echo sandbox)"
export DEVFLOW_NAME

alias dv-work='cd "$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"'
alias yolo='claude --dangerously-skip-permissions'

# Auto-attach the devflow tmux session on interactive SSH logins, so
# `devflow attach` / `daytona ssh` drop straight into the agent.
if [ -n "${SSH_CONNECTION:-}" ] && [ -z "${TMUX:-}" ] && [ -t 0 ] \
   && [ -f "$HOME/.devflow/autotmux" ] && command -v tmux >/dev/null 2>&1; then
  case "$-" in
    *i*)
      "$HOME/.devflow/bin/dv-ensure" >/dev/null 2>&1
      tmux new-session -A -s dv
      printf '\n[devflow] detached — "exit" to close, "tmux attach -t dv" to rejoin.\n'
      ;;
  esac
fi
DV_SHELLRC

  local rcfile
  for rcfile in "$HOME/.bashrc" "$HOME/.profile"; do
    if ! grep -q 'devflow/shellrc' "$rcfile" 2>/dev/null; then
      {
        printf '\n# --- devflow ---\n'
        printf '[ -f "$HOME/.devflow/shellrc" ] && . "$HOME/.devflow/shellrc"\n'
      } >> "$rcfile"
    fi
  done

  # ---- in-sandbox helper scripts ----
  cat > "$DV_BIN/dv-agent" <<'DV_DVAGENT'
#!/usr/bin/env bash
# dv-agent [claude|codex] — launch the coding agent in the work directory,
# resuming the previous conversation when one exists.
set -u
AGENT="${1:-$(cat "$HOME/.devflow/agent" 2>/dev/null || echo claude)}"
WORKDIR="$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"
cd "$WORKDIR" 2>/dev/null || cd "$HOME"
[ -f "$HOME/.devflow/env" ] && . "$HOME/.devflow/env"
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"

TASK=""
if [ -f "$HOME/.devflow/task" ]; then
  TASK="$(cat "$HOME/.devflow/task")"
  rm -f "$HOME/.devflow/task"
fi

CLAUDE_FLAGS="--dangerously-skip-permissions"
if [ "$(id -u)" = "0" ]; then
  # claude refuses bypass mode as root
  CLAUDE_FLAGS="--permission-mode acceptEdits"
fi

has_claude_history() {
  local munged
  munged="$(printf '%s' "$WORKDIR" | sed 's|[/._]|-|g')"
  ls "$HOME/.claude/projects/$munged"/*.jsonl >/dev/null 2>&1
}

case "$AGENT" in
  codex)
    # prefer the oh-my-codex launcher when the harness installed it
    if [ -n "$TASK" ]; then exec codex "$TASK"; fi
    if codex resume --last 2>/dev/null; then exit 0; fi
    if command -v omx >/dev/null 2>&1; then exec omx; fi
    exec codex
    ;;
  claude|*)
    if [ -n "$TASK" ]; then
      # shellcheck disable=SC2086
      exec claude $CLAUDE_FLAGS "$TASK"
    fi
    if has_claude_history; then
      # shellcheck disable=SC2086
      claude $CLAUDE_FLAGS --continue || exec claude $CLAUDE_FLAGS
    else
      # shellcheck disable=SC2086
      exec claude $CLAUDE_FLAGS
    fi
    ;;
esac
DV_DVAGENT
  chmod +x "$DV_BIN/dv-agent"

  cat > "$DV_BIN/dv-ensure" <<'DV_DVENSURE'
#!/usr/bin/env bash
# dv-ensure — make sure the devflow tmux session exists (agent + shell windows)
set -u
command -v tmux >/dev/null 2>&1 || exit 0
WORKDIR="$(cat "$HOME/.devflow/workdir" 2>/dev/null || echo "$HOME")"
AGENT="$(cat "$HOME/.devflow/agent" 2>/dev/null || echo claude)"
export PATH="$HOME/.local/bin:$HOME/.devflow/bin:$PATH"

if ! tmux has-session -t dv 2>/dev/null; then
  tmux new-session -d -s dv -n agent -c "$WORKDIR"
  case "$AGENT" in
    none) ;;
    both)
      tmux send-keys -t dv:agent "dv-agent claude" C-m
      tmux new-window -t dv -n codex -c "$WORKDIR"
      tmux send-keys -t dv:codex "dv-agent codex" C-m
      ;;
    *)
      tmux send-keys -t dv:agent "dv-agent $AGENT" C-m
      ;;
  esac
  tmux new-window -t dv -n shell -c "$WORKDIR"
  tmux select-window -t dv:agent
fi
DV_DVENSURE
  chmod +x "$DV_BIN/dv-ensure"

  cat > "$DV_BIN/dv-statusline" <<'DV_STATUSLINE'
#!/usr/bin/env bash
# claude code statusline: sandbox · model · dir · branch · context
input="$(cat)"
name="$(cat "$HOME/.devflow/name" 2>/dev/null || echo sandbox)"
if command -v jq >/dev/null 2>&1; then
  model="$(printf '%s' "$input" | jq -r '.model.display_name // "?"')"
  dir="$(printf '%s' "$input" | jq -r '.workspace.current_dir // "?"')"
  ctx="$(printf '%s' "$input" | jq -r '.context_window.used_percentage // empty' 2>/dev/null)"
else
  model="?"; dir="$PWD"; ctx=""
fi
branch="$(git -C "$dir" branch --show-current 2>/dev/null)"
out="☁ $name · $model · ${dir/#$HOME/~}"
[ -n "$branch" ] && out="$out · $branch"
[ -n "$ctx" ] && out="$out · ctx ${ctx%%.*}%"
printf '%s' "$out"
DV_STATUSLINE
  chmod +x "$DV_BIN/dv-statusline"

  # ---- start the session ----
  "$DV_BIN/dv-ensure"
  printf '%s' "$DV_PROVISION_VERSION" > "$DV_DIR/provisioned"
  log "workspace ready: agent=$DV_AGENT repo=${DV_REPO:-none} workdir=$WORKDIR"
}

# ============================ phase: harness ==================================
install_dv_subagents() {
  # devflow-native mini-team for Claude Code (always installed; dv- prefix
  # avoids collisions with oh-my-claudecode's own roster)
  mkdir -p "$HOME/.claude/agents"

  if [ ! -f "$HOME/.claude/agents/dv-engineer.md" ]; then
    cat > "$HOME/.claude/agents/dv-engineer.md" <<'DV_AG_ENG'
---
name: dv-engineer
description: Senior implementation engineer. Use for writing, refactoring, and debugging code once an approach is decided — turns a plan or bug report into working, tested changes.
---

You are a senior software engineer working inside a disposable cloud sandbox.
You own implementation quality: correct, minimal, idiomatic changes that match
the surrounding codebase.

- Read the relevant code before changing it; follow the repo's existing
  patterns, naming, and tooling.
- Prefer the smallest change that fully solves the problem. No drive-by
  refactors unless asked.
- Run the project's tests/linters after changes; fix what you break. If there
  are no tests, add focused ones for the behavior you changed.
- Commit logically-scoped changes with clear messages as you go.
- Report back: what changed, why, how it was verified, and any follow-ups.
DV_AG_ENG
  fi

  if [ ! -f "$HOME/.claude/agents/dv-designer.md" ]; then
    cat > "$HOME/.claude/agents/dv-designer.md" <<'DV_AG_DES'
---
name: dv-designer
description: Product/UX and API designer. Use before building user-facing surfaces or public interfaces — turns requirements into concrete flows, layouts, naming, and API shapes.
---

You are a pragmatic product designer who thinks in user flows and interface
contracts (UI and API alike).

- Start from the user's job-to-be-done; enumerate the primary flow and the two
  most likely edge flows before proposing surfaces.
- For UI: propose hierarchy, states (empty/loading/error), and copy. Favor
  conventions of the project's existing stack over novelty.
- For APIs/CLIs: design the smallest coherent surface; name things the way the
  codebase already names things; show example calls before writing code.
- Deliver artifacts the engineer can build from directly: annotated flows,
  component/endpoint lists, example payloads — not vague principles.
DV_AG_DES
  fi

  if [ ! -f "$HOME/.claude/agents/dv-security.md" ]; then
    cat > "$HOME/.claude/agents/dv-security.md" <<'DV_AG_SEC'
---
name: dv-security
description: Security reviewer. Use proactively after changes touching auth, input handling, secrets, network, file access, or dependencies — finds and explains real vulnerabilities with fixes.
---

You are an application security reviewer. Hunt for vulnerabilities that are
actually exploitable in this codebase — not theoretical checklist items.

- Priorities: injection (SQL/shell/template), authn/authz gaps, secret
  handling and logging, unsafe deserialization, path traversal, SSRF, unsafe
  defaults, and dependency risk.
- For each finding: the exact location, a concrete attack scenario, severity,
  and the minimal fix. Verify the fix compiles/tests when you apply one.
- Distinguish "exploitable now" from "hardening"; lead with the former.
- End with a short verdict: safe to ship, or blockers listed in order.
DV_AG_SEC
  fi
}

phase_harness() {
  log "phase 4/4 harness: multi-agent setup ($DV_HARNESS)…"

  case "$DV_HARNESS" in
    omc|omx|both)
      if ! ensure_npm; then
        log "warn: npm unavailable — skipped $DV_HARNESS install (core harness still active)"
        DV_HARNESS=core
      fi
      ;;
  esac

  if [ "$DV_HARNESS" = "omc" ] || [ "$DV_HARNESS" = "both" ]; then
    if ! command -v omc >/dev/null 2>&1; then
      log "installing oh-my-claudecode (this can take a minute)…"
      npm install -g oh-my-claude-sisyphus@latest > "$DV_DIR/omc-install.log" 2>&1 \
        || log "warn: omc npm install failed (see ~/.devflow/omc-install.log)"
      ensure_node_path
      link_global_bin omc
      link_global_bin oh-my-claudecode
      link_global_bin omc-cli
    fi
    if command -v omc >/dev/null 2>&1; then
      if omc setup --no-plugin --force --quiet </dev/null >> "$DV_DIR/omc-install.log" 2>&1; then
        log "omc ready: /autopilot, /ultrawork, /team (architect, designer, security-reviewer, +26 more)"
      else
        log "warn: omc setup failed:"
        tail -n 6 "$DV_DIR/omc-install.log" 2>/dev/null | sed 's/^/[devflow]   /'
      fi
    fi
  fi

  if [ "$DV_HARNESS" = "omx" ] || [ "$DV_HARNESS" = "both" ]; then
    if ! command -v omx >/dev/null 2>&1; then
      log "installing oh-my-codex…"
      npm install -g oh-my-codex@latest > "$DV_DIR/omx-install.log" 2>&1 \
        || log "warn: omx npm install failed (see ~/.devflow/omx-install.log)"
      ensure_node_path
      link_global_bin omx
    fi
    if command -v omx >/dev/null 2>&1; then
      if omx setup --scope user --merge-agents --force </dev/null >> "$DV_DIR/omx-install.log" 2>&1; then
        log "omx ready: launch codex sessions with 'omx' (\$ultragoal keywords, agent teams)"
      else
        log "warn: omx setup failed:"
        tail -n 6 "$DV_DIR/omx-install.log" 2>/dev/null | sed 's/^/[devflow]   /'
      fi
    fi
  fi

  # after omc setup: its installer syncs ~/.claude/agents and drops unknown
  # files, so the devflow-native trio must be (re)installed last
  install_dv_subagents
  log "core team ready: dv-engineer / dv-designer / dv-security"

  printf '%s' "$DV_HARNESS" > "$DV_DIR/harness"
  log "harness done."
}

load_secrets   # defaults + secrets file if present (tools needs pins/token too)

case "$DV_PHASE" in
  tools)     phase_tools ;;
  auth)      phase_auth ;;
  workspace) phase_workspace ;;
  harness)   phase_harness ;;
  all)       phase_tools; phase_auth; phase_workspace; phase_harness ;;
  *)         fail "unknown phase: $DV_PHASE" ;;
esac
DVPROV_EOF
}

# ----------------------------------------------------------------------------
# Provision + sync orchestration (local side)
# ----------------------------------------------------------------------------
upload_provisioner() { # NAME [WITH_SECRETS]
  local name="$1" with_secrets="${2:-1}"
  emit_provision_script | dt_push_file "$name" "/tmp/.dv-provision.sh"
  if [ "$with_secrets" = 1 ]; then
    build_secrets_bundle | dt_push_file "$name" "/tmp/.dv-secrets.env"
  fi
  dt_run "$name" 'mkdir -p "$HOME/.devflow/stage" && chmod 700 "$HOME/.devflow" "$HOME/.devflow/stage" && mv -f /tmp/.dv-provision.sh "$HOME/.devflow/stage/provision.sh" && { [ ! -f /tmp/.dv-secrets.env ] || mv -f /tmp/.dv-secrets.env "$HOME/.devflow/stage/secrets.env"; }' 120 >/dev/null
}

run_phase() { # NAME PHASE AGENT REPO BRANCH TASK_B64 [HARNESS]
  local name="$1" phase="$2" agent="$3" repo="$4" branch="$5" task_b64="$6" harness="${7:-core}"
  dt_run "$name" "DV_PHASE='$phase' DV_AGENT='$agent' DV_REPO='$repo' DV_BRANCH='$branch' DV_NAME='$name' DV_TASK_B64='$task_b64' DV_WORKROOT='$DEVFLOW_WORKROOT' DV_HARNESS='$harness' bash \"\$HOME/.devflow/stage/provision.sh\"" 0
}

provision_sandbox() { # NAME AGENT REPO BRANCH TASK HARNESS
  local name="$1" agent="$2" repo="$3" branch="$4" task="$5" harness="$6" task_b64=""
  [ -n "$task" ] && task_b64="$(printf '%s' "$task" | b64_encode)"

  step "uploading provisioner + syncing subscription auth…"
  upload_provisioner "$name" 1

  step "installing tools (tmux, gh, claude, codex — output appears when done)…"
  run_phase "$name" tools "$agent" "$repo" "$branch" "$task_b64" "$harness"

  step "applying auth…"
  run_phase "$name" auth "$agent" "$repo" "$branch" "$task_b64" "$harness"

  step "setting up workspace + starting agent session…"
  run_phase "$name" workspace "$agent" "$repo" "$branch" "$task_b64" "$harness"

  step "installing multi-agent harness ($harness)…"
  run_phase "$name" harness "$agent" "$repo" "$branch" "$task_b64" "$harness"
}

ensure_running() { # NAME — start if stopped/archived
  local st
  st="$(sandbox_state "$1")"
  case "$st" in
    started) return 0 ;;
    missing) die "no sandbox named '$1' — run: devflow up" ;;
    stopped|archived)
      step "sandbox is $st — starting…"
      dt start "$1" >/dev/null
      wait_for_state "$1" started 300
      ;;
    *)
      step "sandbox state: $st — waiting for it to start…"
      wait_for_state "$1" started 300
      ;;
  esac
}

# ----------------------------------------------------------------------------
# Sandbox listing / resolution
# ----------------------------------------------------------------------------
devflow_sandboxes_json() {
  dt list -f json 2>/dev/null \
    | jq '(if type == "object" then (.items // .sandboxes // .result // []) else . end)
          | [ .[] | select(((.labels // {})["devflow"] // "") == "1") ]'
}

resolve_name() { # [ARG] -> NAME (auto-picks when unambiguous)
  local arg="${1:-}"
  if [ -n "$arg" ]; then printf '%s' "$arg"; return 0; fi
  local names count
  names="$(devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' 2>/dev/null || true)"
  count="$(printf '%s' "$names" | grep -c . 2>/dev/null || true)"
  if [ "$count" = "1" ]; then printf '%s' "$names"; return 0; fi
  if [ "$count" = "0" ] || [ -z "$count" ]; then die "no devflow sandboxes — run: devflow up"; fi
  if have_cmd fzf && [ -t 0 ]; then
    printf '%s\n' "$names" | fzf --height=40% --reverse --prompt='sandbox> '
  else
    err "multiple sandboxes — specify one of:"
    printf '%s\n' "$names" >&2
    exit 1
  fi
}

# ----------------------------------------------------------------------------
# Commands
# ----------------------------------------------------------------------------
cmd_up() {
  local repo="" name="" branch="" agent="$DEVFLOW_AGENT" task="" attach=1 fresh=0 blank=0
  local cpu="$DEVFLOW_CPU" memory="$DEVFLOW_MEMORY" disk="$DEVFLOW_DISK" auto_stop="$DEVFLOW_AUTO_STOP"
  local snapshot="$DEVFLOW_SNAPSHOT" explicit_resources=0 harness="$DEVFLOW_HARNESS"

  while [ $# -gt 0 ]; do
    case "$1" in
      -a|--agent)   need_val "$1" "${2:-}"; agent="$2"; shift 2 ;;
      -H|--harness) need_val "$1" "${2:-}"; harness="$2"; shift 2 ;;
      -n|--name)    need_val "$1" "${2:-}"; name="$2"; shift 2 ;;
      -b|--branch)  need_val "$1" "${2:-}"; branch="$2"; shift 2 ;;
      -m|--task)    need_val "$1" "${2:-}"; task="$2"; shift 2 ;;
      --cpu)        need_val "$1" "${2:-}"; cpu="$2"; explicit_resources=1; shift 2 ;;
      --memory)     need_val "$1" "${2:-}"; memory="$2"; explicit_resources=1; shift 2 ;;
      --disk)       need_val "$1" "${2:-}"; disk="$2"; explicit_resources=1; shift 2 ;;
      --auto-stop)  need_val "$1" "${2:-}"; auto_stop="$2"; shift 2 ;;
      --snapshot)   need_val "$1" "${2:-}"; snapshot="$2"; shift 2 ;;
      --no-attach)  attach=0; shift ;;
      --fresh)      fresh=1; shift ;;
      --blank)      blank=1; shift ;;
      --pick)       repo="__PICK__"; shift ;;
      -h|--help)    usage_up; return 0 ;;
      -*)           die "unknown flag for up: $1 (see: devflow up --help)" ;;
      *)            repo="$1"; shift ;;
    esac
  done

  case "$agent" in claude|codex|both|none) ;; *) die "invalid --agent '$agent' (claude|codex|both|none)" ;; esac
  case "$harness" in auto|omc|omx|both|core|none) ;; *) die "invalid --harness '$harness' (auto|omc|omx|both|core|none)" ;; esac
  harness="$(resolve_harness "$agent" "$harness")"

  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup   (or: daytona login)"

  # --- resolve repo ---
  if [ "$blank" = 1 ]; then
    repo=""
  elif [ "$repo" = "__PICK__" ]; then
    pick_repo; repo="$REPO_PICKED"
  elif [ -n "$repo" ]; then
    local norm
    norm="$(repo_from_arg "$repo")"
    [ -n "$norm" ] || die "could not parse repo '$repo' — expected owner/name or a GitHub URL"
    repo="$norm"
  else
    repo="$(current_repo)"
    if [ -n "$repo" ]; then
      step "using current repo: ${C_BOLD}$repo${C_RESET}"
    elif [ -t 0 ]; then
      pick_repo; repo="$REPO_PICKED"
    fi
  fi

  # --- name ---
  if [ -z "$name" ]; then
    if [ -n "$repo" ]; then name="dv-$(sanitize_name "${repo##*/}")"
    else name="dv-scratch"; fi
  else
    name="$(sanitize_name "$name")"
  fi

  # --- existing sandbox? ---
  local st
  st="$(sandbox_state "$name")"
  if [ "$st" != "missing" ]; then
    if [ "$fresh" = 1 ]; then
      step "recreating '$name' (--fresh)…"
      dt delete "$name" >/dev/null 2>&1 || true
    else
      say "sandbox '$name' already exists ($st) — attaching. (--fresh recreates, -n NAME makes another)"
      cmd_attach "$name"
      return $?
    fi
  fi

  say "spinning up ${C_BOLD}$name${C_RESET}  ${C_DIM}agent=$agent harness=$harness repo=${repo:-none} ${cpu}cpu/${memory}mb/${disk}gb auto-stop=${auto_stop}m${C_RESET}"
  auth_summary

  # --- create ---
  local create_args
  create_args=(create "--name=$name" "--auto-stop=$auto_stop"
               --label devflow=1 --label "devflow.agent=$agent"
               --label "devflow.harness=$harness")
  [ -n "$repo" ] && create_args+=(--label "devflow.repo=$repo")
  if [ -n "$snapshot" ]; then
    create_args+=("--snapshot=$snapshot")
    [ "$explicit_resources" = 1 ] && create_args+=("--cpu=$cpu" "--memory=$memory" "--disk=$disk")
  else
    create_args+=("--cpu=$cpu" "--memory=$memory" "--disk=$disk")
  fi
  [ -n "$DEVFLOW_TARGET" ] && create_args+=("--target=$DEVFLOW_TARGET")

  step "creating sandbox…"
  dt "${create_args[@]}" || die "sandbox create failed (check quota/billing at app.daytona.io)"
  wait_for_state "$name" started 300
  ok "sandbox running"

  provision_sandbox "$name" "$agent" "$repo" "$branch" "$task" "$harness"
  ok "provisioned"

  if [ -n "$task" ]; then
    say "the agent is on it. it keeps working even when you're not attached."
    step "peek progress:  ${C_BOLD}devflow peek $name${C_RESET}"
    step "join session:   ${C_BOLD}devflow attach $name${C_RESET}"
  fi

  if [ "$attach" = 1 ] && [ -t 0 ]; then
    cmd_attach "$name"
  else
    ok "up. attach anytime, from any machine:  ${C_BOLD}devflow attach $name${C_RESET}"
  fi
}

cmd_attach() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup"
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  [ -n "$name" ] || exit 1
  ensure_running "$name"
  # if the sandbox restarted, this recreates the tmux session + resumes the agent
  dt_run "$name" '"$HOME/.devflow/bin/dv-ensure" 2>/dev/null || true' 60 >/dev/null 2>&1 || true
  say "attaching to ${C_BOLD}$name${C_RESET} ${C_DIM}(detach: Ctrl-b d — the session keeps running)${C_RESET}"
  exec daytona ssh "$name"
}

cmd_ssh() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  ensure_running "$name"
  exec daytona ssh "$name"
}

cmd_ssh_command() { # print a plain `ssh` command usable from any machine
  need_cmd jq "brew install jq"
  need_cmd curl "install curl"
  local name="" expires=1440
  while [ $# -gt 0 ]; do
    case "$1" in
      --expires) need_val "$1" "${2:-}"; expires="$2"; shift 2 ;;
      *) name="$1"; shift ;;
    esac
  done
  name="$(resolve_name "$name")" || exit 1
  ensure_running "$name"

  local api_key="${DAYTONA_API_KEY:-}" api_url="${DAYTONA_API_URL:-https://app.daytona.io/api}" cfg=""
  if [ -z "$api_key" ]; then
    for cfg in "$HOME/Library/Application Support/daytona/config.json" \
               "${XDG_CONFIG_HOME:-$HOME/.config}/daytona/config.json"; do
      [ -f "$cfg" ] || continue
      api_key="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
                 | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
                 | (.api.key // .api.token // empty)' "$cfg" 2>/dev/null | head -1)"
      local u
      u="$(jq -r '. as $c | ($c.activeProfile // "default") as $a
                 | ($c.profiles // [])[] | select((.id // .name) == $a or .name == $a)
                 | (.api.url // empty)' "$cfg" 2>/dev/null | head -1)"
      [ -n "$u" ] && api_url="$u"
      [ -n "$api_key" ] && break
    done
  fi
  [ -n "$api_key" ] || die "no Daytona API key available — use 'devflow ssh $name' instead, or set DAYTONA_API_KEY"

  local sandbox_id resp
  sandbox_id="$(dt_info_json "$name" | jq -r '.id // .sandboxId // empty')"
  [ -n "$sandbox_id" ] || die "could not resolve sandbox id for '$name'"
  resp="$(curl -fsSL -X POST -H "Authorization: Bearer $api_key" \
          "$api_url/sandbox/$sandbox_id/ssh-access?expiresInMinutes=$expires" 2>/dev/null)" \
    || die "ssh-access API call failed — fall back to: devflow ssh $name"
  local sshcmd token
  sshcmd="$(printf '%s' "$resp" | jq -r '.sshCommand // empty')"
  token="$(printf '%s' "$resp" | jq -r '.token // empty')"
  if [ -z "$sshcmd" ] && [ -n "$token" ]; then
    sshcmd="ssh $token@ssh.app.daytona.io"
  fi
  [ -n "$sshcmd" ] || die "unexpected ssh-access response — fall back to: devflow ssh $name"
  say "valid for ${expires}m — run from any machine with plain ssh:"
  printf '%s\n' "$sshcmd"
}

cmd_exec() {
  local name="${1:-}"
  [ -n "$name" ] || die "usage: devflow exec NAME -- CMD…"
  shift
  [ "${1:-}" = "--" ] && shift
  [ $# -gt 0 ] || die "usage: devflow exec NAME -- CMD…"
  ensure_running "$name"
  dt_run "$name" "$*" 0
}

cmd_peek() {
  local name="" lines=40
  while [ $# -gt 0 ]; do
    case "$1" in
      --lines) need_val "$1" "${2:-}"; lines="$2"; shift 2 ;;
      *) name="$1"; shift ;;
    esac
  done
  name="$(resolve_name "$name")" || exit 1
  local st
  st="$(sandbox_state "$name")"
  if [ "$st" != "started" ]; then
    say "'$name' is ${st} — nothing running to peek at. ${C_DIM}devflow attach $name restarts it.${C_RESET}"
    return 0
  fi
  say "agent pane in ${C_BOLD}$name${C_RESET} (last $lines lines):"
  dt_run "$name" "tmux capture-pane -p -t dv:agent -S -$lines 2>/dev/null || echo '(no tmux session yet — devflow attach $name)'" 60
}

cmd_ls() {
  need_cmd daytona "brew install daytonaio/cli/daytona"
  need_cmd jq "brew install jq"
  dt_auth_check || die "not logged in to Daytona — run: devflow setup"
  local json count
  json="$(devflow_sandboxes_json)"
  count="$(printf '%s' "$json" | jq 'length')"
  if [ "$count" = "0" ]; then
    say "no devflow sandboxes yet. start one:  ${C_BOLD}devflow up${C_RESET}"
    return 0
  fi
  printf '%s\n' "${C_BOLD}NAME                     STATE      AGENT   REPO                              CPU/MEM${C_RESET}"
  printf '%s' "$json" | jq -r '.[] | [
      (.name // .id // "?"),
      (.state // .status // "?"),
      ((.labels // {})["devflow.agent"] // "-"),
      ((.labels // {})["devflow.repo"] // "-"),
      (((.cpu // "?") | tostring) + "c/" + ((.memory // "?") | tostring) + "m")
    ] | @tsv' \
  | while IFS=$'\t' read -r n s a r c; do
      local color="$C_DIM"
      [ "$s" = "started" ] && color="$C_GREEN"
      printf '%-24s %s%-10s%s %-7s %-33s %s\n' "$n" "$color" "$s" "$C_RESET" "$a" "$r" "$c"
    done
}

cmd_stop() {
  need_cmd jq "brew install jq"
  if [ "${1:-}" = "--all" ]; then
    local n
    devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' | while read -r n; do
      [ -n "$n" ] || continue
      step "stopping $n…"
      dt stop "$n" </dev/null >/dev/null 2>&1 || true
    done
    ok "all devflow sandboxes stopped"
    return 0
  fi
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  dt stop "$name"
  ok "stopped '$name' — disk preserved; 'devflow attach $name' restarts and resumes the agent"
}

cmd_rm() {
  need_cmd jq "brew install jq"
  local force=0 all=0 name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      --all) all=1; shift ;;
      *) name="$1"; shift ;;
    esac
  done
  if [ "$all" = 1 ]; then
    if [ "$force" != 1 ]; then confirm "delete ALL devflow sandboxes (unpushed work in them is lost)?" || exit 1; fi
    local n
    devflow_sandboxes_json | jq -r '.[] | (.name // .id // empty)' | while read -r n; do
      [ -n "$n" ] || continue
      step "deleting $n…"
      dt delete "$n" </dev/null >/dev/null 2>&1 || true
    done
    ok "all devflow sandboxes deleted"
    return 0
  fi
  name="$(resolve_name "$name")" || exit 1
  if [ "$force" != 1 ]; then confirm "delete sandbox '$name'? unpushed work in it is lost" || exit 1; fi
  dt delete "$name"
  ok "deleted '$name'"
}

cmd_sync() {
  need_cmd jq "brew install jq"
  local name
  name="$(resolve_name "${1:-}")" || exit 1
  ensure_running "$name"
  step "re-syncing subscription auth into '$name'…"
  upload_provisioner "$name" 1
  run_phase "$name" auth "" "" "" ""
  ok "auth refreshed in '$name'"
}

cmd_token() {
  need_cmd claude "curl -fsSL https://claude.ai/install.sh | bash"
  say "launching ${C_BOLD}claude setup-token${C_RESET} — approve in the browser, then copy the token it prints."
  claude setup-token || warn "setup-token exited non-zero"
  printf '%s' "paste token (sk-ant-oat01-…, input hidden): "
  local tok
  read -rs tok || true
  printf '\n'
  [ -n "$tok" ] || die "no token entered"
  case "$tok" in
    sk-ant-oat01-*) ;;
    *) warn "that doesn't look like a setup-token (expected sk-ant-oat01-…) — storing anyway" ;;
  esac
  config_set "$SECRETS_FILE" DEVFLOW_CLAUDE_TOKEN "$tok"
  ok "stored in $SECRETS_FILE (600). New sandboxes use it; refresh existing ones with: devflow sync"
}

cmd_config() {
  case "${1:-list}" in
    list)
      say "config file: $CONFIG_FILE"
      if [ -f "$CONFIG_FILE" ]; then sed 's/^/  /' "$CONFIG_FILE"; else echo "  (defaults — nothing set)"; fi
      ;;
    get)  [ -n "${2:-}" ] || die "usage: devflow config get KEY"
          eval "printf '%s\n' \"\${$2:-}\"" ;;
    set)  [ -n "${2:-}" ] && [ -n "${3:-}" ] || die "usage: devflow config set KEY VALUE"
          config_set "$CONFIG_FILE" "$2" "$3"; ok "$2 set" ;;
    edit) mkdir -p "$CONFIG_DIR"; "${EDITOR:-vi}" "$CONFIG_FILE" ;;
    *)    die "usage: devflow config [list|get KEY|set KEY VALUE|edit]" ;;
  esac
}

cmd_dashboard() {
  local url="https://app.daytona.io"
  if have_cmd open; then open "$url"; elif have_cmd xdg-open; then xdg-open "$url"; else say "$url"; fi
}

# ----------------------------------------------------------------------------
# setup & doctor
# ----------------------------------------------------------------------------
check_row() { # LABEL STATUS DETAIL
  local label="$1" status="$2" detail="${3:-}"
  case "$status" in
    ok)   printf '  %s %-26s %s\n' "${C_GREEN}✓${C_RESET}" "$label" "${C_DIM}$detail${C_RESET}" ;;
    warn) printf '  %s %-26s %s\n' "${C_YELLOW}!${C_RESET}" "$label" "$detail" ;;
    fail) printf '  %s %-26s %s\n' "${C_RED}✗${C_RESET}" "$label" "$detail" ;;
  esac
}

cmd_doctor() {
  say "$DEVFLOW_VERSION — environment check"
  echo
  printf '%s\n' "${C_BOLD}local tools${C_RESET}"
  local spec c fix
  for spec in "daytona|brew install daytonaio/cli/daytona" "jq|brew install jq" "git|xcode-select --install / apt install git" "gh|brew install gh" "fzf|brew install fzf (optional: nicer pickers)"; do
    c="${spec%%|*}"; fix="${spec#*|}"
    if have_cmd "$c"; then check_row "$c" ok "$(command -v "$c")"
    else
      case "$c" in fzf) check_row "$c" warn "missing — $fix" ;; *) check_row "$c" fail "missing — $fix" ;; esac
    fi
  done
  echo
  printf '%s\n' "${C_BOLD}accounts${C_RESET}"
  if have_cmd daytona && dt_auth_check; then
    check_row "daytona" ok "logged in"
  else
    check_row "daytona" fail "daytona login   (API keys: app.daytona.io/dashboard/keys)"
  fi
  if have_cmd gh && gh auth status >/dev/null 2>&1; then
    check_row "github (gh)" ok "$(gh api user -q .login 2>/dev/null || echo 'logged in')"
  else
    check_row "github (gh)" fail "gh auth login"
  fi
  harvest_all
  case "$CLAUDE_MODE" in
    token) check_row "claude (subscription)" ok "long-lived token configured" ;;
    creds) check_row "claude (subscription)" ok "local credentials found (tip: devflow token)" ;;
    *)     check_row "claude (subscription)" warn "none — run 'devflow token' (or log in to claude locally)" ;;
  esac
  # shellcheck disable=SC2088  # display text, not a path
  if [ -n "$CODEX_AUTH_B64" ]; then check_row "codex (chatgpt)" ok "~/.codex/auth.json present"
  else check_row "codex (chatgpt)" warn "none — run 'codex' locally, sign in with ChatGPT"; fi
  echo
  printf '%s\n' "${C_BOLD}defaults${C_RESET}"
  check_row "agent" ok "$DEVFLOW_AGENT"
  check_row "harness" ok "$DEVFLOW_HARNESS (auto → omc for claude, omx for codex)"
  check_row "resources" ok "${DEVFLOW_CPU}cpu / ${DEVFLOW_MEMORY}mb / ${DEVFLOW_DISK}gb"
  check_row "auto-stop" ok "${DEVFLOW_AUTO_STOP}m (0 = runs until 'devflow stop')"
  [ -n "$DEVFLOW_SNAPSHOT" ] && check_row "snapshot" ok "$DEVFLOW_SNAPSHOT"
  echo
  say "ready? try:  ${C_BOLD}devflow up${C_RESET}"
}

cmd_setup() {
  say "$DEVFLOW_VERSION setup — cloud agent sessions on your subscriptions"
  mkdir -p "$CONFIG_DIR"; chmod 700 "$CONFIG_DIR"
  echo

  step "1/5 dependencies…"
  local missing="" c
  for c in daytona jq git gh; do have_cmd "$c" || missing="$missing $c"; done
  if [ -n "$missing" ]; then
    if have_cmd brew; then
      if confirm "install missing tools via Homebrew:$missing?"; then
        for c in $missing; do
          case "$c" in
            daytona) brew install daytonaio/cli/daytona ;;
            *)       brew install "$c" ;;
          esac
        done
      fi
    else
      warn "missing:$missing — install them and re-run devflow setup"
    fi
  fi
  ok "dependencies"

  step "2/5 Daytona account (sandbox cloud — \$200 free compute for new accounts)…"
  if have_cmd daytona && dt_auth_check; then
    ok "already logged in to Daytona"
  else
    say "a browser opens to sign in / sign up at app.daytona.io"
    if confirm "run 'daytona login' now?"; then
      dt login || warn "login failed — alternative: daytona login --api-key KEY (app.daytona.io/dashboard/keys)"
    else
      warn "skipped — run 'daytona login' before 'devflow up'"
    fi
  fi

  step "3/5 Claude Code subscription auth…"
  harvest_all
  case "$CLAUDE_MODE" in
    token) ok "long-lived token already configured" ;;
    creds)
      ok "local subscription credentials detected — they'll be copied into sandboxes"
      say "recommended: a dedicated 1-year token avoids login races between laptop and sandbox."
      if confirm "create one now with 'claude setup-token'?"; then cmd_token; fi
      ;;
    *)
      warn "no Claude credentials found"
      if have_cmd claude && confirm "run 'claude setup-token' now (needs Pro/Max subscription)?"; then cmd_token; fi
      ;;
  esac

  step "4/5 Codex (ChatGPT) auth…"
  if [ -n "${CODEX_AUTH_B64:-}" ]; then
    # shellcheck disable=SC2088  # display text, not a path
    ok "~/.codex/auth.json found — it'll be copied into sandboxes"
  else
    warn "not signed in to Codex — run 'codex', pick 'Sign in with ChatGPT', then re-run setup"
  fi

  step "5/5 GitHub + defaults…"
  if have_cmd gh && gh auth status >/dev/null 2>&1; then
    ok "gh authenticated"
  else
    if have_cmd gh && confirm "run 'gh auth login' now?"; then gh auth login; fi
  fi
  if [ -t 0 ]; then
    printf 'default agent [claude/codex/both] (claude): '
    local a; read -r a || true
    case "$a" in codex|both) config_set "$CONFIG_FILE" DEVFLOW_AGENT "$a"; ok "default agent: $a" ;; *) ;; esac
  fi
  echo
  ok "setup complete — verify with ${C_BOLD}devflow doctor${C_RESET}, then run ${C_BOLD}devflow up${C_RESET}"
}

# ----------------------------------------------------------------------------
# Custom snapshot (optional: instant starts)
# ----------------------------------------------------------------------------
emit_dockerfile() {
cat <<'DV_DOCKERFILE'
# devflow base snapshot — agents + tools prebaked for instant session starts.
# Built server-side by Daytona:  devflow snapshot build
FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash ca-certificates curl git jq ripgrep sudo tmux unzip xz-utils \
      python3 python3-pip openssh-client less nano vim-tiny locales \
    && rm -rf /var/lib/apt/lists/*
# non-root user with passwordless sudo (claude bypass mode refuses root)
RUN userdel -r ubuntu 2>/dev/null || true; \
    useradd -m -s /bin/bash -u 1000 daytona && \
    echo 'daytona ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/91-daytona
USER daytona
WORKDIR /home/daytona
ENV HOME=/home/daytona
ENV PATH="/home/daytona/.local/bin:${PATH}"
RUN mkdir -p "$HOME/.local/bin" && \
    curl -fsSL https://claude.ai/install.sh | bash && \
    GH_V=2.96.0 && \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_V}/gh_${GH_V}_linux_amd64.tar.gz" | tar -xz -C /tmp && \
    cp "/tmp/gh_${GH_V}_linux_amd64/bin/gh" "$HOME/.local/bin/gh" && \
    curl -fsSL "https://github.com/openai/codex/releases/download/rust-v0.142.5/codex-x86_64-unknown-linux-musl.tar.gz" | tar -xz -C /tmp && \
    find /tmp -maxdepth 1 -name 'codex*' -type f -exec cp {} "$HOME/.local/bin/codex" \; && \
    chmod +x "$HOME"/.local/bin/* && \
    "$HOME/.local/bin/claude" --version && "$HOME/.local/bin/codex" --version && "$HOME/.local/bin/gh" --version
# node + the oh-my-* multi-agent harnesses, prebaked for instant session starts
RUN export NVM_DIR="$HOME/.nvm" && \
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash && \
    . "$NVM_DIR/nvm.sh" && nvm install 22 && \
    npm config set prefix "$HOME/.local" && \
    npm install -g oh-my-claude-sisyphus@latest oh-my-codex@latest && \
    "$HOME/.local/bin/omc" --version && "$HOME/.local/bin/omx" --version
CMD ["sleep", "infinity"]
DV_DOCKERFILE
}

cmd_snapshot() {
  case "${1:-}" in
    build)
      need_cmd daytona "brew install daytonaio/cli/daytona"
      dt_auth_check || die "not logged in to Daytona — run: devflow setup"
      local snap_name="devflow-base-$DEVFLOW_VERSION" tmp mem_gb
      mem_gb=$((DEVFLOW_MEMORY / 1024)); [ "$mem_gb" -lt 1 ] && mem_gb=1
      tmp="$(mktemp -d "${TMPDIR:-/tmp}/devflow-snap.XXXXXX")"
      emit_dockerfile >"$tmp/Dockerfile"
      say "building snapshot ${C_BOLD}$snap_name${C_RESET} on Daytona (one-time, a few minutes)…"
      if dt snapshot create "$snap_name" --dockerfile "$tmp/Dockerfile" \
           "--cpu=$DEVFLOW_CPU" "--memory=$mem_gb" "--disk=$DEVFLOW_DISK"; then
        config_set "$CONFIG_FILE" DEVFLOW_SNAPSHOT "$snap_name"
        rm -rf "$tmp"
        ok "snapshot built + set as default — new sandboxes now start in seconds"
      else
        rm -rf "$tmp"
        die "snapshot build failed (see output above)"
      fi
      ;;
    dockerfile) emit_dockerfile ;;
    *) die "usage: devflow snapshot [build|dockerfile]" ;;
  esac
}

# ----------------------------------------------------------------------------
# Help
# ----------------------------------------------------------------------------
usage_up() {
cat <<EOF
${C_BOLD}devflow up${C_RESET} [REPO] [flags] — create (or reattach to) a cloud agent session

  REPO                owner/name or GitHub URL; omit to use the current repo,
                      or get a picker of your GitHub repos

  -a, --agent A       claude | codex | both | none     (default: $DEVFLOW_AGENT)
  -H, --harness H     multi-agent harness: auto | omc | omx | both | core
                      (default: $DEVFLOW_HARNESS — auto matches the agent:
                      oh-my-claudecode for claude, oh-my-codex for codex;
                      core = devflow's built-in dv-engineer/designer/security)
  -m, --task "…"      hand the agent a task right away; add --no-attach to
                      fire-and-forget, then 'devflow peek' to check on it
  -b, --branch B      checkout (or create) branch B
  -n, --name N        sandbox name (default: dv-<repo>)
      --blank         no repo — empty scratch sandbox
      --pick          force the repo picker
      --fresh         delete + recreate if the sandbox already exists
      --no-attach     don't SSH in after starting
      --cpu N | --memory MB | --disk GB   resources (default ${DEVFLOW_CPU}/${DEVFLOW_MEMORY}/${DEVFLOW_DISK})
      --auto-stop MIN 0 = keep running until 'devflow stop' (default ${DEVFLOW_AUTO_STOP})
      --snapshot S    custom snapshot (see: devflow snapshot build)
EOF
}

usage() {
cat <<EOF
${C_CYAN}${C_BOLD}devflow${C_RESET} $DEVFLOW_VERSION — agentic cloud dev sessions on Daytona, powered by your subscriptions

${C_BOLD}start here${C_RESET}
  devflow setup                 one-time: accounts + auth (no API keys needed)
  devflow up [REPO]             spin up Claude Code / Codex on a repo & attach
  devflow up -m "fix bug X" --no-attach    fire-and-forget, close your laptop

  every sandbox gets a multi-agent harness: oh-my-claudecode (/autopilot,
  /team, 29 agents) with claude, oh-my-codex with codex, plus devflow's own
  dv-engineer / dv-designer / dv-security subagents. tune: --harness

${C_BOLD}daily driving${C_RESET}
  devflow attach [NAME]   (a)   reattach from anywhere — tmux keeps it alive
  devflow peek [NAME]           glance at the agent without attaching
  devflow ls                    list sandboxes
  devflow stop [NAME|--all]     stop (disk kept) — attach restarts + resumes
  devflow rm [NAME|--all]       delete sandbox
  devflow sync [NAME]           re-sync subscription auth into a sandbox

${C_BOLD}more${C_RESET}
  devflow ssh [NAME]            SSH in (lands in tmux; detach: Ctrl-b d)
  devflow ssh-command [NAME]    print a plain ssh command for any machine
  devflow exec NAME -- CMD      run a one-off command in a sandbox
  devflow token                 store a 1-year Claude subscription token
  devflow snapshot build        prebake a snapshot for instant starts
  devflow doctor                check local setup
  devflow config [set K V]      defaults (agent, resources, auto-stop…)
  devflow dashboard             open app.daytona.io

Docs: https://github.com/dalinkstone/devflow
EOF
}

# ----------------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  [ $# -gt 0 ] && shift
  load_config

  case "$cmd" in
    up|start|new)         cmd_up "$@" ;;
    attach|a|open)        cmd_attach "$@" ;;
    ssh)                  cmd_ssh "$@" ;;
    ssh-command|ssh-cmd)  cmd_ssh_command "$@" ;;
    exec)                 cmd_exec "$@" ;;
    peek|watch)           cmd_peek "$@" ;;
    ls|list|ps)           cmd_ls "$@" ;;
    stop)                 cmd_stop "$@" ;;
    rm|delete|down)       cmd_rm "$@" ;;
    sync)                 cmd_sync "$@" ;;
    token)                cmd_token "$@" ;;
    setup|init)           cmd_setup "$@" ;;
    doctor|check)         cmd_doctor "$@" ;;
    config)               cmd_config "$@" ;;
    snapshot)             cmd_snapshot "$@" ;;
    dashboard)            cmd_dashboard "$@" ;;
    __provision-script)   emit_provision_script ;;
    __dockerfile)         emit_dockerfile ;;
    version|--version|-v) echo "devflow $DEVFLOW_VERSION" ;;
    help|--help|-h)       usage ;;
    *)                    err "unknown command: $cmd"; echo; usage; exit 1 ;;
  esac
}

main "$@"
